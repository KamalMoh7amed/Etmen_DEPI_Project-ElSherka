@using Etmen_PL.Models.ViewModels.Doctor
@model DoctorDashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم الذكية للعيادة";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<!-- Load Chart.js and FontAwesome -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    :root {
        --primary-glass: rgba(26, 111, 191, 0.08);
        --success-glass: rgba(40, 167, 69, 0.08);
        --warning-glass: rgba(255, 193, 7, 0.08);
        --danger-glass: rgba(220, 53, 69, 0.08);
        --purple-glass: rgba(142, 68, 173, 0.08);
        
        --glow-blue: rgba(26, 111, 191, 0.2);
        --glow-green: rgba(39, 174, 96, 0.2);
    }

    body {
        background-color: #f4f7fa;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 24px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
    }
    .glass-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.09);
        background: rgba(255, 255, 255, 0.8);
        border-color: rgba(26, 111, 191, 0.25);
    }

    /* ═══ DOCTOR HERO CARD ═════════════════════════════════ */
    .dr-hero-premium {
        position: relative;
        border-radius: 30px;
        padding: 3rem;
        background: linear-gradient(135deg, #0A1C2C 0%, #156082 50%, #1a6fbf 100%) !important;
        box-shadow: 0 20px 40px rgba(10, 28, 44, 0.25);
        color: white;
        overflow: hidden;
        z-index: 1;
    }
    .dr-hero-premium::before {
        content: '';
        position: absolute;
        top: -30%; left: -20%;
        width: 450px; height: 450px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0, 201, 167, 0.25) 0%, transparent 60%);
        filter: blur(40px);
        z-index: -1;
        animation: floatBg 8s ease-in-out infinite alternate;
    }
    .dr-hero-premium::after {
        content: '';
        position: absolute;
        bottom: -30%; right: -10%;
        width: 350px; height: 350px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(26, 111, 191, 0.2) 0%, transparent 60%);
        filter: blur(35px);
        z-index: -1;
        animation: floatBg 10s ease-in-out infinite alternate-reverse;
    }
    @@keyframes floatBg {
        0% { transform: translate(0, 0); }
        100% { transform: translate(30px, 20px); }
    }

    /* ═══ STATS METRICS ════════════════════════════════════ */
    .metric-icon-box {
        width: 60px; height: 60px;
        border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 8px 20px rgba(0,0,0,0.02);
        transition: all 0.3s;
    }
    .glass-card:hover .metric-icon-box {
        transform: scale(1.1) rotate(-8deg);
    }
    .metric-blue { background: var(--primary-glass); color: var(--primary); }
    .metric-orange { background: var(--warning-glass); color: #e67e22; }
    .metric-green { background: var(--success-glass); color: var(--success); }
    .metric-purple { background: var(--purple-glass); color: #9b59b6; }

    /* ═══ INTERACTIVE CALENDAR WIDGET ══════════════════════ */
    .calendar-container {
        padding: 1.5rem;
    }
    .calendar-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 1.5rem;
    }
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
        text-align: center;
    }
    .calendar-day-name {
        font-weight: 800;
        font-size: 0.78rem;
        color: var(--text-muted);
        text-transform: uppercase;
        padding-bottom: 8px;
    }
    .calendar-day-cell {
        aspect-ratio: 1;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--dark);
        cursor: pointer;
        position: relative;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }
    .calendar-day-cell:hover {
        background: var(--primary-glass);
        color: var(--primary);
        border-color: rgba(26, 111, 191, 0.2);
    }
    .calendar-day-cell.today {
        background: var(--primary) !important;
        color: white !important;
        box-shadow: 0 6px 15px rgba(26, 111, 191, 0.3);
    }
    .calendar-day-cell.active-day {
        border: 2px solid var(--primary);
        background: rgba(26, 111, 191, 0.05);
    }
    .calendar-day-cell.has-events::after {
        content: '';
        position: absolute;
        bottom: 5px;
        width: 6px; height: 6px;
        background-color: var(--primary);
        border-radius: 50%;
    }
    .calendar-day-cell.today.has-events::after {
        background-color: white;
    }
    .calendar-day-cell.other-month {
        opacity: 0.3;
        cursor: default;
    }
    .calendar-day-cell.other-month:hover {
        background: transparent;
        color: inherit;
        border-color: transparent;
    }

    /* ═══ LIVE QUEUE TRACKER ═══════════════════════════════ */
    .live-indicator {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--danger);
        background: rgba(220, 53, 69, 0.1);
        padding: 4px 12px;
        border-radius: 20px;
        animation: pulseLive 2s infinite;
    }
    @@keyframes pulseLive {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }

    /* ═══ QUICK CONSULTATION SLIDE-OVER PANEL ══════════════ */
    .slide-over-panel {
        position: fixed;
        top: 0; right: -420px;
        width: 400px; height: 100vh;
        background: white;
        box-shadow: -10px 0 40px rgba(0,0,0,0.1);
        z-index: 1050;
        transition: right 0.4s cubic-bezier(0.77, 0, 0.175, 1);
        display: flex; flex-direction: column;
        border-left: 1px solid var(--border);
    }
    .slide-over-panel.show {
        right: 0;
    }
    .slide-over-header {
        padding: 1.5rem;
        border-bottom: 1px solid #f0f4f8;
        display: flex; justify-content: space-between; align-items: center;
        background: var(--primary);
        color: white;
    }
    .slide-over-body {
        padding: 1.5rem;
        overflow-y: auto;
        flex-grow: 1;
    }

    /* ═══ SWITCH STYLING ═══════════════════════════════════ */
    .form-switch-custom {
        display: flex; align-items: center; gap: 8px;
    }
    .form-switch-custom input {
        width: 2.5rem; height: 1.25rem;
        cursor: pointer;
    }
</style>

<div class="container-fluid py-2 animate__animated animate__fadeIn">
    <!-- Welcome Header -->
    <div class="dr-hero-premium mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-white-50 text-white mb-2 px-3 py-1.5 fw-bold" style="font-size:0.8rem; background:rgba(255,255,255,0.15);">
                    <i class="fas fa-chart-pie me-1"></i> بوابة الطبيب الرقمية الذكية
                </span>
                <h1 class="fw-black mb-1">دكتور @Model.DoctorName</h1>
                <p class="mb-0 text-white-50 fw-semibold">
                    <i class="fas fa-stethoscope me-1"></i> تخصصك: @(Model.Specialization ?? "طبيب عام")
                    <span class="mx-2">|</span>
                    <i class="far fa-calendar-alt me-1"></i> اليوم: @DateTime.Now.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
                </p>
            </div>
            <div class="col-md-4 text-md-start text-center mt-3 mt-md-0">
                <a href="/DoctorClinic" class="btn btn-light rounded-pill px-4 py-2 fw-800 text-primary">
                    <i class="fas fa-clinic-medical me-1"></i> لوحة إدارة العيادة والمنشأة <i class="fas fa-chevron-left ms-1" style="font-size:0.75rem;"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Stats Cards Row -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-lg-6 col-md-6 col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="fw-bold fs-2 text-dark mb-1">@Model.TodayAppointmentsCount</h3>
                        <span class="text-muted small fw-bold">مواعيد اليوم</span>
                    </div>
                    <div class="metric-icon-box metric-blue"><i class="fas fa-calendar-day"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="fw-bold fs-2 text-dark mb-1">@Model.PendingAppointmentsCount</h3>
                        <span class="text-muted small fw-bold">مواعيد قيد التأكيد</span>
                    </div>
                    <div class="metric-icon-box metric-orange"><i class="fas fa-user-clock"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="fw-bold fs-2 text-dark mb-1">@Model.TotalPatientsCount</h3>
                        <span class="text-muted small fw-bold">إجمالي المرضى بالمنظومة</span>
                    </div>
                    <div class="metric-icon-box metric-green"><i class="fas fa-user-injured"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="fw-bold fs-2 text-dark mb-1">@(Model.AverageRating.HasValue ? Model.AverageRating.Value.ToString("F1") : "5.0")</h3>
                        <span class="text-muted small fw-bold">تقييم العيادة</span>
                    </div>
                    <div class="metric-icon-box metric-purple"><i class="fas fa-star"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Live Clinic Queue Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="glass-card p-4 border-primary">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold m-0"><i class="fas fa-hospital-user text-primary me-2"></i> حالة طابور العيادة المباشر</h5>
                    <span class="live-indicator"><i class="fas fa-circle text-danger" style="font-size:0.6rem;"></i> مباشر / عيادة</span>
                </div>
                <div id="queue-loader" class="text-center py-3 d-none">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
                <div class="row g-3" id="queue-container">
                    <!-- Current Patient -->
                    <div class="col-lg-5 col-12">
                        <div class="p-3 border rounded-4 bg-light d-flex align-items-center gap-3">
                            <div class="avatar-circle bg-primary text-white fs-3" style="width:50px;height:50px;">
                                <i class="fas fa-user-md"></i>
                            </div>
                            <div class="flex-grow-1">
                                <small class="text-muted d-block fw-bold mb-1">المريض الحالي بالفحص</small>
                                <span class="fw-bold text-dark fs-5" id="current-patient-name">لا يوجد مريض حالياً</span>
                                <small class="text-muted d-block" id="current-patient-time">-</small>
                            </div>
                            <div id="current-patient-actions" class="d-none">
                                <button onclick="completeCurrentPatient()" class="btn btn-sm btn-success rounded-pill px-3"><i class="fas fa-check"></i> إنهاء الفحص</button>
                            </div>
                        </div>
                    </div>
                    <!-- Next Patient -->
                    <div class="col-lg-4 col-12">
                        <div class="p-3 border rounded-4 bg-light d-flex align-items-center gap-3">
                            <div class="avatar-circle bg-info text-white fs-4" style="width:50px;height:50px;">
                                <i class="fas fa-arrow-left"></i>
                            </div>
                            <div class="flex-grow-1">
                                <small class="text-muted d-block fw-bold mb-1">المريض القادم في الانتظار</small>
                                <span class="fw-bold text-dark fs-6" id="next-patient-name">لا يوجد مريض منتظر</span>
                                <small class="text-muted d-block" id="next-patient-time">-</small>
                            </div>
                            <div id="next-patient-actions" class="d-none">
                                <button onclick="callNextPatient()" class="btn btn-sm btn-primary rounded-pill px-3"><i class="fas fa-bullhorn"></i> نداء مريض</button>
                            </div>
                        </div>
                    </div>
                    <!-- Queue Count Stats -->
                    <div class="col-lg-3 col-12">
                        <div class="p-3 border rounded-4 bg-light d-flex justify-content-around text-center h-100 align-items-center">
                            <div>
                                <h3 class="fw-bold text-primary mb-0" id="queue-waiting-count">0</h3>
                                <small class="text-muted fw-bold">المنتظرون</small>
                            </div>
                            <div class="border-start h-50"></div>
                            <div>
                                <h3 class="fw-bold text-success mb-0" id="queue-completed-count">0</h3>
                                <small class="text-muted fw-bold">تم إنهاء فحصهم اليوم</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Calendar & Day schedule Grid -->
    <div class="row g-4 mb-4">
        <!-- Interactive Calendar Widget -->
        <div class="col-xl-5 col-lg-6 col-12">
            <div class="glass-card calendar-container h-100">
                <div class="calendar-header">
                    <h5 class="fw-bold m-0"><i class="far fa-calendar-alt text-primary me-2"></i> منظم المواعيد التفاعلي</h5>
                    <div class="d-flex align-items-center gap-2">
                        <button onclick="prevMonth()" class="btn btn-sm btn-outline-secondary rounded-circle"><i class="fas fa-chevron-right"></i></button>
                        <span id="calendar-month-year" class="fw-bold text-dark fs-6" style="min-width: 100px; text-align: center;">يونيو 2026</span>
                        <button onclick="nextMonth()" class="btn btn-sm btn-outline-secondary rounded-circle"><i class="fas fa-chevron-left"></i></button>
                    </div>
                </div>
                <div class="calendar-grid mb-3">
                    <div class="calendar-day-name">أح</div>
                    <div class="calendar-day-name">ثن</div>
                    <div class="calendar-day-name">ثل</div>
                    <div class="calendar-day-name">رب</div>
                    <div class="calendar-day-name">خم</div>
                    <div class="calendar-day-name">جم</div>
                    <div class="calendar-day-name">سب</div>
                </div>
                <div class="calendar-grid" id="calendar-days-grid">
                    <!-- Loaded dynamically via JS -->
                </div>
            </div>
        </div>

        <!-- Daily Schedule Drilldown panel -->
        <div class="col-xl-7 col-lg-6 col-12">
            <div class="glass-card p-4 h-100 d-flex flex-column">
                <div class="dr-card-header d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="dr-card-title m-0"><i class="far fa-calendar-check text-primary me-2"></i> جدول أعمال اليوم المختار</h5>
                        <small id="schedule-date-title" class="text-muted fw-bold">14 يونيو 2026</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button id="block-day-btn" onclick="blockSelectedDay()" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="fas fa-ban"></i> قفل اليوم بالكامل</button>
                    </div>
                </div>

                <div class="flex-grow-1 overflow-auto" style="max-height: 350px;" id="schedule-drilldown-container">
                    <!-- Loaded via AJAX -->
                    <div class="text-center py-5 text-muted">
                        <i class="far fa-hand-pointer fs-1 mb-3 text-primary opacity-50"></i>
                        <h5>اختر يوماً من التقويم لعرض تفاصيل الجدول وإدارة الفترات الزمنية</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Visual Analytics Charts Row -->
    <div class="row g-4 mb-4">
        <!-- Appointment status distribution doughnut -->
        <div class="col-lg-4 col-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-chart-pie text-primary me-2"></i> توزيع حالات الحجوزات</h5>
                <div style="height: 250px; position: relative;" class="d-flex align-items-center justify-content-center">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
        <!-- Weekly appointments line chart -->
        <div class="col-lg-5 col-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-chart-line text-primary me-2"></i> عدد الحجوزات الأسبوعية</h5>
                <div style="height: 250px; position: relative;">
                    <canvas id="weeklyChart"></canvas>
                </div>
            </div>
        </div>
        <!-- Peak Booking Hours Bar chart / Heatmap -->
        <div class="col-lg-3 col-12">
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-fire text-primary me-2"></i> ساعات ذروة الحجوزات</h5>
                <div style="height: 250px; position: relative;">
                    <canvas id="peakHoursChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Slide-Over Panel for Quick Consultation Notes -->
<div class="slide-over-panel" id="consultation-panel">
    <div class="slide-over-header">
        <h6 class="m-0 fw-bold"><i class="fas fa-notes-medical me-2"></i> الملف والاستشارة السريعة</h6>
        <button onclick="closeConsultationPanel()" class="btn-close btn-close-white" aria-label="Close"></button>
    </div>
    <div class="slide-over-body">
        <input type="hidden" id="consultation-appt-id" />
        
        <div class="mb-4">
            <label class="form-label small fw-bold text-muted">اسم المريض</label>
            <h5 class="fw-bold text-dark" id="consultation-patient-name">-</h5>
        </div>
        <div class="mb-4">
            <label class="form-label small fw-bold text-muted">توقيت الفحص</label>
            <p class="fw-bold text-primary mb-0" id="consultation-appt-time">-</p>
        </div>
        
        <div class="mb-3">
            <label class="form-label small fw-bold text-muted">حالة الحضور</label>
            <select id="consultation-status" class="form-select rounded-pill px-3">
                <option value="Scheduled">مجدول</option>
                <option value="Confirmed">مؤكد</option>
                <option value="Completed">مكتمل بالفحص</option>
                <option value="Cancelled">ملغي</option>
            </select>
        </div>
        
        <div class="mb-4">
            <label class="form-label small fw-bold text-muted">الروشتة / ملاحظات التشخيص وعلاج المريض</label>
            <textarea id="consultation-notes" rows="6" class="form-control rounded-4 p-3" placeholder="اكتب التشخيص والعلاج أو أي ملاحظات طبية هنا..."></textarea>
        </div>
        
        <div class="d-grid mt-4">
            <button onclick="saveConsultationNotes()" class="btn btn-primary rounded-pill py-2.5 fw-bold"><i class="fas fa-save me-1"></i> حفظ وتحديث ملف المريض</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global variables for selected date and calendar state
        let currentDate = new Date(2026, 5, 14); // 14 June 2026
        let activeSelectedDate = new Date(2026, 5, 14);
        
        $(document).ready(function() {
            renderCalendar();
            loadScheduleForDate(activeSelectedDate);
            loadLiveQueue();
            loadCharts();
            
            // Poll Live Queue every 15 seconds
            setInterval(loadLiveQueue, 15000);
        });

        // ── Calendar Logic ───────────────────────────────────────────────
        const arabicMonths = ["يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو", "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر"];
        
        function renderCalendar() {
            const month = currentDate.getMonth();
            const year = currentDate.getFullYear();
            
            $('#calendar-month-year').text(arabicMonths[month] + " " + year);
            
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            
            const grid = $('#calendar-days-grid');
            grid.empty();
            
            // Blank cells for preceding days of week
            for (let i = 0; i < firstDay; i++) {
                grid.append('<div class="calendar-day-cell other-month"></div>');
            }
            
            const today = new Date();
            
            for (let day = 1; day <= daysInMonth; day++) {
                const cellDate = new Date(year, month, day);
                let classes = "calendar-day-cell";
                
                if (cellDate.getDate() === today.getDate() && cellDate.getMonth() === today.getMonth() && cellDate.getFullYear() === today.getFullYear()) {
                    classes += " today";
                }
                
                if (cellDate.getDate() === activeSelectedDate.getDate() && cellDate.getMonth() === activeSelectedDate.getMonth() && cellDate.getFullYear() === activeSelectedDate.getFullYear()) {
                    classes += " active-day";
                }
                
                // Add dummy events flag for days 12, 14, 15, 18 for high-fidelity feel
                if ([12, 14, 15, 18].includes(day) && month === 5) {
                    classes += " has-events";
                }
                
                const cell = $(`<div class="${classes}" onclick="selectDate(this, ${year}, ${month}, ${day})">${day}</div>`);
                grid.append(cell);
            }
        }
        
        function prevMonth() {
            currentDate.setMonth(currentDate.getMonth() - 1);
            renderCalendar();
        }
        
        function nextMonth() {
            currentDate.setMonth(currentDate.getMonth() + 1);
            renderCalendar();
        }
        
        function selectDate(element, year, month, day) {
            $('.calendar-day-cell').removeClass('active-day');
            $(element).addClass('active-day');
            
            activeSelectedDate = new Date(year, month, day);
            loadScheduleForDate(activeSelectedDate);
        }

        // ── Load Schedule Day details via AJAX ──────────────────────────
        function loadScheduleForDate(date) {
            const formattedDate = date.getFullYear() + "-" + (date.getMonth() + 1) + "-" + date.getDate();
            $('#schedule-date-title').text(date.toLocaleDateString('ar-EG', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }));
            
            const container = $('#schedule-drilldown-container');
            container.html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');
            
            $.ajax({
                url: '/DoctorDashboard/Schedule',
                type: 'GET',
                data: { date: formattedDate },
                success: function(res) {
                    if (!res.success) {
                        container.html(`<div class="alert alert-danger">${res.message}</div>`);
                        return;
                    }
                    
                    let html = '';
                    
                    // Header Separator for Bookings
                    html += '<h6 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="far fa-calendar-check text-primary me-2"></i> الحجوزات الطبية للمرضى</h6>';
                    
                    if (res.appointments.length === 0) {
                        html += '<p class="text-muted small py-2">لا توجد حجوزات مؤكدة لهذا اليوم.</p>';
                    } else {
                        html += '<div class="d-flex flex-column gap-2 mb-4">';
                        res.appointments.forEach(apt => {
                            let badgeClass = 'pending';
                            let badgeText = 'معلق';
                            if (apt.status === 'Confirmed') { badgeClass = 'confirmed'; badgeText = 'مؤكد'; }
                            else if (apt.status === 'Completed') { badgeClass = 'completed'; badgeText = 'مكتمل'; }
                            else if (apt.status === 'Cancelled') { badgeClass = 'cancelled'; badgeText = 'ملغي'; }
                            
                            html += `
                                <div class="p-3 rounded-4 border bg-white d-flex align-items-center justify-content-between">
                                    <div onclick="openConsultationPanel(${apt.id}, '${apt.patientName}', '${apt.startTime} - ${apt.endTime}', '${apt.status}', '${apt.notes.replace(/'/g, "\\'")}')" style="cursor:pointer;" class="flex-grow-1">
                                        <span class="fw-bold text-dark d-block">${apt.patientName}</span>
                                        <small class="text-muted font-monospace"><i class="far fa-clock"></i> ${apt.startTime} - ${apt.endTime}</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="status-badge ${badgeClass}"><span class="dot"></span> ${badgeText}</span>
                                        <button onclick="openConsultationPanel(${apt.id}, '${apt.patientName}', '${apt.startTime} - ${apt.endTime}', '${apt.status}', '${apt.notes.replace(/'/g, "\\'")}')" class="btn btn-sm btn-light rounded-circle" title="استشارة سريعة"><i class="fas fa-file-signature text-primary"></i></button>
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div>';
                    }
                    
                    // Available/Locked slots
                    html += '<h6 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="far fa-clock text-primary me-2"></i> فترات حجز العيادة المتاحة والتحكم بالنشاط</h6>';
                    
                    if (res.slots.length === 0) {
                        html += '<p class="text-muted small py-2">لا توجد فترات عمل مهيأة لهذا اليوم. يمكنك استخدام التوليد التلقائي لإنشائها.</p>';
                    } else {
                        html += '<div class="row g-2">';
                        res.slots.forEach(slot => {
                            const uniqueId = `slotSwitch-${slot.id}`;
                            const isChecked = !slot.isBooked;
                            
                            html += `
                                <div class="col-sm-6 col-12">
                                    <div class="p-2 border rounded-pill bg-white px-3 d-flex align-items-center justify-content-between">
                                        <small class="fw-bold text-dark font-monospace"><i class="far fa-clock me-1"></i> ${slot.startTime} - ${slot.endTime}</small>
                                        <div class="form-check form-switch m-0">
                                            <input class="form-check-input" type="checkbox" id="${uniqueId}" ${isChecked ? 'checked' : ''} ${slot.isBooked ? 'disabled' : ''} onchange="toggleSlotState(${slot.id}, '${formattedDate}', '${slot.startTime}', '${slot.endTime}', this)" />
                                            <label class="form-check-label text-muted small fw-bold me-1" for="${uniqueId}">${slot.isBooked ? 'محجوز' : (isChecked ? 'متاح' : 'مغلق')}</label>
                                        </div>
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div>';
                    }
                    
                    container.html(html);
                },
                error: function() {
                    container.html('<div class="alert alert-danger">خطأ في جلب بيانات الجدول اليومي.</div>');
                }
            });
        }
        
        // ── Toggle Slot Availability via AJAX ───────────────────────────
        function toggleSlotState(slotId, dateStr, startTime, endTime, checkbox) {
            const enable = checkbox.checked;
            
            $.ajax({
                url: '/DoctorSlots/ToggleSlot',
                type: 'POST',
                data: {
                    id: slotId,
                    date: dateStr,
                    startTime: startTime,
                    endTime: endTime,
                    enable: enable,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (!res.success) {
                        alert(res.message);
                        checkbox.checked = !enable; // revert
                    } else {
                        // Reload day drilldown to refresh
                        loadScheduleForDate(activeSelectedDate);
                    }
                },
                error: function() {
                    alert('خطأ أثناء تعديل حالة الفترة.');
                    checkbox.checked = !enable;
                }
            });
        }
        
        // ── Emergency Day Block ──────────────────────────────────────────
        function blockSelectedDay() {
            if (!confirm('هل أنت متأكد من رغبتك في إغلاق وقفل كافة الفترات الزمنية المتاحة لهذا اليوم بالكامل؟')) return;
            
            const formattedDate = activeSelectedDate.getFullYear() + "-" + (activeSelectedDate.getMonth() + 1) + "-" + activeSelectedDate.getDate();
            
            $.ajax({
                url: '/DoctorSlots/BlockFullDay',
                type: 'POST',
                data: {
                    date: formattedDate,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (res.success) {
                        alert(res.message);
                        loadScheduleForDate(activeSelectedDate);
                    } else {
                        alert(res.message);
                    }
                },
                error: function() {
                    alert('حدث خطأ أثناء إغلاق فترات اليوم.');
                }
            });
        }

        // ── Live Queue Tracker Logic ────────────────────────────────────
        let currentActiveAppointmentId = null;
        
        function loadLiveQueue() {
            const formattedDate = activeSelectedDate.getFullYear() + "-" + (activeSelectedDate.getMonth() + 1) + "-" + activeSelectedDate.getDate();
            
            $.ajax({
                url: '/DoctorDashboard/Schedule',
                type: 'GET',
                data: { date: formattedDate },
                success: function(res) {
                    if (res.success) {
                        // Current patient in exam (first Completed status or Confirmed starting first)
                        const inExam = res.appointments.find(a => a.status === 'Completed' || a.status === 'Confirmed');
                        const waiting = res.appointments.filter(a => a.status === 'Confirmed' || a.status === 'Scheduled');
                        const completedToday = res.appointments.filter(a => a.status === 'Completed');
                        
                        $('#queue-waiting-count').text(waiting.length);
                        $('#queue-completed-count').text(completedToday.length);
                        
                        if (inExam) {
                            currentActiveAppointmentId = inExam.id;
                            $('#current-patient-name').text(inExam.patientName);
                            $('#current-patient-time').text(inExam.startTime + " - " + inExam.endTime);
                            $('#current-patient-actions').removeClass('d-none');
                        } else {
                            currentActiveAppointmentId = null;
                            $('#current-patient-name').text("لا يوجد مريض بالفحص حالياً");
                            $('#current-patient-time').text("-");
                            $('#current-patient-actions').addClass('d-none');
                        }
                        
                        // Next waiting
                        const nextApt = waiting.find(a => a.id !== (inExam ? inExam.id : null));
                        if (nextApt) {
                            $('#next-patient-name').text(nextApt.patientName);
                            $('#next-patient-time').text(nextApt.startTime + " - " + nextApt.endTime);
                            $('#next-patient-actions').removeClass('d-none');
                        } else {
                            $('#next-patient-name').text("لا يوجد مرضى في الانتظار");
                            $('#next-patient-time').text("-");
                            $('#next-patient-actions').addClass('d-none');
                        }
                    }
                }
            });
        }
        
        function completeCurrentPatient() {
            if (!currentActiveAppointmentId) return;
            
            $.ajax({
                url: '/DoctorDashboard/SaveNotes',
                type: 'POST',
                data: {
                    appointmentId: currentActiveAppointmentId,
                    notes: "تم الفحص الطبي بالكامل وإعطاء التعليمات الطبية.",
                    status: 'Completed',
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (res.success) {
                        alert('تم إنهاء فحص المريض وحفظ حالته بنجاح!');
                        loadLiveQueue();
                        loadScheduleForDate(activeSelectedDate);
                    } else {
                        alert(res.message);
                    }
                }
            });
        }
        
        function callNextPatient() {
            alert('تم إرسال نداء للمريض القادم في صالة العيادة!');
        }

        // ── Consultation Side-panel Notes Logic ────────────────────────
        function openConsultationPanel(id, name, time, status, notes) {
            $('#consultation-appt-id').val(id);
            $('#consultation-patient-name').text(name);
            $('#consultation-appt-time').text(time);
            $('#consultation-status').val(status);
            $('#consultation-notes').val(notes);
            
            $('#consultation-panel').addClass('show');
        }
        
        function closeConsultationPanel() {
            $('#consultation-panel').removeClass('show');
        }
        
        function saveConsultationNotes() {
            const id = $('#consultation-appt-id').val();
            const status = $('#consultation-status').val();
            const notes = $('#consultation-notes').val();
            
            $.ajax({
                url: '/DoctorDashboard/SaveNotes',
                type: 'POST',
                data: {
                    appointmentId: id,
                    notes: notes,
                    status: status,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (res.success) {
                        alert(res.message);
                        closeConsultationPanel();
                        loadScheduleForDate(activeSelectedDate);
                        loadLiveQueue();
                    } else {
                        alert(res.message);
                    }
                },
                error: function() {
                    alert('خطأ أثناء حفظ الملاحظات.');
                }
            });
        }

        // ── Chart.js Setup ──────────────────────────────────────────────
        function loadCharts() {
            // Doughnut Chart: Appointment status
            const ctxStatus = document.getElementById('statusChart').getContext('2d');
            new Chart(ctxStatus, {
                type: 'doughnut',
                data: {
                    labels: ['مكتملة', 'ملغية', 'لم يحضر', 'مؤكدة'],
                    datasets: [{
                        data: [18, 2, 1, 5],
                        backgroundColor: ['#2ecc71', '#e74c3c', '#95a5a6', '#3498db'],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { family: 'tahoma' } } }
                    }
                }
            });
            
            // Line Chart: Patient throughput
            const ctxWeekly = document.getElementById('weeklyChart').getContext('2d');
            new Chart(ctxWeekly, {
                type: 'line',
                data: {
                    labels: ['السبت', 'الأحد', 'الإثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة'],
                    datasets: [{
                        label: 'إجمالي المواعيد الأسبوعية',
                        data: [12, 19, 15, 25, 22, 30, 8],
                        borderColor: '#1a6fbf',
                        backgroundColor: 'rgba(26, 111, 191, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
            
            // Bar Chart: Peak booking hours
            const ctxPeak = document.getElementById('peakHoursChart').getContext('2d');
            new Chart(ctxPeak, {
                type: 'bar',
                data: {
                    labels: ['6 مساءً', '7 مساءً', '8 مساءً', '9 مساءً', '10 مساءً'],
                    datasets: [{
                        label: 'إجمالي الحجوزات',
                        data: [25, 38, 42, 30, 15],
                        backgroundColor: '#8e44ad',
                        borderRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        }
    </script>
}