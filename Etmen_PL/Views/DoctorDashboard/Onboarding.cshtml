@model Etmen_PL.Controllers.DoctorOnboardingInputModel
@{
    Layout = null; // Clean independent layout
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تفعيل حساب الطبيب — إطمن</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <style>
        :root {
            --primary: #1A6FBF;
            --primary-dark: #0D4C8A;
            --primary-light: #E8F4FD;
            --accent: #00C9A7;
            --success: #27AE60;
            --danger: #E74C3C;
            --warning: #F39C12;
            --dark: #0F1923;
            --text: #2C3E50;
            --text-muted: #7F8C8D;
            --border: #DDE3EC;
            --white: #FFFFFF;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.8);
            --card-shadow: 0 15px 35px rgba(15, 36, 55, 0.08);
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: radial-gradient(circle at 10% 20%, rgba(240, 244, 248, 1) 0%, rgba(228, 235, 242, 1) 90.1%);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Top Progress Bar indicator */
        .onboarding-stepper {
            height: 6px;
            width: 100%;
            background: #DDE3EC;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
        }
        .onboarding-progress {
            height: 100%;
            width: 25%;
            background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%);
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Top Header Navigation */
        .onboarding-header {
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--dark);
        }
        .brand-logo-icon {
            width: 42px;
            height: 42px;
            background: var(--primary);
            border-radius: 12px;
            display: grid;
            place-items: center;
            color: white;
            font-size: 1.25rem;
            box-shadow: 0 4px 10px rgba(26, 111, 191, 0.3);
        }
        .brand-logo-text {
            font-weight: 900;
            font-size: 1.5rem;
            color: var(--dark);
        }
        .brand-logo-text span {
            color: var(--primary);
        }
        .back-btn {
            background: white;
            border: 1px solid var(--border);
            color: var(--text);
            width: 40px; height: 40px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }
        .back-btn:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
            transform: translateX(3px);
        }

        /* Main Container */
        .onboarding-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        /* Onboarding card */
        .onboarding-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 3rem;
            width: 100%;
            max-width: 780px;
            box-shadow: var(--card-shadow);
            position: relative;
            overflow: hidden;
            animation: fadeIn 0.5s ease;
        }

        .step-section {
            display: none;
        }
        .step-section.active {
            display: block;
            animation: slideInRight 0.4s ease;
        }

        /* Custom file uploads */
        .upload-avatar-wrapper {
            position: relative;
            width: 140px; height: 140px;
            margin: 0 auto 2rem auto;
        }
        .upload-avatar-circle {
            width: 100%; height: 100%;
            border-radius: 50%;
            background: #F0F4F8;
            border: 2px dashed var(--primary);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.3s;
            position: relative;
        }
        .upload-avatar-circle:hover {
            background: var(--primary-light);
            border-color: var(--primary-dark);
        }
        .upload-avatar-circle img {
            width: 100%; height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0; left: 0;
            display: none;
        }
        .upload-avatar-circle i {
            font-size: 2.2rem;
            color: var(--primary);
            margin-bottom: 5px;
        }
        .upload-avatar-circle span {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 700;
        }
        .upload-avatar-btn-plus {
            position: absolute;
            bottom: 5px; left: 5px;
            background: var(--primary);
            color: white;
            width: 32px; height: 32px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-size: 0.8rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            pointer-events: none;
            border: 2px solid white;
        }

        /* Form Controls */
        .form-label {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--dark);
            margin-bottom: 0.5rem;
        }
        .form-control, .form-select {
            border-radius: 12px;
            border: 1.5px solid var(--border);
            padding: 0.75rem 1rem;
            font-weight: 500;
            transition: all 0.3s;
            background-color: rgba(255, 255, 255, 0.9);
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-light);
            background-color: white;
        }

        /* Phone input custom styling */
        .phone-group {
            display: flex;
            gap: 10px;
        }
        .phone-prefix {
            width: 105px;
            flex-shrink: 0;
        }

        /* Radio Card Selection */
        .radio-cards {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            margin-top: 1rem;
        }
        .radio-card {
            border: 2px solid var(--border);
            border-radius: 18px;
            padding: 1.5rem;
            cursor: pointer;
            transition: all 0.25s;
            background: white;
            position: relative;
        }
        .radio-card:hover {
            border-color: var(--primary);
            transform: translateY(-3px);
        }
        .radio-card.active {
            border-color: var(--primary);
            background: var(--primary-light);
            box-shadow: 0 8px 20px rgba(26, 111, 191, 0.1);
        }
        .radio-card-input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        /* Product Subscribe Card */
        .product-card {
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            background: white;
            max-width: 320px;
            margin: 2rem auto;
            box-shadow: 0 10px 25px rgba(0,0,0,0.03);
            text-align: center;
            transition: all 0.3s;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }
        .product-header {
            background: linear-gradient(135deg, var(--dark) 0%, #15324d 100%);
            color: white;
            padding: 2rem 1.5rem;
            position: relative;
        }
        .product-icon {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
            color: var(--accent);
        }
        .product-title {
            font-weight: 800;
            font-size: 1.3rem;
            margin: 0;
        }
        .product-body {
            padding: 2rem 1.5rem;
        }
        .product-desc {
            color: var(--text-muted);
            font-size: 0.88rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        .product-subscribe-btn {
            background: white;
            border: 2px solid var(--primary);
            color: var(--primary);
            border-radius: 10px;
            padding: 8px 24px;
            font-weight: 700;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .product-subscribe-btn.subscribed {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

        /* Footer buttons */
        .onboarding-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 3rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(0,0,0,0.06);
        }
        .btn-next {
            background: var(--primary);
            color: white;
            border-radius: 12px;
            padding: 0.75rem 2rem;
            font-weight: 800;
            border: none;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(26, 111, 191, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-next:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 111, 191, 0.4);
            color: white;
        }

        .heading-title {
            font-weight: 900;
            font-size: 1.8rem;
            color: var(--dark);
            margin-bottom: 0.5rem;
        }
        .heading-sub {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 2.5rem;
        }
    </style>
</head>
<body>

    <!-- Stepper Progress Bar -->
    <div class="onboarding-stepper">
        <div class="onboarding-progress" id="progressBar"></div>
    </div>

    <!-- Header -->
    <header class="onboarding-header">
        <a href="#" class="brand-logo">
            <div class="brand-logo-icon"><i class="fas fa-heartbeat"></i></div>
            <span class="brand-logo-text">إط<span>من</span></span>
        </a>
        <button type="button" class="back-btn" id="prevBtn" onclick="prevStep()" style="display:none;">
            <i class="fas fa-arrow-right"></i>
        </button>
    </header>

    <!-- Form container -->
    <main class="onboarding-container">
        <form asp-action="SaveOnboarding" method="post" enctype="multipart/form-data" id="onboardingForm" class="onboarding-card">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold"></div>

            <!-- ================= STEP 1: PERSONAL INFO ================= -->
            <section class="step-section active" id="step1">
                <h2 class="heading-title">أدخل بياناتك الشخصية</h2>
                <p class="heading-sub">هذه هي بيانات حسابك الشخصية، سيُطلب منك تالياً إدخال معلومات العيادة/المستشفى الخاصة بك.</p>

                <!-- Avatar Upload -->
                <div class="upload-avatar-wrapper">
                    <div class="upload-avatar-circle" onclick="document.getElementById('profilePicInput').click()">
                        <i class="fas fa-camera"></i>
                        <span>أضف صورة</span>
                        <img id="avatarPreview" src="" alt="Profile Image" />
                    </div>
                    <div class="upload-avatar-btn-plus"><i class="fas fa-plus"></i></div>
                    <input type="file" name="profilePicFile" id="profilePicInput" accept="image/*" style="display:none;" onchange="previewImage(this, 'avatarPreview')" />
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label">الاسم الأول *</label>
                        <input asp-for="FirstName" class="form-control" placeholder="كمال" required />
                        <span asp-validation-for="FirstName" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label">الاسم الأخير *</label>
                        <input asp-for="LastName" class="form-control" placeholder="محمد" required />
                        <span asp-validation-for="LastName" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="PhoneNumber" class="form-label">رقم الجوال *</label>
                        <div class="phone-group">
                            <select class="form-select phone-prefix" id="countryCode">
                                <option value="+20">🇪🇬 +20</option>
                                <option value="+966">🇸🇦 +966</option>
                                <option value="+971">🇦🇪 +971</option>
                            </select>
                            <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="1099464322" required />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Speciality" class="form-label">التخصص الطبي *</label>
                        <select asp-for="Speciality" class="form-select" id="specialitySelect" required>
                            <option value="">اختر التخصص</option>
                            <option value="القلب والأوعية الدموية">القلب والأوعية الدموية</option>
                            <option value="طب الأطفال حديثي الولادة">طب الأطفال حديثي الولادة</option>
                            <option value="الجلدية والتجميل">الجلدية والتجميل</option>
                            <option value="الباطنة والجهاز الهضمي">الباطنة والجهاز الهضمي</option>
                            <option value="العظام والمفاصل">العظام والمفاصل</option>
                            <option value="النساء والتوليد">النساء والتوليد</option>
                            <option value="جراحة عامة">جراحة عامة</option>
                            <option value="الأنف والأذن والحنجرة">الأنف والأذن والحنجرة</option>
                            <option value="الطب النفسي">الطب النفسي</option>
                        </select>
                        <div class="invalid-feedback text-danger mt-1 fw-bold" id="specialityError" style="display:none;">يرجى تحديد التخصص الطبي.</div>
                        <span asp-validation-for="Speciality" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                        <input asp-for="Email" class="form-control bg-light" readonly />
                    </div>
                </div>
            </section>

            <!-- ================= STEP 2: CREATE ENTITY ================= -->
            <section class="step-section" id="step2">
                <h2 class="heading-title">أنشئ منشأتك الطبية</h2>
                <p class="heading-sub">أدخل اسم المنشأة والشعار الخاص بها، يمكنك لاحقاً إضافة الفروع والعيادات والغرف.</p>

                <!-- Logo Upload -->
                <div class="upload-avatar-wrapper">
                    <div class="upload-avatar-circle" onclick="document.getElementById('entityLogoInput').click()">
                        <i class="fas fa-camera"></i>
                        <span>شعار المنشأة</span>
                        <img id="logoPreview" src="" alt="Entity Logo" />
                    </div>
                    <div class="upload-avatar-btn-plus"><i class="fas fa-plus"></i></div>
                    <input type="file" name="entityLogoFile" id="entityLogoInput" accept="image/*" style="display:none;" onchange="previewImage(this, 'logoPreview')" />
                </div>

                <div class="row g-4">
                    <div class="col-md-12">
                        <label asp-for="EntityType" class="form-label">نوع المنشأة *</label>
                        <select asp-for="EntityType" class="form-select" required>
                            <option value="Clinics">عيادات (Clinics)</option>
                            <option value="Center">مركز طبي (Center)</option>
                            <option value="Hospital">مستشفى (Hospital)</option>
                        </select>
                        <span asp-validation-for="EntityType" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="EntityName" class="form-label">اسم المنشأة *</label>
                        <input asp-for="EntityName" class="form-control" placeholder="عيادة كوكو التخصصية" required />
                        <span asp-validation-for="EntityName" class="text-danger small fw-bold"></span>
                    </div>
                </div>
            </section>

            <!-- ================= STEP 3: PRODUCTS SUBSCRIPTION ================= -->
            <section class="step-section" id="step3">
                <h2 class="heading-title">اشترك في منتجات إطمن</h2>
                <p class="heading-sub">يمكنك الاشتراك في منتج واحد أو أكثر من منتجاتنا الطبية لتفعيل الحجز الفوري وإدارة المرضى.</p>

                <!-- Vezeeta Book Card style -->
                <div class="product-card">
                    <div class="product-header">
                        <div class="product-icon"><i class="fas fa-book-medical"></i></div>
                        <h4 class="product-title">إطمن بوك (Book)</h4>
                    </div>
                    <div class="product-body">
                        <p class="product-desc">ابنِ ملفك الطبي الشخصي على منصتنا، وضاعف من ظهورك الرقمي لزيادة واستقبال الحجوزات الطبية الفورية بسهولة.</p>
                        <button type="button" class="product-subscribe-btn subscribed" id="subBtn" onclick="toggleSubscription()">
                            <i class="fas fa-check"></i> مشترك
                        </button>
                    </div>
                </div>
            </section>

            <!-- ================= STEP 4: SETUP BOOK / BRANCH ================= -->
            <section class="step-section" id="step4">
                <h2 class="heading-title">إعداد خدمة إطمن بوك</h2>
                <p class="heading-sub">أنشئ فروعك وحدد مواقعها الجغرافية. ستحتاج إلى تحديد المجموعات والتخصصات المدعومة في كل فرع.</p>

                <h5 class="fw-bold fs-6 mb-2 text-dark">نظام التسعير والعمولات</h5>
                <div class="radio-cards mb-4">
                    <div class="radio-card active" onclick="selectRadioCard(this, 'pricingOption1')">
                        <input type="radio" asp-for="PricingOption" value="Monthly + Transaction" id="pricingOption1" class="radio-card-input" checked />
                        <div class="fw-bold">رسوم شهرية + عمولة المعاملة</div>
                        <span class="text-muted small">سعر اشتراك ثابت مخفض مع عمولة رمزية على كل حجز.</span>
                    </div>
                    <div class="radio-card" onclick="selectRadioCard(this, 'pricingOption2')">
                        <input type="radio" asp-for="PricingOption" value="Transaction Only" id="pricingOption2" class="radio-card-input" />
                        <div class="fw-bold">عمولة على المعاملة فقط</div>
                        <span class="text-muted small">بدون رسوم اشتراك شهرية، تدفع فقط نسبة عن كل كشف مؤكد.</span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="BranchType" class="form-label">نوع الفرع *</label>
                        <select asp-for="BranchType" class="form-select" required>
                            <option value="Clinic">عيادة فردية (Clinic)</option>
                            <option value="Polyclinic">مجمع عيادات (Polyclinic)</option>
                        </select>
                        <span asp-validation-for="BranchType" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BranchEnglishName" class="form-label">اسم الفرع بالإنجليزي *</label>
                        <input asp-for="BranchEnglishName" class="form-control" placeholder="Koko Clinic Main" required />
                        <span asp-validation-for="BranchEnglishName" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BranchArabicName" class="form-label">اسم الفرع بالعربي *</label>
                        <input asp-for="BranchArabicName" class="form-control" placeholder="عيادة كوكو الرئيسية" required />
                        <span asp-validation-for="BranchArabicName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="City" class="form-label">المحافظة *</label>
                        <select asp-for="City" class="form-select" id="citySelect" onchange="updateAreas()" required>
                            <option value="القاهرة">القاهرة</option>
                            <option value="الجيزة">الجيزة</option>
                            <option value="الأسكندرية">الأسكندرية</option>
                            <option value="الدقهلية">الدقهلية</option>
                            <option value="البحر الأحمر">البحر الأحمر</option>
                            <option value="البحيرة">البحيرة</option>
                            <option value="الفيوم">الفيوم</option>
                            <option value="الغربية">الغربية</option>
                            <option value="الإسماعيلية">الإسماعيلية</option>
                            <option value="المنوفية">المنوفية</option>
                            <option value="المنيا">المنيا</option>
                            <option value="القليوبية">القليوبية</option>
                            <option value="الوادي الجديد">الوادي الجديد</option>
                            <option value="السويس">السويس</option>
                            <option value="أسوان">أسوان</option>
                            <option value="أسيوط">أسيوط</option>
                            <option value="بني سويف">بني سويف</option>
                            <option value="بورسعيد">بورسعيد</option>
                            <option value="دمياط">دمياط</option>
                            <option value="الشرقية">الشرقية</option>
                            <option value="جنوب سيناء">جنوب سيناء</option>
                            <option value="كفر الشيخ">كفر الشيخ</option>
                            <option value="مطروح">مطروح</option>
                            <option value="قنا">قنا</option>
                            <option value="شمال سيناء">شمال سيناء</option>
                            <option value="سوهاج">سوهاج</option>
                            <option value="الأقصر">الأقصر</option>
                        </select>
                        <span asp-validation-for="City" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Area" class="form-label">المنطقة / الحي *</label>
                        <select asp-for="Area" class="form-select" id="areaSelect" required>
                            <!-- populated dynamically via JS -->
                        </select>
                        <span asp-validation-for="Area" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BranchMobile" class="form-label">رقم هاتف الفرع *</label>
                        <input asp-for="BranchMobile" type="tel" class="form-control" placeholder="022345678" required />
                        <span asp-validation-for="BranchMobile" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SmsMobile" class="form-label">رقم جوال تنبيهات SMS *</label>
                        <input asp-for="SmsMobile" type="tel" class="form-control" placeholder="01099464322" required />
                        <span asp-validation-for="SmsMobile" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TaxId" class="form-label">الرقم الضريبي *</label>
                        <input asp-for="TaxId" class="form-control mask-code" placeholder="123-456-789" required />
                        <span asp-validation-for="TaxId" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CommercialRegistration" class="form-label">السجل التجاري *</label>
                        <input asp-for="CommercialRegistration" class="form-control mask-code" placeholder="123-456-789" required />
                        <span asp-validation-for="CommercialRegistration" class="text-danger small fw-bold"></span>
                    </div>

                    <!-- Map selection area -->
                    <div class="col-md-12 mt-3">
                        <label class="form-label text-dark fw-bold">تحديد موقع العيادة الجغرافي على الخريطة *</label>
                        <p class="text-muted small">ابحث عن منطقتك أو اسحب المؤشر لتحديد موقع العيادة بدقة لتمكين المرضى من العثور عليها بسهولة.</p>
                        
                        <!-- Map Search Bar -->
                        <div class="input-group mb-2">
                            <input type="text" id="mapSearchInput" class="form-control" placeholder="ابحث عن اسم الشارع أو المنطقة أو المعلم..." />
                            <button type="button" class="btn btn-primary px-3" onclick="searchLocation()"><i class="fas fa-search"></i> ابحث</button>
                        </div>
                        <div id="locationSearchSpinner" class="text-primary small mb-2" style="display:none;">
                            <i class="fas fa-spinner fa-spin me-1"></i> جاري البحث عن الموقع...
                        </div>
                        
                        <!-- Map container -->
                        <div id="onboardingMap" class="border rounded" style="height: 320px; width: 100%; z-index: 100;"></div>
                        
                        <!-- Hidden inputs to submit coordinates -->
                        <input type="hidden" asp-for="Latitude" id="latitudeInput" value="30.0444" />
                        <input type="hidden" asp-for="Longitude" id="longitudeInput" value="31.2357" />
                    </div>
                </div>
            </section>

            <!-- Navigation Buttons -->
            <div class="onboarding-footer">
                <button type="button" class="btn btn-outline-secondary px-4 py-2" id="cancelBtn" onclick="window.location.href='/Account/Logout'">
                    <i class="fas fa-sign-out-alt me-1"></i> خروج
                </button>
                
                <button type="button" class="btn-next" id="nextBtn" onclick="nextStep()">
                    <span>متابعة</span> <i class="fas fa-arrow-left"></i>
                </button>
            </div>
        </form>
    </main>

    <!-- JS Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let currentStepNum = 1;
        const totalSteps = 4;

        const areaMap = {
            "القاهرة": ["مصر الجديدة", "مدينة نصر", "المعادي", "التجمع الخامس", "شبرا", "وسط البلد", "حلوان", "الزيتون"],
            "الجيزة": ["الدقي", "المهندسين", "الشيخ زايد", "الهرم", "6 أكتوبر", "فيصل", "العجوزة", "إمبابة"],
            "الأسكندرية": ["سموحة", "ميامي", "لوران", "المنشية", "العجمي", "سيدي بشر", "محرم بك", "الشاطبي"],
            "الدقهلية": ["المنصورة", "ميت غمر", "السنبلاوين", "دكرنس", "طلخا", "شربين"],
            "البحر الأحمر": ["الغردقة", "سفاجا", "القصير", "مرسى علم", "شلاتين", "الجونة"],
            "البحيرة": ["دمنهور", "كفر الدوار", "رشيد", "إدكو", "أبو حمص", "كوم حمادة"],
            "الفيوم": ["الفيوم الجديدة", "سنورس", "إطسا", "طامية", "يوسف الصديق", "أبشواي"],
            "الغربية": ["طنطا", "المحلة الكبرى", "كفر الزيات", "زفتى", "بسيون", "سمنود"],
            "الإسماعيلية": ["الإسماعيلية", "التل الكبير", "فايد", "القنطرة شرق", "القنطرة غرب", "أبو صوير"],
            "المنوفية": ["شبين الكوم", "أشمون", "منوف", "السادات", "باجور", "قويسنا"],
            "المنيا": ["المنيا", "ملوي", "بني مزار", "مغاغة", "أبو قرقاص", "سمالوط"],
            "القليوبية": ["بنها", "شبرا الخيمة", "قليوب", "الخانكة", "العبور", "طوخ"],
            "الوادي الجديد": ["الخارجة", "الداخلة", "الفرافرة", "باريس", "بلاط"],
            "السويس": ["السويس", "الأربعين", "عتاقة", "الجناين", "فيصل (السويس)"],
            "أسوان": ["أسوان", "كوم أمبو", "إدفو", "نصر النوبة", "أبو سمبل"],
            "أسيوط": ["أسيوط", "ديروط", "منفلوط", "أبو تيج", "أبنوب", "البداري"],
            "بني سويف": ["بني سويف", "الواسطى", "ببا", "الفشن", "ناصر", "اهناسيا"],
            "بورسعيد": ["بورسعيد", "بورفؤاد", "الزهور", "الشرق", "العرب", "الضواحي"],
            "دمياط": ["دمياط", "رأس البر", "دمياط الجديدة", "فارسكور", "الزرقا", "كفر سعد"],
            "الشرقية": ["الزقازيق", "العاشر من رمضان", "بلبيس", "منيا القمح", "فاقوس", "أبو حماد"],
            "جنوب سيناء": ["طور سيناء", "شرم الشيخ", "دهب", "نويبع", "طابا", "سانت كاترين"],
            "كفر الشيخ": ["كفر الشيخ", "دسوق", "مطوبس", "فوه", "قلين", "سيدي سالم"],
            "مطروح": ["مرسى مطروح", "العلمين", "الضبعة", "سيوة", "الحمام", "السلوم"],
            "قنا": ["قنا", "نجع حمادي", "دشنا", "أبو تشت", "قوص", "نقادة"],
            "شمال سيناء": ["العريش", "الشيخ زويد", "رفح", "بئر العبد", "الحسنة"],
            "سوهاج": ["سوهاج", "طما", "طهطا", "جرجا", "البلينا", "أخميم"],
            "الأقصر": ["الأقصر", "إسنا", "أرمنت", "القرنة", "الطود"]
        };

        const cityCoordinates = {
            "القاهرة": [30.0444, 31.2357],
            "الجيزة": [30.0131, 31.2089],
            "الأسكندرية": [31.2001, 29.9187],
            "الدقهلية": [31.0409, 31.3785],
            "البحر الأحمر": [27.2579, 33.8116],
            "البحيرة": [31.0364, 30.4688],
            "الفيوم": [29.3084, 30.8428],
            "الغربية": [30.7865, 31.0004],
            "الإسماعيلية": [30.6043, 32.2723],
            "المنوفية": [30.5510, 31.0120],
            "المنيا": [28.0871, 30.7618],
            "القليوبية": [30.4591, 31.1856],
            "الوادي الجديد": [25.4390, 30.5486],
            "السويس": [29.9668, 32.5498],
            "أسوان": [24.0889, 32.8998],
            "أسيوط": [27.1783, 31.1859],
            "بني سويف": [29.0744, 31.0979],
            "بورسعيد": [31.2653, 32.3019],
            "دمياط": [31.4175, 31.8144],
            "الشرقية": [30.5877, 31.5020],
            "جنوب سيناء": [28.2403, 33.6231],
            "كفر الشيخ": [31.1107, 30.9388],
            "مطروح": [31.3543, 27.2373],
            "قنا": [26.1551, 32.7160],
            "شمال سيناء": [31.1321, 33.8032],
            "سوهاج": [26.5591, 31.6948],
            "الأقصر": [25.6872, 32.6396]
        };

        let map = null;
        let marker = null;

        // Initialize Area dropdown on page load
        $(document).ready(function() {
            updateAreas();
            setupMasks();

            $("#areaSelect").on("change", function() {
                const city = $("#citySelect").val();
                const area = $(this).val();
                if (city && area && map !== null) {
                    const query = area + ", " + city + ", Egypt";
                    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`)
                        .then(r => r.json())
                        .then(d => {
                            if (d && d.length > 0) {
                                const lat = parseFloat(d[0].lat);
                                const lon = parseFloat(d[0].lon);
                                map.setView([lat, lon], 13);
                                marker.setLatLng([lat, lon]);
                                $("#latitudeInput").val(lat.toFixed(6));
                                $("#longitudeInput").val(lon.toFixed(6));
                            }
                        });
                }
            });

            $("#mapSearchInput").on("keypress", function(e) {
                if (e.which === 13) { // Enter key
                    e.preventDefault();
                    searchLocation();
                }
            });
        });

        function updateAreas() {
            const city = $("#citySelect").val();
            const areas = areaMap[city] || [];
            const areaSelect = $("#areaSelect");
            areaSelect.empty();
            areas.forEach(a => {
                areaSelect.append(`<option value="${a}">${a}</option>`);
            });

            // Center map on city coordinates if map is initialized
            if (map !== null && cityCoordinates[city]) {
                const coords = cityCoordinates[city];
                map.setView(coords, 12);
                marker.setLatLng(coords);
                $("#latitudeInput").val(coords[0].toFixed(6));
                $("#longitudeInput").val(coords[1].toFixed(6));
            }
        }

        function initMap() {
            if (map !== null) {
                setTimeout(() => {
                    map.invalidateSize();
                }, 200);
                return;
            }

            const initialLat = 30.0444;
            const initialLng = 31.2357;

            // Create Leaflet Map
            map = L.map('onboardingMap').setView([initialLat, initialLng], 12);

            // Add OpenStreetMap tiles
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            // Create Draggable Marker
            marker = L.marker([initialLat, initialLng], {
                draggable: true
            }).addTo(map);

            // Update hidden inputs on dragend
            marker.on('dragend', function(event) {
                const position = marker.getLatLng();
                $("#latitudeInput").val(position.lat.toFixed(6));
                $("#longitudeInput").val(position.lng.toFixed(6));
            });

            // Update hidden inputs and marker position on map click
            map.on('click', function(event) {
                const latlng = event.latlng;
                marker.setLatLng(latlng);
                $("#latitudeInput").val(latlng.lat.toFixed(6));
                $("#longitudeInput").val(latlng.lng.toFixed(6));
            });

            // Invalidate size in case of rendering glitch
            setTimeout(() => {
                map.invalidateSize();
                const city = $("#citySelect").val();
                if (city && cityCoordinates[city]) {
                    const coords = cityCoordinates[city];
                    map.setView(coords, 12);
                    marker.setLatLng(coords);
                    $("#latitudeInput").val(coords[0].toFixed(6));
                    $("#longitudeInput").val(coords[1].toFixed(6));
                }
            }, 200);
        }

        function searchLocation() {
            const query = $("#mapSearchInput").val();
            if (!query) {
                alert("يرجى إدخال اسم المنطقة أو الشارع للبحث.");
                return;
            }

            $("#locationSearchSpinner").show();
            const searchQuery = query + ", Egypt";

            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(searchQuery)}&limit=1`)
                .then(response => response.json())
                .then(data => {
                    $("#locationSearchSpinner").hide();
                    if (data && data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lon = parseFloat(data[0].lon);
                        map.setView([lat, lon], 14);
                        marker.setLatLng([lat, lon]);
                        $("#latitudeInput").val(lat.toFixed(6));
                        $("#longitudeInput").val(lon.toFixed(6));
                    } else {
                        // Retry without Egypt prefix just in case
                        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`)
                            .then(r => r.json())
                            .then(d => {
                                if (d && d.length > 0) {
                                    const lat = parseFloat(d[0].lat);
                                    const lon = parseFloat(d[0].lon);
                                    map.setView([lat, lon], 14);
                                    marker.setLatLng([lat, lon]);
                                    $("#latitudeInput").val(lat.toFixed(6));
                                    $("#longitudeInput").val(lon.toFixed(6));
                                } else {
                                    alert("لم يتم العثور على نتائج للموقع المدخل. يرجى المحاولة بصيغة أخرى.");
                                }
                            });
                    }
                })
                .catch(error => {
                    $("#locationSearchSpinner").hide();
                    console.error("Geocoding error:", error);
                    alert("حدث خطأ أثناء الاتصال بخدمة البحث.");
                });
        }

        // Automatic format input masking (e.g. 123-456-789)
        function setupMasks() {
            $(".mask-code").on("input", function() {
                let val = $(this).val().replace(/\D/g, "");
                if (val.length > 9) val = val.substring(0, 9);
                
                let formatted = "";
                if (val.length > 0) {
                    formatted += val.substring(0, 3);
                }
                if (val.length > 3) {
                    formatted += "-" + val.substring(3, 6);
                }
                if (val.length > 6) {
                    formatted += "-" + val.substring(6, 9);
                }
                $(this).val(formatted);
            });
        }

        // Preview uploaded avatar / logo
        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    $(`#${previewId}`).attr("src", e.target.result).show();
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Custom radio cards selection styling
        function selectRadioCard(element, radioId) {
            $(".radio-card").removeClass("active");
            $(element).addClass("active");
            $(`#${radioId}`).prop("checked", true);
        }

        // Toggle Step 3 Product Subscription status
        let isSubscribed = true;
        function toggleSubscription() {
            isSubscribed = !isSubscribed;
            const btn = $("#subBtn");
            if (isSubscribed) {
                btn.addClass("subscribed").html('<i class="fas fa-check"></i> مشترك');
            } else {
                btn.removeClass("subscribed").html('<i class="fas fa-plus"></i> اشترك الآن');
            }
        }

        // Step Navigation Logic
        function updateProgress() {
            const percentage = (currentStepNum / totalSteps) * 100;
            $("#progressBar").css("width", `${percentage}%`);
        }

        function validateStep(step) {
            let isValid = true;
            $(`#step${step} [required]`).each(function() {
                if (!$(this).val()) {
                    isValid = false;
                    $(this).addClass("is-invalid");
                } else {
                    $(this).removeClass("is-invalid");
                }
            });

            // Special handling for Step 1 Specialty select
            if (step === 1) {
                const specVal = $("#specialitySelect").val();
                if (!specVal) {
                    isValid = false;
                    $("#specialitySelect").addClass("is-invalid");
                    $("#specialityError").show();
                } else {
                    $("#specialitySelect").removeClass("is-invalid");
                    $("#specialityError").hide();
                }
            }

            return isValid;
        }

        function nextStep() {
            if (!validateStep(currentStepNum)) {
                return;
            }

            if (currentStepNum < totalSteps) {
                // Hide current section
                $(`#step${currentStepNum}`).removeClass("active").hide();
                currentStepNum++;
                
                // Show next section
                $(`#step${currentStepNum}`).addClass("active").show();
                
                // Show/hide navigation helper buttons
                $("#prevBtn").show();
                
                if (currentStepNum === totalSteps) {
                    $("#nextBtn span").text("تفعيل الحساب والاشتراك");
                    $("#nextBtn i").attr("class", "fas fa-check-circle");
                    initMap();
                } else {
                    $("#nextBtn span").text("متابعة");
                    $("#nextBtn i").attr("class", "fas fa-arrow-left");
                }
                
                updateProgress();
            } else {
                // Submit Form on last step
                if (isSubscribed) {
                    $("#onboardingForm").submit();
                } else {
                    alert("يرجى الاشتراك في خدمة إطمن بوك لتفعيل حسابك ومتابعة التسجيل.");
                }
            }
        }

        function prevStep() {
            if (currentStepNum > 1) {
                $(`#step${currentStepNum}`).removeClass("active").hide();
                currentStepNum--;
                $(`#step${currentStepNum}`).addClass("active").show();
                
                if (currentStepNum === 1) {
                    $("#prevBtn").hide();
                }
                
                $("#nextBtn span").text("متابعة");
                $("#nextBtn i").attr("class", "fas fa-arrow-left");
                
                updateProgress();
            }
        }
    </script>
</body>
</html>
