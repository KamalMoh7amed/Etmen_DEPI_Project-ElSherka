@model IEnumerable<Etmen_BLL.DTOs.Lab.LabResultDto>
@{
    ViewData["Title"] = "نتائج التحاليل والتقارير الطبية";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    var uploadModel = ViewBag.LabUpload as Etmen_PL.Models.ViewModels.Patient.LabUploadViewModel ?? new Etmen_PL.Models.ViewModels.Patient.LabUploadViewModel();
}

<style>
    /* Premium file upload area */
    .upload-zone-custom {
        border: 2.5px dashed var(--border);
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background: #FAFCFF;
        position: relative;
    }
    .upload-zone-custom:hover, .upload-zone-custom.dragover {
        border-color: var(--primary);
        background: var(--primary-light);
    }
    .upload-zone-custom input[type="file"] {
        position: absolute; inset: 0; width: 100%; height: 100%;
        opacity: 0; cursor: pointer;
    }
    .upload-zone-icon-custom {
        font-size: 3rem; color: var(--primary); margin-bottom: 1.2rem;
        animation: pulseMini 2s infinite;
    }

    /* Vertical timeline for labs */
    .lab-timeline {
        position: relative;
        padding-right: 2.5rem;
    }
    .lab-timeline::before {
        content: '';
        position: absolute;
        right: 15px; top: 10px; bottom: 10px;
        width: 3px;
        background: linear-gradient(to bottom, var(--primary), var(--accent));
        border-radius: 3px;
    }
    .lab-timeline-item {
        position: relative;
        margin-bottom: 2.5rem;
    }
    .lab-timeline-dot {
        position: absolute;
        right: -32px; top: 12px;
        width: 18px; height: 18px;
        border-radius: 50%;
        background-color: var(--primary);
        border: 4px solid white;
        box-shadow: 0 0 0 3px var(--primary-light);
        z-index: 2;
    }
    .lab-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(26,111,191,0.01);
    }
    .lab-card:hover {
        transform: translateX(-3px);
        box-shadow: 0 10px 25px rgba(26,111,191,0.05);
        border-color: var(--primary);
    }

    .lab-file-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 50px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }
    .lab-file-badge:hover {
        background: var(--primary);
        color: white;
    }
</style>

<div class="row g-4 mb-4">
    <div class="col-12 animate__animated animate__fadeInUp">
        <h2 class="fw-black text-dark"><i class="fas fa-flask text-primary"></i> نتائج التحاليل والتقارير الطبية (OCR)</h2>
        <p class="text-muted">ارفع مستندات تقاريرك الطبية والتحاليل المخبرية. سيقوم المساعد الطبي بقراءتها تلقائياً بالذكاء الاصطناعي وتلخيصها لك.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Right side: Upload Box -->
    <div class="col-lg-5 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="med-card">
            <h4 class="fw-black text-primary mb-4"><i class="fas fa-cloud-upload-alt"></i> تسجيل تحليل جديد</h4>
            
            <form method="post" asp-controller="LabResults" asp-action="Upload" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PatientId" value="@uploadModel.PatientId" />

                <div class="mb-3">
                    <label class="form-label fw-bold small">اسم التحليل أو الفحص</label>
                    <input type="text" name="TestName" class="form-control" placeholder="مثال: تحليل CBC أو فحص السكر التراكمي" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">تاريخ إجراء الفحص</label>
                    <input type="date" name="TestDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">الملف الطبي (صورة أو PDF)</label>
                    <div class="upload-zone-custom" id="labUploadZone">
                        <input type="file" name="LabFile" accept=".pdf,.jpg,.jpeg,.png" id="labFileInput" required />
                        <div class="upload-zone-icon-custom"><i class="fas fa-file-medical"></i></div>
                        <p class="fw-bold mb-1 text-dark">اسحب الملف هنا أو انقر للاستعراض</p>
                        <p class="text-muted small mb-0" id="labFileNameDisplay">تنسيقات مدعومة: PDF, JPG, PNG (بحد أقصى 10 ميجا)</p>
                    </div>
                </div>

                <div class="form-check form-switch p-0 pe-4 mb-4">
                    <input class="form-check-input float-end" type="checkbox" id="UseOcr" name="UseOcr" value="true" checked>
                    <label class="form-check-label fw-bold me-4" for="UseOcr">
                        <i class="fas fa-brain text-accent"></i> تفعيل التعرف الضوئي بالذكاء الاصطناعي (OCR)
                    </label>
                    <div class="text-muted small mt-1">سيقوم النظام بمسح النص واستخراجه آلياً لتخزينه في ملفك الموحد.</div>
                </div>

                <button type="submit" class="btn btn-submit w-100 py-3"><i class="fas fa-upload"></i> رفع وتخزين التقرير</button>
            </form>
        </div>
    </div>

    <!-- Left side: Timeline list -->
    <div class="col-lg-7 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <div class="med-card">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h4 class="fw-black text-primary mb-0"><i class="fas fa-history"></i> الخط الزمني للتحاليل السابقة</h4>
                @if (Model != null && Model.Any())
                {
                    <span class="badge bg-primary px-3 py-2 fw-bold" style="border-radius:8px;">@Model.Count() تحاليل مسجلة</span>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="lab-timeline">
                    @foreach (var lab in Model)
                    {
                        string ext = string.Empty;
                        if (!string.IsNullOrEmpty(lab.FilePath))
                        {
                            ext = System.IO.Path.GetExtension(lab.FilePath).ToUpper().TrimStart('.');
                        }

                        <div class="lab-timeline-item">
                            <div class="lab-timeline-dot"></div>
                            <div class="lab-card">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                    <div>
                                        <h6 class="fw-bold mb-1 text-dark">@lab.TestName</h6>
                                        <span class="text-muted small"><i class="far fa-calendar-alt"></i> تم الفحص: @lab.TestDate.ToString("yyyy/MM/dd")</span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        @if (!string.IsNullOrEmpty(lab.FilePath))
                                        {
                                            <a href="@lab.FilePath" target="_blank" class="lab-file-badge">
                                                <i class="fas fa-file-download"></i> مستند @ext
                                            </a>
                                        }
                                        @if (lab.Id > 0)
                                        {
                                            <a href="@Url.Action("DownloadPdf", "LabResults", new { id = lab.Id })" class="lab-file-badge" style="background: #FDF2F2; color: var(--danger); border: 1px solid rgba(231,76,60,0.15);" title="تحميل التقرير الموحد PDF">
                                                <i class="fas fa-file-pdf"></i> تقرير PDF
                                            </a>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(lab.OcrExtractedData))
                                {
                                    <div class="p-3 mb-2 rounded-3" style="background:#F0FDF4; border:1px solid #BBF7D0;">
                                        <span class="small fw-bold text-success d-block mb-1"><i class="fas fa-brain"></i> البيانات المستخرجة بالـ OCR:</span>
                                        <p class="mb-0 small text-dark">@lab.OcrExtractedData</p>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(lab.Results))
                                {
                                    <div class="p-3 rounded-3" style="background:#E8F4FD; border:1px solid #C4DDF2;">
                                        <span class="small fw-bold text-primary d-block mb-1"><i class="fas fa-notes-medical"></i> ملخص النتيجة الطبية:</span>
                                        <p class="mb-0 small text-dark">@lab.Results</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-flask mb-3 fs-1 text-black-50" style="animation: pulseMini 2s infinite;"></i>
                    <p class="fw-bold mb-1">لا توجد سجلات تحاليل سابقة</p>
                    <p class="small text-muted max-width-350 mx-auto">ارفع أول فحص مخبري من النموذج الأيمن لتبدأ بتكوين خطك الزمني الطبي الموحد.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Setup Drag and Drop
        const zone = document.getElementById('labUploadZone');
        const input = document.getElementById('labFileInput');
        const display = document.getElementById('labFileNameDisplay');

        ['dragenter', 'dragover'].forEach(name => {
            zone.addEventListener(name, e => {
                e.preventDefault();
                zone.classList.add('dragover');
            });
        });
        ['dragleave', 'drop'].forEach(name => {
            zone.addEventListener(name, e => {
                e.preventDefault();
                zone.classList.remove('dragover');
            });
        });

        input.addEventListener('change', function() {
            if (this.files.length > 0) {
                const file = this.files[0];
                const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
                display.innerHTML = `<i class="fas fa-check-circle text-success"></i> <strong>${file.name}</strong> (${sizeMB} ميجا)`;
            }
        });
    </script>
}
