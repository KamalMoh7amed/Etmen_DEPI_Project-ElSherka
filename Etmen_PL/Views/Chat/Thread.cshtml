@using Etmen_PL.Models.ViewModels.Chat
@model ChatThreadViewModel
@{
    ViewData["Title"] = $"محادثة مع {Model.OtherUserName}";
    var isDoctor = User.IsInRole("Doctor");
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    Layout = isDoctor ? "~/Views/Shared/_DoctorLayout.cshtml" : "~/Views/Shared/_PatientLayout.cshtml";
}

<div class="chat-container">
    <!-- Chat Header -->
    <div class="chat-header">
        <div class="d-flex align-items-center gap-3">
            <a href="/Chat/Index" class="btn-back-chat">
                <i class="fas fa-arrow-right"></i>
            </a>
            <div class="chat-user-avatar">
                @Model.OtherUserName.Substring(0, Math.Min(2, Model.OtherUserName.Length))
            </div>
            <div>
                <h6 class="fw-bold mb-0 chat-user-name">@Model.OtherUserName</h6>
                <small class="text-muted chat-status-text" id="chatStatus">
                    <span class="online-dot"></span> محادثة نشطة
                </small>
            </div>
        </div>
    </div>

    <!-- Messages Area -->
    <div class="chat-messages-area" id="messagesArea">
        @if (Model.Messages.Any())
        {
            foreach (var msg in Model.Messages)
            {
                var isMine = msg.SenderId == currentUserId;
                <div class="d-flex mb-3 @(isMine ? "justify-content-start" : "justify-content-end") message-item animate__animated animate__fadeInUp" style="animation-duration:0.3s;">
                    <div class="msg-bubble @(isMine ? "msg-sent" : "msg-received")">
                        <p class="mb-1" style="line-height:1.5;margin:0;word-break:break-word;">@msg.Message</p>
                        <div class="msg-meta">
                            <span style="font-size:0.65rem;">@msg.SentAt.ToString("HH:mm")</span>
                            @if (isMine)
                            {
                                <span style="font-size:0.65rem;margin-right:4px;">
                                    @if (msg.IsRead)
                                    {
                                        <i class="fas fa-check-double text-primary"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-check"></i>
                                    }
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center h-100">
                <div class="text-center">
                    <div style="font-size:3rem;color:var(--border);margin-bottom:0.5rem;"><i class="far fa-comment-dots"></i></div>
                    <p class="text-muted small fw-bold mb-0">لا توجد رسائل بعد</p>
                    <p class="text-muted" style="font-size:0.75rem;">أرسل رسالة لبدء المحادثة</p>
                </div>
            </div>
        }
    </div>

    <!-- Typing Indicator -->
    <div id="typingIndicator" style="display:none;padding:8px 24px;background:rgba(255,255,255,0.02);border-top:1px solid rgba(0,0,0,0.03);">
        <div class="d-flex align-items-center gap-2" style="color:var(--text-muted);font-size:0.75rem;">
            <div class="typing-dots"><span>.</span><span>.</span><span>.</span></div>
            <span>@Model.OtherUserName يكتب...</span>
        </div>
    </div>

    <!-- Input Area -->
    <div class="chat-input-area">
        <form id="chatForm" class="d-flex gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" id="receiverId" value="@Model.OtherUserId" />
            <div class="flex-grow-1">
                <textarea id="messageInput" class="form-control chat-textarea" rows="1" placeholder="اكتب رسالتك هنا..." oninput="autoResize(this)"></textarea>
            </div>
            <button type="submit" class="chat-send-btn" id="sendBtn">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 180px);
        min-height: 520px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.03);
        overflow: hidden;
    }
    body.theme-dark .chat-container {
        background: #151A22;
        border-color: #2D3748;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
    }
    
    /* Header styling */
    .chat-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
        flex-shrink: 0;
    }
    body.theme-dark .chat-header {
        background: #1A202C;
        border-bottom-color: #2D3748;
    }
    .chat-user-name {
        color: #1e293b;
    }
    body.theme-dark .chat-user-name {
        color: #f3f4f6;
    }
    .chat-status-text {
        font-size: 0.75rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    body.theme-dark .chat-status-text {
        color: #9ca3af;
    }
    
    .btn-back-chat {
        background: #f1f5f9;
        border: 1px solid #cbd5e1;
        color: #475569;
        padding: 6px 12px;
        border-radius: 10px;
        transition: all 0.2s;
        text-decoration: none;
    }
    .btn-back-chat:hover {
        background: #e2e8f0;
        color: #1e293b;
    }
    body.theme-dark .btn-back-chat {
        background: #2D3748;
        border-color: #4A5568;
        color: #cbd5e1;
    }
    body.theme-dark .btn-back-chat:hover {
        background: #4A5568;
        color: #fff;
    }
    
    .chat-user-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2);
    }
    
    .online-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #22c55e;
    }
    
    /* Messages area */
    .chat-messages-area {
        background: #f8fafc;
        padding: 1.5rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    body.theme-dark .chat-messages-area {
        background: #0D1117;
    }
    #messagesArea::-webkit-scrollbar { width: 5px; }
    #messagesArea::-webkit-scrollbar-track { background: transparent; }
    #messagesArea::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    body.theme-dark #messagesArea::-webkit-scrollbar-thumb { background: #4A5568; }
    
    /* Message bubble styling */
    .msg-bubble {
        padding: 0.75rem 1.1rem;
        border-radius: 18px;
        font-size: 0.9rem;
        line-height: 1.5;
        max-width: 75%;
        position: relative;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        transition: all 0.2s ease;
    }
    
    /* Sent messages (Mine) */
    .msg-sent {
        background: #e0e7ff;
        color: #1e1b4b;
        border-bottom-right-radius: 4px;
        border: 1px solid #c7d2fe;
    }
    body.theme-dark .msg-sent {
        background: #1e293b;
        color: #f3f4f6;
        border-color: #3b82f6;
    }
    
    .msg-received {
        background: #ffffff;
        color: #1e293b;
        border-bottom-left-radius: 4px;
        border: 1px solid #e2e8f0;
    }
    body.theme-dark .msg-received {
        background: #1c2128;
        color: #f3f4f6;
        border-color: #2d3748;
    }
    
    /* Time & Status */
    .msg-meta {
        font-size: 0.65rem;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
        opacity: 0.7;
    }
    .msg-sent .msg-meta {
        color: #4338ca;
        justify-content: flex-end;
    }
    body.theme-dark .msg-sent .msg-meta {
        color: #93c5fd;
    }
    .msg-received .msg-meta {
        color: #64748b;
        justify-content: flex-start;
    }
    body.theme-dark .msg-received .msg-meta {
        color: #9ca3af;
    }
    
    /* Input area */
    .chat-input-area {
        background: #ffffff;
        border-top: 1px solid #e2e8f0;
        padding: 1.1rem 1.3rem;
        flex-shrink: 0;
    }
    body.theme-dark .chat-input-area {
        background: #1A202C;
        border-top-color: #2D3748;
    }
    
    .chat-textarea {
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-radius: 24px;
        padding: 0.75rem 1.2rem;
        font-size: 0.92rem;
        transition: all 0.2s ease;
        color: #0f172a;
        resize: none;
        max-height: 120px;
    }
    body.theme-dark .chat-textarea {
        background: #2D3748;
        border-color: #4A5568;
        color: #f3f4f6;
    }
    .chat-textarea:focus {
        background: #ffffff;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        outline: none;
    }
    body.theme-dark .chat-textarea:focus {
        background: #1A202C;
        border-color: #3b82f6;
    }
    
    .chat-send-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        transition: all 0.2s ease;
        box-shadow: 0 4px 6px rgba(59, 130, 246, 0.2);
        padding: 0;
    }
    .chat-send-btn:hover:not(:disabled) {
        background: #2563eb;
        transform: translateY(-1px);
    }
    .chat-send-btn:disabled {
        background: #94a3b8;
        box-shadow: none;
        cursor: not-allowed;
    }
    
    .typing-dots span {
        animation: dotAnim 1.4s infinite;
        font-size: 1.5rem;
        line-height: 0;
        margin: 0 1px;
        display: inline-block;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes dotAnim {
        0%, 60%, 100% { opacity: 0.3; }
        30% { opacity: 1; }
    }
    .message-item {
        animation: slideInMsg 0.3s ease;
    }
    @@keyframes slideInMsg {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
    <script>
        function autoResize(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
        }

        // Scroll to bottom
        function scrollToBottom() {
            const area = document.getElementById('messagesArea');
            area.scrollTop = area.scrollHeight;
        }
        scrollToBottom();

        // Send message
        $('#chatForm').on('submit', function(e) {
            e.preventDefault();
            const input = $('#messageInput');
            const text = input.val().trim();
            if (!text) return;

            const receiverId = $('#receiverId').val();
            const token = $('input[name="__RequestVerificationToken"]').val();
            const btn = $('#sendBtn');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

            $.post('/Chat/SendMessage', {
                receiverId: receiverId,
                messageText: text,
                __RequestVerificationToken: token
            }, function(response) {
                if (response.success) {
                    // Remove empty state if present
                    $('#messagesArea .h-100').remove();
                    
                    // Append new message
                    const msg = response.data;
                    const isMine = msg.senderId === '@currentUserId';
                    const readIcon = isMine ? '<i class="fas fa-check"></i>' : '';
                    const html = `
                        <div class="d-flex mb-3 justify-content-start message-item">
                            <div class="msg-bubble msg-sent">
                                <p class="mb-1" style="line-height:1.5;margin:0;word-break:break-word;">${escapeHtml(msg.message)}</p>
                                <div class="msg-meta">
                                    <span style="font-size:0.65rem;">${new Date(msg.sentAt).toLocaleTimeString('ar-EG', {hour:'2-digit',minute:'2-digit'})}</span>
                                    <span style="font-size:0.65rem;margin-right:4px;">${readIcon}</span>
                                </div>
                            </div>
                        </div>
                    `;
                    $('#messagesArea').append(html);
                    input.val('');
                    input.css('height', 'auto');
                    scrollToBottom();
                } else {
                    alert(response.message || 'فشل الإرسال');
                }
            }).fail(function() {
                alert('خطأ في الاتصال بالخادم');
            }).always(function() {
                btn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i>');
            });
        });

        // Escape HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Enter to send, Shift+Enter for new line
        $('#messageInput').on('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                $('#chatForm').submit();
            }
        });
    </script>

    <!-- SignalR Client Integration -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        $(function() {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/chat")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveMessage", function(senderId, msg) {
                const currentReceiverId = $('#receiverId').val();
                if (senderId === currentReceiverId) {
                    // Remove empty state
                    $('#messagesArea .h-100').remove();
                    
                    const isMine = msg.senderId === '@currentUserId';
                    const readIcon = isMine ? (msg.isRead ? '<i class="fas fa-check-double text-primary"></i>' : '<i class="fas fa-check"></i>') : '';
                    const bubbleClass = isMine ? 'msg-sent' : 'msg-received';
                    const alignment = isMine ? 'justify-content-start' : 'justify-content-end';
                    
                    const html = `
                        <div class="d-flex mb-3 ${alignment} message-item">
                            <div class="msg-bubble ${bubbleClass}">
                                <p class="mb-1" style="line-height:1.5;margin:0;word-break:break-word;">${escapeHtml(msg.message)}</p>
                                <div class="msg-meta">
                                    <span style="font-size:0.65rem;">${new Date(msg.sentAt).toLocaleTimeString('ar-EG', {hour:'2-digit',minute:'2-digit'})}</span>
                                    ${isMine ? `<span style="font-size:0.65rem;margin-right:4px;">${readIcon}</span>` : ''}
                                </div>
                            </div>
                        </div>
                    `;
                    $('#messagesArea').append(html);
                    scrollToBottom();
                }
            });

            connection.on("ReceiveTyping", function(senderId, isTyping) {
                const currentReceiverId = $('#receiverId').val();
                if (senderId === currentReceiverId) {
                    if (isTyping) {
                        $('#typingIndicator').show();
                    } else {
                        $('#typingIndicator').hide();
                    }
                }
            });

            connection.start().then(function() {
                console.log("SignalR connected to ChatHub.");
            }).catch(function(err) {
                console.error("SignalR Connection Error: ", err);
            });

            // Handle typing indicator trigger
            let typingTimer;
            $('#messageInput').on('input', function() {
                const receiverId = $('#receiverId').val();
                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("SendTyping", receiverId, true).catch(err => console.error(err));
                    
                    clearTimeout(typingTimer);
                    typingTimer = setTimeout(function() {
                        connection.invoke("SendTyping", receiverId, false).catch(err => console.error(err));
                    }, 2000);
                }
            });
        });
    </script>

}
