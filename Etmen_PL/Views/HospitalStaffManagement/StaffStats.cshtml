@model Etmen_BLL.DTOs.HospitalStaff.StaffStatsDto
@{
    ViewData["Title"] = "إحصائيات أداء الموظفين";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_DoctorLayout.cshtml";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                @if (User.IsInRole("Admin"))
                {
                    <a href="/AdminProviders/Edit/@Model.ProviderId" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-arrow-right"></i> العودة للمنشأة
                    </a>
                }
                else
                {
                    <a href="/DoctorClinic" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-arrow-right"></i> العودة للعيادة
                    </a>
                }
            </div>
            <h2 class="fw-black text-dark m-0" style="font-weight: 900;">إحصائيات أداء موظفي الطوارئ</h2>
            <p class="text-muted small mb-0">
                <i class="fas fa-chart-line me-1"></i> تقارير الكفاءة وسرعة الاستجابة لطلبات الطوارئ في <strong>@Model.ProviderName</strong>.
            </p>
        </div>
    </div>

    <!-- Stats summary widgets -->
    <div class="row g-4 mb-4">
        <!-- Widget 1: Total staff -->
        <div class="col-lg-3 col-md-6 col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-3" style="background: white; border: 1px solid rgba(0,0,0,0.02) !important;">
                <div class="rounded-3 p-3 bg-primary-light text-primary fs-3" style="background-color:rgba(26,111,191,0.05);"><i class="fas fa-users"></i></div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.TotalStaffCount</h3>
                    <small class="text-muted">إجمالي الموظفين</small>
                </div>
            </div>
        </div>

        <!-- Widget 2: Active Receptionists -->
        <div class="col-lg-3 col-md-6 col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-3" style="background: white; border: 1px solid rgba(0,0,0,0.02) !important;">
                <div class="rounded-3 p-3 bg-success-light text-success fs-3" style="background-color:rgba(40,167,69,0.05);"><i class="fas fa-concierge-bell"></i></div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.ActiveReceptionistsCount</h3>
                    <small class="text-muted">نشط للاستقبال</small>
                </div>
            </div>
        </div>

        <!-- Widget 3: Active Triage Staff -->
        <div class="col-lg-3 col-md-6 col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-3" style="background: white; border: 1px solid rgba(0,0,0,0.02) !important;">
                <div class="rounded-3 p-3 bg-warning-light text-warning fs-3" style="background-color:rgba(255,193,7,0.05);"><i class="fas fa-ambulance"></i></div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.ActiveTriageStaffCount</h3>
                    <small class="text-muted">نشط للفرز والطوارئ</small>
                </div>
            </div>
        </div>

        <!-- Widget 4: Average response time -->
        <div class="col-lg-3 col-md-6 col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4 d-flex flex-row align-items-center gap-3" style="background: white; border: 1px solid rgba(0,0,0,0.02) !important;">
                <div class="rounded-3 p-3 bg-danger-light text-danger fs-3" style="background-color:rgba(220,53,69,0.05);"><i class="fas fa-stopwatch"></i></div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.AverageResponseTimeInMinutes دقيقة</h3>
                    <small class="text-muted">متوسط سرعة الاستجابة</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Table -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="background: white;">
                <h5 class="fw-bold text-dark border-bottom pb-3 mb-4">
                    <i class="fas fa-list-check text-primary"></i> أداء الموظفين الفردي
                </h5>

                <div class="table-responsive">
                    <table class="table align-middle table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>اسم الموظف</th>
                                <th>البريد الإلكتروني</th>
                                <th>الدور الوظيفي</th>
                                <th class="text-center">الحالات التي تعامل معها</th>
                                <th class="text-center">متوسط سرعة الاستجابة</th>
                                <th>الكفاءة والتقييم</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.StaffPerformance.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fas fa-chart-bar fs-1 mb-3 text-muted opacity-50"></i>
                                        <h5>لا توجد بيانات أداء مسجلة للموظفين بعد</h5>
                                        <p class="small mb-0">تظهر الإحصائيات هنا بمجرد استجابة الموظفين لحالات الطوارئ والفرز.</p>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var staff in Model.StaffPerformance)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-circle bg-primary-light text-primary fw-bold" style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;background-color:rgba(26,111,191,0.1);">
                                                    @staff.StaffName.Substring(0, Math.Min(1, staff.StaffName.Length))
                                                </div>
                                                <span class="fw-bold text-dark">@staff.StaffName</span>
                                            </div>
                                        </td>
                                        <td><span class="font-monospace text-muted small">@staff.Email</span></td>
                                        <td>
                                            <span class="badge @(staff.RoleType == StaffRoleType.TriageStaff ? "bg-warning-light text-warning" : "bg-primary-light text-primary") rounded-pill px-3 py-1.5" style="font-size: 0.8rem; background-color:@(staff.RoleType == StaffRoleType.TriageStaff ? "rgba(255,193,7,0.1)" : "rgba(26,111,191,0.1)") !important;">
                                                @(staff.RoleType == StaffRoleType.TriageStaff ? "موظف طوارئ وفرز" : "موظف استقبال")
                                            </span>
                                        </td>
                                        <td class="text-center"><span class="fw-bold text-dark fs-6">@staff.HandledRequestsCount</span></td>
                                        <td class="text-center"><span class="fw-bold text-danger fs-6">@staff.AverageResponseTimeInMinutes دقيقة</span></td>
                                        <td>
                                            @{
                                                var score = 0;
                                                if (staff.HandledRequestsCount > 0)
                                                {
                                                    if (staff.AverageResponseTimeInMinutes <= 5) score = 100;
                                                    else if (staff.AverageResponseTimeInMinutes <= 10) score = 85;
                                                    else if (staff.AverageResponseTimeInMinutes <= 20) score = 65;
                                                    else score = 45;
                                                }
                                            }
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 8px; border-radius: 4px;">
                                                    <div class="progress-bar @(score >= 80 ? "bg-success" : score >= 60 ? "bg-warning" : "bg-danger")" role="progressbar" style="width: @score%" aria-valuenow="@score" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <span class="small fw-bold text-muted">@score%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
