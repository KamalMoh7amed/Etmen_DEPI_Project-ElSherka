@model List<Etmen_BLL.DTOs.HospitalStaff.StaffActivityLogDto>
@{
    ViewData["Title"] = "سجل العمليات والأنشطة";
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_DoctorLayout.cshtml";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                @if (User.IsInRole("Admin"))
                {
                    <a href="/AdminProviders/Edit/@ViewBag.ProviderId" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-arrow-right"></i> العودة للمنشأة
                    </a>
                }
                else
                {
                    <a href="/DoctorClinic" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-arrow-right"></i> العودة للعيادة
                    </a>
                }
            </div>
            <h2 class="fw-black text-dark m-0" style="font-weight: 900;">سجل العمليات والأنشطة (Audit Trail)</h2>
            <p class="text-muted small mb-0">
                <i class="fas fa-history me-1"></i> تتبع ومراقبة العمليات المنفذة بواسطة موظفي الاستقبال والطوارئ.
            </p>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="card border-0 shadow-sm rounded-4 p-4" style="background: white;">
        <h5 class="fw-bold text-dark border-bottom pb-3 mb-4">
            <i class="fas fa-receipt text-primary"></i> عمليات الموظفين الأخيرة
        </h5>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 200px;">التاريخ والوقت</th>
                        <th style="width: 200px;">الموظف</th>
                        <th style="width: 180px;">العملية</th>
                        <th>التفاصيل</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-file-invoice fs-1 mb-3 text-muted opacity-50"></i>
                                <h5>لا توجد عمليات مسجلة حالياً</h5>
                                <p class="small mb-0">يتم تسجيل أي إجراء مثل تحديث الأسرة أو قبول الحالات تلقائياً هنا.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in Model)
                        {
                            var actionClass = log.Action switch
                            {
                                "Invited" => "badge bg-info-light text-info",
                                "AcceptedInvitation" => "badge bg-success-light text-success",
                                "RespondToRequest" => "badge bg-primary-light text-primary",
                                "UpdateBeds" => "badge bg-warning-light text-warning",
                                "UpdateProfile" => "badge bg-dark-light text-dark",
                                "RequestSupport" => "badge bg-danger-light text-danger",
                                _ => "badge bg-secondary-light text-secondary"
                            };

                            var actionArabic = log.Action switch
                            {
                                "Invited" => "دعوة موظف",
                                "AcceptedInvitation" => "قبول الدعوة",
                                "RespondToRequest" => "استجابة لطوارئ",
                                "UpdateBeds" => "تعديل أسرة",
                                "UpdateProfile" => "تحديث ملف المنشأة",
                                "RequestSupport" => "طلب دعم عاجل",
                                _ => log.Action
                            };

                            <tr>
                                <td>
                                    <span class="text-muted font-monospace small"><i class="far fa-clock me-1"></i> @log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark"><i class="fas fa-user-circle me-1 text-muted"></i> @log.StaffName</span>
                                </td>
                                <td>
                                    <span class="@actionClass py-1.5 px-3 rounded-pill" style="font-size:0.8rem; background-color: rgba(0,0,0,0.03) !important;">@actionArabic</span>
                                </td>
                                <td>
                                    <span class="text-dark small">@log.Details</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
