@using Etmen_PL.Models.ViewModels.Emergency
@model DoctorPanicInboxViewModel
@{
    ViewData["Title"] = "صندوق حالات الطوارئ";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<style>
    /* ──────────────────────── Emergency Inbox Styles ──────────────────────── */
    .ei-hero {
        position: relative;
        overflow: hidden;
        border-radius: 20px;
        padding: 2rem 2.5rem;
        background: linear-gradient(135deg, #1a0505 0%, #4a0a0a 45%, #8b1a1a 100%);
        border: 1px solid rgba(220, 38, 38, 0.3);
        box-shadow: 0 8px 40px rgba(220, 38, 38, 0.25), 0 2px 10px rgba(0,0,0,0.5);
        animation: fadeInDown 0.6s ease both;
    }

    .ei-hero::before {
        content: '';
        position: absolute;
        top: -50%; right: -20%;
        width: 450px; height: 450px;
        background: radial-gradient(circle, rgba(220,38,38,0.18) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .pulse-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 52px; height: 52px;
        border-radius: 50%;
        background: rgba(220, 38, 38, 0.25);
        border: 2px solid rgba(220, 38, 38, 0.5);
        animation: iconPulse 2s ease-in-out infinite;
        flex-shrink: 0;
    }
    .pulse-icon i { color: #f87171; font-size: 1.4rem; }

    @@keyframes iconPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(220,38,38,0.4); }
        50%       { box-shadow: 0 0 0 12px rgba(220,38,38,0); }
    }
    @@keyframes fadeInDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
    @@keyframes fadeInUp   { from { opacity:0; transform:translateY(20px);  } to { opacity:1; transform:translateY(0); } }
    @@keyframes slideInLeft{ from { opacity:0; transform:translateX(-30px); } to { opacity:1; transform:translateX(0); } }

    /* ── Stats ── */
    .ei-stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
    .ei-stat-box   { text-align:center; padding:.8rem 1.2rem; position:relative; }
    .ei-stat-box + .ei-stat-box::before {
        content:''; position:absolute; right:0; top:15%; height:70%; width:1px;
        background:rgba(255,255,255,.15);
    }
    .ei-stat-num   { font-size:2rem; font-weight:800; line-height:1; letter-spacing:-1px; }
    .ei-stat-label { font-size:.68rem; color:rgba(255,255,255,.55); margin-top:4px; text-transform:uppercase; letter-spacing:.5px; }

    /* ── Availability Card ── */
    .availability-card {
        background:rgba(255,255,255,.03);
        border:1px solid rgba(255,255,255,.08);
        border-radius:14px; padding:1.1rem 1.5rem;
        animation:fadeInUp .7s ease .15s both;
    }
    .toggle-switch { position:relative; display:inline-block; width:56px; height:28px; flex-shrink:0; }
    .toggle-switch input { opacity:0; width:0; height:0; }
    .toggle-slider {
        position:absolute; cursor:pointer; inset:0;
        background:rgba(255,255,255,.15); border-radius:28px;
        transition:background .35s ease; border:1px solid rgba(255,255,255,.2);
    }
    .toggle-slider::before {
        content:''; position:absolute; width:20px; height:20px;
        left:4px; top:50%; transform:translateY(-50%);
        background:#fff; border-radius:50%;
        transition:transform .35s cubic-bezier(.34,1.56,.64,1);
        box-shadow:0 2px 6px rgba(0,0,0,.35);
    }
    .toggle-switch input:checked + .toggle-slider { background:#16a34a; border-color:#22c55e; }
    .toggle-switch input:checked + .toggle-slider::before { transform:translateY(-50%) translateX(28px); }

    /* ── Filter Bar ── */
    .ei-filter-bar {
        display:flex; align-items:center; gap:.6rem; flex-wrap:wrap;
        animation:fadeInUp .65s ease .25s both;
    }
    .ei-filter-btn {
        padding:5px 14px; border-radius:20px; font-size:.78rem; font-weight:600; cursor:pointer;
        border:1px solid rgba(255,255,255,.12); background:rgba(255,255,255,.06);
        color:#9ca3af; transition:all .25s ease;
    }
    .ei-filter-btn:hover  { background:rgba(255,255,255,.12); color:#e5e7eb; }
    .ei-filter-btn.active { background:rgba(220,38,38,.2); color:#f87171; border-color:rgba(220,38,38,.4); }
    .ei-filter-btn.active-unassigned { background:rgba(251,191,36,.15); color:#fbbf24; border-color:rgba(251,191,36,.4); }
    .ei-filter-btn.active-mine       { background:rgba(74,222,128,.15); color:#4ade80; border-color:rgba(74,222,128,.4); }

    /* ── Cases Panel ── */
    .ei-panel {
        background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07);
        border-radius:18px; overflow:hidden;
        animation:fadeInUp .65s ease .2s both;
    }
    .ei-panel-header {
        display:flex; align-items:center; justify-content:space-between;
        padding:1.1rem 1.5rem; border-bottom:1px solid rgba(255,255,255,.07);
        background:rgba(255,255,255,.02);
    }
    .ei-panel-title { font-size:.95rem; font-weight:700; color:#e5e7eb; display:flex; align-items:center; gap:.6rem; }
    .ei-refresh-btn {
        display:inline-flex; align-items:center; gap:.4rem;
        padding:.4rem .9rem; border-radius:8px;
        background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
        color:#9ca3af; font-size:.78rem; cursor:pointer; transition:all .25s ease; text-decoration:none;
    }
    .ei-refresh-btn:hover { background:rgba(255,255,255,.1); color:#e5e7eb; transform:translateY(-1px); }

    /* ── Case Card ── */
    .ec-card {
        position:relative; padding:1.1rem 1.5rem;
        border-bottom:1px solid rgba(255,255,255,.06);
        transition:background .25s ease; animation:slideInLeft .45s ease both;
    }
    .ec-card:last-child { border-bottom:none; }
    .ec-card:hover { background:rgba(255,255,255,.04); }
    .ec-card::before {
        content:''; position:absolute; right:0; top:0; bottom:0;
        width:4px; border-radius:0 4px 4px 0; transition:width .25s ease;
    }
    .ec-card:hover::before { width:5px; }
    .ec-card.risk-emergency::before { background:linear-gradient(to bottom,#dc2626,#991b1b); }
    .ec-card.risk-critical::before  { background:linear-gradient(to bottom,#f59e0b,#d97706); }
    .ec-card.risk-high::before      { background:linear-gradient(to bottom,#f97316,#ea580c); }
    .ec-card.risk-other::before     { background:linear-gradient(to bottom,#6366f1,#4f46e5); }

    /* hidden filter state */
    .ec-card.filtered-out { display:none; }

    /* ── Avatar ── */
    .ec-avatar {
        width:44px; height:44px; border-radius:12px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.1rem; flex-shrink:0; border:2px solid rgba(255,255,255,.1);
    }
    .ec-avatar.risk-emergency { background:linear-gradient(135deg,#dc2626,#7f1d1d); }
    .ec-avatar.risk-critical  { background:linear-gradient(135deg,#f59e0b,#92400e); }
    .ec-avatar.risk-high      { background:linear-gradient(135deg,#f97316,#7c2d12); }
    .ec-avatar.risk-other     { background:linear-gradient(135deg,#6366f1,#312e81); }

    /* ── Badges ── */
    .ec-risk-badge {
        display:inline-flex; align-items:center; gap:5px;
        padding:3px 10px; border-radius:20px;
        font-size:.72rem; font-weight:700; letter-spacing:.4px;
    }
    .ec-risk-badge.risk-emergency { background:rgba(220,38,38,.2);  color:#f87171; border:1px solid rgba(220,38,38,.4); }
    .ec-risk-badge.risk-critical  { background:rgba(245,158,11,.2); color:#fbbf24; border:1px solid rgba(245,158,11,.4); }
    .ec-risk-badge.risk-high      { background:rgba(249,115,22,.2); color:#fb923c; border:1px solid rgba(249,115,22,.4); }
    .ec-risk-badge.risk-other     { background:rgba(99,102,241,.2); color:#a5b4fc; border:1px solid rgba(99,102,241,.4); }

    .ec-assigned-badge {
        display:inline-flex; align-items:center; gap:5px;
        padding:4px 12px; border-radius:20px; font-size:.73rem; font-weight:700;
        background:rgba(22,163,74,.15); color:#86efac; border:1px solid rgba(22,163,74,.35);
    }
    .ec-assigned-badge .dot {
        width:7px; height:7px; border-radius:50%; background:#4ade80;
        animation:blink 1.5s ease-in-out infinite;
    }
    @@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }

    /* ── Action Buttons ── */
    .ec-assign-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:6px 14px; border-radius:10px; font-size:.78rem; font-weight:700;
        background:linear-gradient(135deg,#dc2626,#b91c1c); color:white;
        border:1px solid rgba(220,38,38,.5); cursor:pointer;
        transition:all .25s ease; box-shadow:0 2px 10px rgba(220,38,38,.3);
        white-space:nowrap;
    }
    .ec-assign-btn:hover { background:linear-gradient(135deg,#b91c1c,#991b1b); transform:translateY(-2px); box-shadow:0 4px 15px rgba(220,38,38,.45); }
    .ec-assign-btn:active { transform:translateY(0); }

    .ec-chat-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:6px 14px; border-radius:10px; font-size:.78rem; font-weight:700;
        background:rgba(99,102,241,.18); color:#a5b4fc;
        border:1px solid rgba(99,102,241,.35); cursor:pointer;
        transition:all .25s ease; text-decoration:none; white-space:nowrap;
    }
    .ec-chat-btn:hover { background:rgba(99,102,241,.3); color:#c7d2fe; transform:translateY(-2px); }

    .ec-profile-btn {
        display:inline-flex; align-items:center; justify-content:center;
        width:34px; height:34px; border-radius:9px;
        background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.12);
        color:#9ca3af; transition:all .25s ease; flex-shrink:0;
    }
    .ec-profile-btn:hover { background:rgba(255,255,255,.12); color:#e5e7eb; transform:translateY(-2px); }

    /* ── Priority & Wait ── */
    .ec-priority { display:inline-flex; align-items:center; gap:5px; font-size:.8rem; font-weight:700; color:#fbbf24; }
    .ec-wait     { font-size:.72rem; color:rgba(255,255,255,.45); display:flex; align-items:center; gap:4px; }
    .ec-symptoms { font-size:.72rem; color:rgba(255,255,255,.4); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-top:3px; }

    /* ── Empty State ── */
    .ei-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:4rem 2rem; text-align:center; }
    .ei-empty-icon {
        width:80px; height:80px; border-radius:50%;
        background:rgba(22,163,74,.12); border:2px solid rgba(22,163,74,.3);
        display:flex; align-items:center; justify-content:center;
        font-size:2.2rem; color:#4ade80; margin-bottom:1.2rem;
        animation:iconPulse 3s ease-in-out infinite;
    }
    .ei-empty-title { font-size:1.05rem; font-weight:700; color:#e5e7eb; margin-bottom:.4rem; }
    .ei-empty-sub   { font-size:.82rem; color:rgba(255,255,255,.4); max-width:320px; }

    /* ── Toast ── */
    .ei-toast {
        display:flex; align-items:center; gap:.75rem;
        padding:.9rem 1.2rem; border-radius:12px;
        font-size:.875rem; font-weight:500;
        animation:fadeInDown .5s ease; margin-bottom:1.5rem;
    }
    .ei-toast.success { background:rgba(22,163,74,.15); border:1px solid rgba(22,163,74,.35); color:#86efac; }
    .ei-toast.error   { background:rgba(220,38,38,.15); border:1px solid rgba(220,38,38,.35); color:#fca5a5; }

    /* ── RT banner ── */
    .rt-live-dot {
        display:inline-block; width:8px; height:8px; border-radius:50%;
        background:#4ade80; animation:blink 1.2s ease-in-out infinite;
        margin-left:4px;
    }

    @@media (max-width:767px) {
        .ei-hero { padding:1.4rem 1.2rem; }
        .ei-stat-num { font-size:1.4rem; }
        .ec-card { padding:1rem; }
    }

    /* ══════════════════════════════════════════
       LIGHT MODE OVERRIDES
       Applied when body does NOT have .theme-dark
       (default / day mode)
    ══════════════════════════════════════════ */
    body:not(.theme-dark) .availability-card {
        background: #ffffff;
        border-color: #DDE3EC;
        box-shadow: 0 2px 12px rgba(26,111,191,.06);
    }
    body:not(.theme-dark) .availability-card div[style*="color:#e5e7eb"] {
        color: #1B2A38 !important;
    }
    body:not(.theme-dark) .availability-card div[style*="rgba(255,255,255,.45)"] {
        color: #7F8C8D !important;
    }
    body:not(.theme-dark) .availability-card div[style*="rgba(255,255,255,.06)"] {
        background: #F0F4F8 !important;
        border-color: #DDE3EC !important;
        color: #7F8C8D !important;
    }
    body:not(.theme-dark) .availability-card span[style*="rgba(255,255,255,.5)"] {
        color: #7F8C8D !important;
    }
    body:not(.theme-dark) .toggle-slider {
        background: #cbd5e1;
        border-color: #94a3b8;
    }
    body:not(.theme-dark) .toggle-slider::before { background: #fff; }
    body:not(.theme-dark) .toggle-switch input:checked + .toggle-slider {
        background: #16a34a; border-color:#22c55e;
    }

    /* Filter bar */
    body:not(.theme-dark) .ei-filter-bar > span {
        color: #7F8C8D !important;
    }
    body:not(.theme-dark) .ei-filter-btn {
        background: #ffffff;
        border-color: #DDE3EC;
        color: #2C3E50;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    body:not(.theme-dark) .ei-filter-btn:hover {
        background: #F0F4F8;
        color: #1B2A38;
        border-color: #b0bec5;
    }
    body:not(.theme-dark) .ei-filter-btn.active {
        background: rgba(220,38,38,.1);
        color: #b91c1c;
        border-color: rgba(220,38,38,.4);
    }
    body:not(.theme-dark) .ei-filter-btn.active-unassigned {
        background: rgba(180,120,0,.1);
        color: #92400e;
        border-color: rgba(180,120,0,.35);
    }
    body:not(.theme-dark) .ei-filter-btn.active-mine {
        background: rgba(22,163,74,.1);
        color: #15803d;
        border-color: rgba(22,163,74,.35);
    }
    body:not(.theme-dark) #filterResultCount {
        color: #7F8C8D !important;
    }

    /* Cases Panel */
    body:not(.theme-dark) .ei-panel {
        background: #ffffff;
        border-color: #DDE3EC;
        box-shadow: 0 2px 12px rgba(26,111,191,.05);
    }
    body:not(.theme-dark) .ei-panel-header {
        background: #F8FAFC;
        border-bottom-color: #DDE3EC;
    }
    body:not(.theme-dark) .ei-panel-title {
        color: #1B2A38;
    }
    body:not(.theme-dark) .ei-refresh-btn {
        background: #F0F4F8;
        border-color: #DDE3EC;
        color: #2C3E50;
    }
    body:not(.theme-dark) .ei-refresh-btn:hover {
        background: #e2e8f0;
        color: #1B2A38;
    }

    /* Case Cards */
    body:not(.theme-dark) .ec-card {
        border-bottom-color: #F0F2F5;
    }
    body:not(.theme-dark) .ec-card:hover {
        background: #F8FAFC;
    }
    body:not(.theme-dark) .ec-card .fw-bold {
        color: #1B2A38 !important;
    }
    body:not(.theme-dark) .ec-wait {
        color: #7F8C8D !important;
    }
    body:not(.theme-dark) .ec-symptoms {
        color: #94a3b8 !important;
    }
    body:not(.theme-dark) .ec-priority {
        color: #d97706 !important;
    }

    /* Risk badges — light mode: darker text for readability */
    body:not(.theme-dark) .ec-risk-badge.risk-emergency {
        background: #fef2f2; color: #991b1b;
        border-color: rgba(220,38,38,.3);
    }
    body:not(.theme-dark) .ec-risk-badge.risk-critical {
        background: #fffbeb; color: #92400e;
        border-color: rgba(245,158,11,.3);
    }
    body:not(.theme-dark) .ec-risk-badge.risk-high {
        background: #fff7ed; color: #9a3412;
        border-color: rgba(249,115,22,.3);
    }
    body:not(.theme-dark) .ec-risk-badge.risk-other {
        background: #eef2ff; color: #3730a3;
        border-color: rgba(99,102,241,.3);
    }

    /* Assigned badge */
    body:not(.theme-dark) .ec-assigned-badge {
        background: #f0fdf4; color: #15803d;
        border-color: rgba(22,163,74,.3);
    }
    body:not(.theme-dark) .ec-assigned-badge .dot {
        background: #16a34a;
    }

    /* Chat / Profile buttons */
    body:not(.theme-dark) .ec-chat-btn {
        background: #eef2ff; color: #3730a3;
        border-color: rgba(99,102,241,.25);
    }
    body:not(.theme-dark) .ec-chat-btn:hover {
        background: #e0e7ff; color: #312e81;
    }
    body:not(.theme-dark) .ec-profile-btn {
        background: #F0F4F8;
        border-color: #DDE3EC;
        color: #2C3E50;
    }
    body:not(.theme-dark) .ec-profile-btn:hover {
        background: #e2e8f0;
        color: #1B2A38;
    }

    /* Empty state */
    body:not(.theme-dark) .ei-empty-title { color: #1B2A38; }
    body:not(.theme-dark) .ei-empty-sub   { color: #7F8C8D; }
    body:not(.theme-dark) .ei-empty-icon  {
        background: #f0fdf4;
        border-color: rgba(22,163,74,.3);
    }

    /* Toasts */
    body:not(.theme-dark) .ei-toast.success {
        background: #f0fdf4; color: #15803d;
        border-color: rgba(22,163,74,.4);
    }
    body:not(.theme-dark) .ei-toast.error {
        background: #fef2f2; color: #991b1b;
        border-color: rgba(220,38,38,.4);
    }

    /* General daylight mode inline style fallback overrides */
    body:not(.theme-dark) *:not(.ei-hero):not(.ei-hero *) > span[style*="rgba(255,255,255"],
    body:not(.theme-dark) *:not(.ei-hero):not(.ei-hero *) > div[style*="rgba(255,255,255"],
    body:not(.theme-dark) *:not(.ei-hero):not(.ei-hero *) > p[style*="rgba(255,255,255"] {
        color: #64748b !important;
    }
</style>


<div class="d-flex flex-column gap-4">

    @* ── Toast Messages ── *@
    @if (TempData["Success"] != null)
    {
        <div class="ei-toast success">
            <i class="fas fa-check-circle"></i>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="ei-toast error">
            <i class="fas fa-exclamation-circle"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    @* ── Hero Banner ── *@
    <div class="ei-hero">
        <div class="row align-items-center gy-3">
            <div class="col-lg-7">
                <div class="d-flex align-items-center gap-3">
                    <div class="pulse-icon"><i class="fas fa-heartbeat"></i></div>
                    <div>
                        <h2 class="fw-black mb-1" style="color:#fff;font-size:1.55rem;letter-spacing:-0.5px;">
                            صندوق حالات الطوارئ
                        </h2>
                        <p class="mb-0" style="color:rgba(255,255,255,.55);font-size:.85rem;">
                            @if (Model.IsAvailable)
                            {
                                <span><i class="fas fa-circle" style="color:#4ade80;font-size:.5rem;vertical-align:middle;"></i> متاح لاستقبال الحالات الجديدة</span>
                            }
                            else
                            {
                                <span><i class="fas fa-circle" style="color:#f97316;font-size:.5rem;vertical-align:middle;"></i> غير متاح حالياً</span>
                            }
                            <span id="rtStatus" style="margin-right:10px;display:none;">
                                <span class="rt-live-dot"></span> <span style="font-size:.72rem;color:rgba(255,255,255,.45);">مباشر</span>
                            </span>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div style="background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:.5rem;">
                    <div class="ei-stats-grid">
                        <div class="ei-stat-box">
                            <div class="ei-stat-num" id="statTotal" style="color:#fff;">@Model.TotalCriticalCases</div>
                            <div class="ei-stat-label">إجمالي الحالات</div>
                        </div>
                        <div class="ei-stat-box">
                            <div class="ei-stat-num" id="statUnassigned" style="color:#fbbf24;">@Model.UnassignedCriticalCases</div>
                            <div class="ei-stat-label">غير مخصصة</div>
                        </div>
                        <div class="ei-stat-box">
                            <div class="ei-stat-num" id="statMine" style="color:#4ade80;">@Model.AssignedToDoctor</div>
                            <div class="ei-stat-label">مخصصة لك</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Availability Toggle ── *@
    <div class="availability-card">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div style="width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:1.2rem;">
                    <i class="fas fa-user-md"></i>
                </div>
                <div>
                    <div style="font-size:.875rem;font-weight:600;color:#e5e7eb;">حالة استقبال الطوارئ</div>
                    <div style="font-size:.72rem;color:rgba(255,255,255,.45);margin-top:2px;">تحكم في قبول حالات الطوارئ الجديدة تلقائياً</div>
                </div>
            </div>
            <form asp-action="ToggleAvailability" method="post" id="toggleForm">
                @Html.AntiForgeryToken()
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size:.8rem;color:rgba(255,255,255,.5);">@(Model.IsAvailable ? "متاح" : "موقف")</span>
                    <label class="toggle-switch" title="تبديل الحالة">
                        <input type="checkbox" @(Model.IsAvailable ? "checked" : "") onchange="document.getElementById('toggleForm').submit();" />
                        <span class="toggle-slider"></span>
                    </label>
                    <span style="font-size:.8rem;color:rgba(255,255,255,.5);">@(Model.IsAvailable ? "نشط" : "غير نشط")</span>
                </div>
            </form>
        </div>
    </div>

    @* ── Filter Bar ── *@
    <div class="ei-filter-bar">
        <span style="font-size:.8rem;color:rgba(255,255,255,.4);margin-left:.5rem;">فلترة:</span>
        <button class="ei-filter-btn active" onclick="applyFilter('all', this)">
            <i class="fas fa-list"></i> الكل
        </button>
        <button class="ei-filter-btn" onclick="applyFilter('unassigned', this)">
            <i class="fas fa-clock"></i> غير مخصصة
        </button>
        <button class="ei-filter-btn" onclick="applyFilter('mine', this)">
            <i class="fas fa-user-check"></i> مخصصة لي
        </button>
        <button class="ei-filter-btn" onclick="applyFilter('emergency', this)">
            <i class="fas fa-fire"></i> طارئ جداً
        </button>
        <button class="ei-filter-btn" onclick="applyFilter('critical', this)">
            <i class="fas fa-exclamation-triangle"></i> خطير
        </button>
        <div style="margin-right:auto;">
            <span id="filterResultCount" style="font-size:.75rem;color:rgba(255,255,255,.35);"></span>
        </div>
    </div>

    @* ── Cases List ── *@
    <div class="ei-panel">
        <div class="ei-panel-header">
            <div class="ei-panel-title">
                <i class="fas fa-list-ul" style="color:#dc2626;"></i>
                قائمة الحالات الحرجة
                @if (Model.Items.Any())
                {
                    <span style="background:rgba(220,38,38,.2);color:#f87171;border:1px solid rgba(220,38,38,.3);border-radius:20px;font-size:.72rem;padding:2px 9px;">
                        @Model.Items.Count
                    </span>
                }
            </div>
            <a href="javascript:location.reload();" class="ei-refresh-btn">
                <i class="fas fa-sync-alt"></i> تحديث
            </a>
        </div>

        <div id="casesList">
        @if (Model.Items.Any())
        {
            @foreach (var (item, index) in Model.Items.OrderByDescending(i => i.PriorityScore).Select((item, i) => (item, i)))
            {
                var riskClass = item.RiskLevel.ToString() switch {
                    "Emergency" => "risk-emergency",
                    "Critical"  => "risk-critical",
                    "High"      => "risk-high",
                    _           => "risk-other"
                };
                var riskLabel = item.RiskLevel.ToString() switch {
                    "Emergency" => "طارئ جداً",
                    "Critical"  => "خطير",
                    "High"      => "مرتفع",
                    _           => item.RiskLevel.ToString()
                };
                var waitMins = (int)(DateTime.UtcNow - item.RequestedAt).TotalMinutes;

                <div class="ec-card @riskClass"
                     style="animation-delay:@(index * 0.07)s;"
                     data-case-id="@item.EmergencyRequestId"
                     data-risk="@item.RiskLevel.ToString().ToLower()"
                     data-assigned="@(item.IsAssignedToCurrentDoctor ? "mine" : "unassigned")">

                    <div class="row align-items-center gy-2">

                        @* Patient ── *@
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="ec-avatar @riskClass">
                                    <i class="fas fa-user" style="color:rgba(255,255,255,.9);"></i>
                                </div>
                                <div>
                                    <div class="fw-bold" style="color:#e5e7eb;font-size:.92rem;">@item.PatientName</div>
                                    <div class="ec-wait">
                                        <i class="far fa-clock"></i>
                                        @(waitMins < 60 ? $"{waitMins} دقيقة" : $"{waitMins / 60} س {waitMins % 60} د")
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Risk + Symptoms ── *@
                        <div class="col-md-3">
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="ec-risk-badge @riskClass">
                                        <i class="fas fa-circle" style="font-size:.5rem;"></i> @riskLabel
                                    </span>
                                    <span style="color:#fbbf24;font-size:.8rem;font-weight:700;">@item.RiskScore.ToString("P0")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(item.Symptoms))
                                {
                                    <div class="ec-symptoms" title="@item.Symptoms">
                                        <i class="fas fa-stethoscope" style="font-size:.65rem;margin-left:3px;"></i>@item.Symptoms
                                    </div>
                                }
                            </div>
                        </div>

                        @* Priority ── *@
                        <div class="col-md-1">
                            <div class="ec-priority"><i class="fas fa-arrow-up"></i> @item.PriorityScore</div>
                        </div>

                        @* Actions ── *@
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2 justify-content-md-end flex-wrap">
                                @if (item.IsAssignedToCurrentDoctor)
                                {
                                    <span class="ec-assigned-badge"><span class="dot"></span> مخصص لك</span>
                                }
                                else
                                {
                                    <form asp-action="AssignToMe" method="post" style="display:inline;" class="assign-form" data-case-id="@item.EmergencyRequestId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.EmergencyRequestId" />
                                        <button type="submit" class="ec-assign-btn">
                                            <i class="fas fa-hand-paper"></i> تولي الحالة
                                        </button>
                                    </form>
                                }
                                @* Quick Chat button *@
                                <a href="/Chat/Thread?otherUserId=@item.PatientUserId" class="ec-chat-btn" title="محادثة مع المريض">
                                    <i class="fas fa-comment-medical"></i> محادثة
                                </a>
                                <a href="/DoctorPanicInbox/Details/@item.EmergencyRequestId" class="ec-profile-btn" title="تفاصيل الحالة" style="width:auto;padding:0 10px;gap:5px;font-size:.75rem;color:#c4b5fd;border-color:rgba(167,139,250,.3);">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="/DoctorPatients/Details/@item.PatientProfileId" class="ec-profile-btn" title="ملف المريض">
                                    <i class="fas fa-user-md"></i>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="ei-empty">
                <div class="ei-empty-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="ei-empty-title">لا توجد حالات طوارئ نشطة</div>
                <p class="ei-empty-sub">كل الحالات تحت السيطرة. سيتم إشعارك فور ورود حالة جديدة.</p>
            </div>
        }
        </div><!-- /casesList -->
    </div>

</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
// ─── Current doctor user id (for ownership check)
const currentDoctorId = "@Model.DoctorUserId";

// ─── Filter logic
function applyFilter(type, btn) {
    // Update active button styles
    document.querySelectorAll('.ei-filter-btn').forEach(b => {
        b.classList.remove('active', 'active-unassigned', 'active-mine');
    });
    if (type === 'all')         btn.classList.add('active');
    else if (type === 'unassigned') btn.classList.add('active-unassigned');
    else if (type === 'mine')       btn.classList.add('active-mine');
    else                            btn.classList.add('active');

    const cards = document.querySelectorAll('.ec-card');
    let visible = 0;
    cards.forEach(card => {
        const risk     = card.dataset.risk;
        const assigned = card.dataset.assigned;
        let show = false;
        if (type === 'all')         show = true;
        else if (type === 'unassigned') show = assigned === 'unassigned';
        else if (type === 'mine')       show = assigned === 'mine';
        else if (type === 'emergency')  show = risk === 'emergency';
        else if (type === 'critical')   show = risk === 'critical';
        card.classList.toggle('filtered-out', !show);
        if (show) visible++;
    });
    const rc = document.getElementById('filterResultCount');
    if (rc) rc.textContent = type !== 'all' ? `${visible} حالة` : '';
}

// ─── SignalR — Emergency Hub
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/hubs/emergency")
    .withAutomaticReconnect()
    .configureLogging(signalR.LogLevel.Warning)
    .build();

// When another doctor takes a case → remove that card immediately
connection.on("CaseAssigned", function(data) {
    const { emergencyRequestId, assignedToDoctorId } = data;
    const card = document.querySelector(`.ec-card[data-case-id="${emergencyRequestId}"]`);
    if (!card) return;

    if (assignedToDoctorId === currentDoctorId) {
        // It's my own card — just mark as mine
        card.dataset.assigned = 'mine';
        const actionsCol = card.querySelector('.ec-assign-btn');
        if (actionsCol) {
            const form = actionsCol.closest('form');
            if (form) {
                const badge = document.createElement('span');
                badge.className = 'ec-assigned-badge';
                badge.innerHTML = '<span class="dot"></span> مخصص لك';
                form.replaceWith(badge);
            }
        }
    } else {
        // Another doctor took it — animate out
        card.style.transition = 'opacity .5s ease, transform .5s ease, max-height .5s ease';
        card.style.opacity = '0';
        card.style.transform = 'translateX(40px)';
        card.style.maxHeight = card.offsetHeight + 'px';
        setTimeout(() => {
            card.style.maxHeight = '0';
            card.style.padding = '0';
            card.style.margin = '0';
            card.style.overflow = 'hidden';
            card.style.borderBottom = 'none';
        }, 300);
        setTimeout(() => {
            card.remove();
            updateStatCounters();
        }, 600);

        // Brief toast
        showRtToast(`الدكتور ${data.assignedDoctorName || 'آخر'} تولى حالة للتو`);
    }
    updateStatCounters();
});

// Connection status indicator
connection.onreconnecting(() => { toggleRtBadge(false); });
connection.onreconnected(() => { toggleRtBadge(true); });

async function startSignalR() {
    try {
        await connection.start();
        toggleRtBadge(true);
        console.log("EmergencyHub connected.");
    } catch (err) {
        console.warn("EmergencyHub connection failed:", err);
        setTimeout(startSignalR, 5000);
    }
}
startSignalR();

function toggleRtBadge(online) {
    const el = document.getElementById('rtStatus');
    if (el) el.style.display = online ? 'inline' : 'none';
}

// ─── Update stats counters from DOM
function updateStatCounters() {
    const cards = document.querySelectorAll('.ec-card');
    let total = 0, unassigned = 0, mine = 0;
    cards.forEach(c => {
        if (c.style.opacity === '0') return; // animating out
        total++;
        if (c.dataset.assigned === 'unassigned') unassigned++;
        if (c.dataset.assigned === 'mine') mine++;
    });
    const el = (id, val) => { const e = document.getElementById(id); if (e) e.textContent = val; };
    el('statTotal', total);
    el('statUnassigned', unassigned);
    el('statMine', mine);
}

// ─── Small RT toast notification
function showRtToast(msg) {
    const id = 'rtt_' + Date.now();
    const el = document.createElement('div');
    el.id = id;
    el.style.cssText = `position:fixed;bottom:24px;left:24px;z-index:9999;
        background:rgba(30,30,40,.92);backdrop-filter:blur(12px);
        color:#e5e7eb;border:1px solid rgba(255,255,255,.12);border-radius:12px;
        padding:12px 18px;font-size:.82rem;font-weight:600;
        display:flex;align-items:center;gap:10px;
        box-shadow:0 8px 30px rgba(0,0,0,.4);
        animation:fadeInDown .4s ease;`;
    el.innerHTML = `<i class="fas fa-info-circle" style="color:#60a5fa;"></i> ${msg}`;
    document.body.appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity .4s'; setTimeout(() => el.remove(), 400); }, 4000);
}

// ─── Auto-refresh every 90 seconds as fallback
setTimeout(() => window.location.reload(), 90000);
</script>
}
