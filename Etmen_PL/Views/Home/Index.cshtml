            transition: all 0.2s;
            font-size: 1rem;
        }
        .social-link:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
        }

        /* ═══════════════════════════════════════════════════
           CHATBOT FLOATING PANEL Preserved & styled
        ═══════════════════════════════════════════════════ */
        .etmen-chatbot {
            position: fixed;
            left: 30px;
            bottom: 30px;
            z-index: 99999;
        }
        .chatbot-toggle {
            width: 60px;
            height: 60px;
  
          border: 0;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            font-size: 24px;
            box-shadow: 0 8px 30px rgba(16, 118, 110, 0.3);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all .25s ease;
            cursor: pointer;
        }
        .chatbot-toggle:hover {
            transform: translateY(-3px);
            background: var(--primary-dark);
            box-shadow: 0 12px 35px rgba(16, 118, 110, 0.4);
        }
        .chatbot-panel {
            width: 370px;
            height: 500px;
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            display: none;
            flex-direction: column;
            position: absolute;
            left: 0;
            bottom: 75px;
            box-shadow: var(--shadow-xl);
            border: 1px solid var(--border);
        }
        .chatbot-panel.show {
      
      display: flex;
        }
        .chatbot-header {
            background: var(--primary);
            color: #fff;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .chatbot-header h4 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 800;
        }
        .chatbot-header p {
            margin: 2px 0 0;
            font-size: .78rem;
            opacity: .85;
        }
        .chatbot-header button {
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 8px;
            background: rgba(255,255,255,.18);
            color: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }
        .chatbot-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: 
#f8fafc;
        }
        .chat-msg {
            display: flex;
            margin-bottom: 12px;
        }
        .chat-msg.user {
            justify-content: flex-end;
        }
        .chat-bubble {
            max-width: 82%;
            padding: 12px 14px;
            border-radius: 16px;
            font-size: .92rem;
            line-height: 1.6;
            word-break: break-word;
        }
        .chat-msg.bot .chat-bubble {
            background: #fff;
            color: var(--dark);
            border: 1px solid var(--border);
            border-top-right-radius: 4px;
            box-shadow: var(--shadow-sm);
        }
        .chat-msg.user .chat-bubble {
            background: var(--primary);
            color: #fff;
            border-top-left-radius: 4px;
        }
        .chat-msg.loading .chat-bubble {
            font-style: italic;
            color: var(--text-muted);
        }
        .chat-bubble.arabic {
            text-align: right;
        }
        .chatbot-form {
          
  display: flex;
            gap: 10px;
            padding: 14px;
            border-top: 1px solid var(--border);
            background: #fff;
        }
        .chatbot-form input {
            flex: 1;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            outline: none;
            font-size: .9rem;
        }
        .chatbot-form input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16, 118, 110, 0.1);
        }
        .chatbot-form button {
            width: 46px;
            border: 0;
            border-radius: 12px;
            background: var(--primary);
            color: #fff;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
        }
        .chatbot-form button:hover {
            background: var(--primary-dark);
        }

        /* ═══════════════════════════════════════════════════
           SCROLL A
NIMATIONS & RESPONSIVE
        ═══════════════════════════════════════════════════ */
        [data-animate] {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        [data-animate].in-view {
            opacity: 1;
            transform: none;
        }
        [data-animate-delay="1"] { transition-delay: 0.1s; }
        [data-animate-delay="2"] { transition-delay: 0.2s; }
        [data-animate-delay="3"] { transition-delay: 0.3s; }

        
@@media (max-width: 991px) {
            .etmen-nav { padding: 0 1.5rem; }
            .nav-links { display: none; }
            .hero-cards-row { flex-direction: column; }
            .showcase-content { flex-direction: column; text-align: center; }
            .showcase-visual { margin-top: 2rem; }
            .steps-container::before { display: none; }
            .steps-container { flex-direction: column; gap: 3rem; }
        }
        
@@media (max-width: 576px) {
            .chatbot-panel {
                width: calc(100vw - 32px);
                height: 440px;
                left: -10px;
            }
            .hero-promo-title { font-size: 1.8rem; }
            .hero { padding-top: 130px; }
            .section-main-title { font-size: 1.8rem; }
        }
    </style>


</head>
