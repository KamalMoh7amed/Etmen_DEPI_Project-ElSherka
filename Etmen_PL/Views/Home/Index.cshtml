@model Etmen_PL.Models.Home.LandingPageViewModel
@{
    ViewData["Title"] = "إطمن — منصة الرعاية الصحية الرقمية المتكاملة";
    Layout = null; /* Standalone page — owns its own full HTML */
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="إطمن — منصة صحية ذكية تجمع المرضى والأطباء ومقدمي الرعاية في مكان واحد مع نظام متكامل لإدارة الأزمات الصحية والأمراض." />

    <!-- Google Fonts (Tajawal) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- Bootstrap RTL -->
    
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        /* ═══════════════════════════════════════════════════
           DESIGN SYSTEM & CSS VARIABLES
        ═══════════════════════════════════════════════════ */
        :root {
            --primary:          #10766e; /* Medical Teal - Altibbi style */
            --primary-dark:     #0d5c56;
            --primary-light:    #f0fdfa;
            --primary-rgb:      16, 118, 110;
            --secondary:        #0284c7; /* Healing Blue */
            --secondary-light:  #f0f9ff;
            --accent:           #06b6d4; /* Cyan Accent */
            --accent-light:     #ecfeff;
            --success:          #10b981;
            --warning:          #f59e0b;
            --danger:           #ef4444;
            --crisis:           #ea580c;
            --dark:             #0f172a; /* Slate 900 */
            --dark-2:           #1e293b; /* Slate 800 */
 
           --text:             #334155; /* Slate 700 */
            --text-muted:       #64748b; /* Slate 500 */
            --border:           #e2e8f0; /* Slate 200 */
            --white:            #ffffff;
            --shadow-sm:        0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md:        0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
            --shadow-lg:        0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
            --shadow-xl:        0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.1);
            --glass:            rgba(255, 255, 255, 0.85);
            --glass-border:     rgba(255, 255, 255, 0.2);
        }

        /* ═══════════════════════════════════════════════════
           RESET & BASE STYLES
        ═══════════════════════════════════════════════════ */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            
font-family: 'Tajawal', sans-serif;
            color: var(--text);
            background: #fafafb;
            overflow-x: hidden;
            line-height: 1.7;
        }
        a { text-decoration: none; transition: all 0.3s; }
        .text-primary-color { color: var(--primary); }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* ═══════════════════════════════════════════════════
           NAVBAR (HEADER)
        ═══════════════════════════════════════════════════ */
        .etmen-nav {
            position: fixed;
            top: 0; right: 0; left: 0;
            z-index: 1000;
            padding: 0 2rem;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(
255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s ease;
        }
        .etmen-nav.scrolled {
            background: var(--white);
            height: 70px;
            box-shadow: var(--shadow-md);
        }
        .nav-logo {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }
        .nav-logo-icon {
            width: 46px; height: 46px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            color: white;
            box-shadow: 0 4px 12px rgba(16, 118, 110, 0.2);
        }
        .nav-logo-text {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--dark);
            letter-spacing: -0.5px;
        }
        .nav-logo-text span { color: var(--primary); }

  
      .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .nav-links a {
            color: var(--text);
            font-size: 0.95rem;
            font-weight: 700;
            position: relative;
            padding: 6px 0;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0; right: 0; left: 0;
            height: 3px;
            background: var(--primary);
            transform: scaleX(0);
            transition: transform 0.25s;
            transform-origin: right;
            border-radius: 2px;
        }
        .nav-links a:hover { color: var(--primary); }
        .nav-links a:hover::after { transform: scaleX(1); }

        .nav-actions { display: flex; gap: 1rem; align-items: center; }

        .btn-nav-login {
            padding: 10px 22px;
            border: 2px solid var(--primary);
         
   background: transparent;
            color: var(--primary);
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 700;
            transition: all 0.25s;
        }
        .btn-nav-login:hover {
            background: var(--primary-light);
            color: var(--primary-dark);
        }
        .btn-nav-register {
            padding: 10px 24px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 800;
            box-shadow: 0 4px 12px rgba(16, 118, 110, 0.25);
            transition: all 0.25s;
        }
        .btn-nav-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(16, 118, 110, 0.35);
            color: white;
        }

        /* ═══════════════════════════════════════════════════
           CRISIS BANNER
        ═════════════════════════════
══════════════════════ */
        .crisis-banner {
            position: fixed;
            top: 80px; right: 0; left: 0;
            z-index: 999;
            background: linear-gradient(90deg, #ea580c, #ef4444, #ea580c);
            background-size: 200% 100%;
            animation: crisisBg 3s linear infinite;
            color: white;
            text-align: center;
            padding: 10px 2rem;
            font-size: 0.95rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            box-shadow: var(--shadow-md);
            transition: top 0.3s ease;
        }
        .etmen-nav.scrolled + .crisis-banner {
            top: 70px;
        }
        
@@keyframes crisisBg {
            0%   { background-position: 0% 50%; }
            50%  { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .crisis-pulse {
            display: inline-block;
            width: 12px; height: 12px;
            background: white;
            border-radius: 50%;
            animation: pulse 1.4s ease-in-out infinite;
        }
        
@@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.3; transform: scale(1.6); }
        }

        /* ═══════════════════════════════════════════════════
           HERO SECTION (UPGRADED WITH ANIMATIONS & VISUALS)
         ═══════════════════════════════════════════════════ */
        .hero {
            padding: 160px 0 100px;
            background: radial-gradient(circle at 10% 20%, rgba(240, 253, 250, 0.65) 0%, rgba(240, 249, 255, 0.45) 90%);
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: 
                radial-gradient(var(--primary-light) 1.5px, transparent 1.5px);
            background-size: 24px 24px;
            opacity: 0.4;
            z-index: 1;
        }
        .hero-container {
            position: relative;
            z-index: 2;
        }
        
        /* background decoration */
        .hero-glow-blob {
            position: absolute;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(16, 118, 110, 0.12) 0%, rgba(2, 132, 199, 0.08) 50%, transparent 100%);
            filter: blur(40px);
            border-radius: 50%;
            z-index: 1;
            pointer-events: none;
            animation: pulseBlob 8s infinite alternate ease-in-out;
        }
        .hero-glow-blob-1 { top: 5%; left: 5%; }
        .hero-glow-blob-2 { bottom: 5%; right: 5%; animation-delay: -4s; }

        @@keyframes pulseBlob {
            0% { transform: scale(1) translate(0, 0); opacity: 0.8; }
            50% { transform: scale(1.15) translate(15px, -15px); opacity: 1; }
            100% { transform: scale(0.9) translate(-10px, 10px); opacity: 0.7; }
        }

        .hero-tagline {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--primary-light);
            border: 1px solid rgba(16, 118, 110, 0.15);
            padding: 6px 18px;
            border-radius: 50px;
            color: var(--primary);
            font-size: 0.9rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 12px rgba(16, 118, 110, 0.03);
            animation: taglineEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        @@keyframes taglineEntrance {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero-title-main {
            font-size: clamp(2.2rem, 5vw, 3.8rem);
            font-weight: 900;
            color: var(--dark);
            line-height: 1.25;
            margin-bottom: 1.5rem;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeUpIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: 0.15s;
        }
        .hero-title-main span {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero-description {
            font-size: 1.15rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            max-width: 650px;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeUpIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: 0.3s;
        }
        @@keyframes fadeUpIn {
            to { opacity: 1; transform: translateY(0); }
        }

        /* Interactive Mode Badges */
        .mode-badge-card {
            background: var(--white);
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-radius: 18px;
            padding: 16px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            height: 100%;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: var(--shadow-sm);
            position: relative;
            overflow: hidden;
        }
        .mode-badge-card::before {
            content: '';
            position: absolute;
            bottom: 0; right: 0; left: 0;
            height: 3px;
            background: var(--primary);
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: right;
            border-radius: 2px;
        }
        .mode-badge-card:hover::before {
            transform: scaleX(1);
        }
        .mode-badge-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
            border-color: rgba(var(--primary-rgb), 0.25);
        }
        .mode-badge-card i {
            font-size: 1.8rem;
            margin-top: 2px;
            flex-shrink: 0;
            transition: transform 0.3s ease;
        }
        .mode-badge-card:hover i {
            transform: scale(1.15) rotate(5deg);
        }
        .mode-badge-card h5 {
            font-size: 1rem;
            font-weight: 800;
            color: var(--dark);
            margin: 0 0 4px 0;
        }
        .mode-badge-card p {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.45;
        }

        /* Upgraded Visual Mockups Container */
        .hero-visual-wrapper {
            position: relative;
            width: 100%;
            height: 440px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: auto;
        }

        /* Glassmorphism Panel */
        .dashboard-main-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            width: 320px;
            padding: 24px;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.06), 
                        inset 0 1px 0 rgba(255, 255, 255, 0.8);
            position: relative;
            z-index: 3;
            transition: all 0.3s ease;
        }
        .dashboard-main-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 25px 50px rgba(15, 23, 42, 0.1);
        }
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            border-bottom: 1px dashed var(--border);
            padding-bottom: 15px;
        }
        .dashboard-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .dashboard-avatar {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary-light), #ccfbf1);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.05rem;
            border: 2px solid var(--white);
            box-shadow: var(--shadow-sm);
        }
        .dashboard-user-info h6 {
            font-size: 0.95rem;
            font-weight: 800;
            color: var(--dark);
            margin: 0;
        }
        .dashboard-user-info span {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
            animation: statusPulse 2s infinite;
        }
        @@keyframes statusPulse {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5); }
            70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        .vital-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .vital-item {
            background: var(--white);
            border: 1px solid rgba(226, 232, 240, 0.7);
            border-radius: 14px;
            padding: 12px 14px;
            transition: all 0.25s ease;
        }
        .vital-item:hover {
            border-color: rgba(16, 118, 110, 0.2);
            transform: translateY(-2px);
        }
        .vital-title {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .vital-value {
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--dark);
            line-height: 1.1;
        }
        .vital-value span {
            font-size: 0.72rem;
            font-weight: 500;
            color: var(--text-muted);
            margin-right: 2px;
        }

        /* Floating Widgets */
        .floating-card {
            position: absolute;
            background: var(--white);
            border-radius: 18px;
            padding: 14px;
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(226, 232, 240, 0.8);
            z-index: 4;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .floating-card:hover {
            transform: scale(1.05) translateY(-5px) !important;
            box-shadow: 0 18px 32px rgba(15, 23, 42, 0.12);
        }
        .float-1 {
            top: 15%;
            left: -8%;
            width: 175px;
            animation: floatSlow 6s infinite ease-in-out;
        }
        .float-2 {
            bottom: 8%;
            right: -8%;
            width: 215px;
            animation: floatMedium 5.5s infinite ease-in-out;
            animation-delay: -1.5s;
        }
        .float-3 {
            bottom: 68%;
            right: -2%;
            animation: floatFast 5s infinite ease-in-out;
            animation-delay: -3s;
        }

        @@keyframes floatSlow {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-12px); }
        }
        @@keyframes floatMedium {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(12px); }
        }
        @@keyframes floatFast {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        /* Float 1 details: ECG Pulse Graph */
        .ecg-card {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .ecg-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .ecg-header span {
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .ecg-icon {
            color: var(--danger);
            animation: heartBeat 1.2s infinite;
        }
        @@keyframes heartBeat {
            0%, 100% { transform: scale(1); }
            25% { transform: scale(1.18); }
            40% { transform: scale(1.05); }
            55% { transform: scale(1.22); }
        }
        .ecg-value {
            font-size: 1.35rem;
            font-weight: 900;
            color: var(--dark);
        }
        .ecg-value span {
            font-size: 0.72rem;
            font-weight: 600;
        }
        .ecg-svg-container {
            width: 100%;
            height: 32px;
            margin-top: 5px;
            overflow: hidden;
        }
        .ecg-path {
            stroke-dasharray: 400;
            stroke-dashoffset: 400;
            animation: drawLine 3.5s linear infinite;
        }
        @@keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }

        /* Float 2 details: Bot/Doctor Chat Bubble */
        .chat-bubble-widget {
            display: flex;
            gap: 8px;
        }
        .chat-bubble-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--secondary), var(--accent));
            color: var(--white);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem;
            flex-shrink: 0;
            box-shadow: 0 4px 8px rgba(2, 132, 199, 0.15);
        }
        .chat-bubble-content {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .chat-bubble-name {
            font-size: 0.72rem;
            font-weight: 800;
            color: var(--secondary);
        }
        .chat-bubble-text {
            font-size: 0.75rem;
            color: var(--dark-2);
            background: var(--secondary-light);
            border-radius: 12px 0 12px 12px;
            padding: 6px 10px;
            line-height: 1.4;
            border: 1px solid rgba(2, 132, 199, 0.05);
        }

        /* Float 3 details: Active Crisis Monitor badge */
        .crisis-badge-widget {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #fff8f6;
            border: 1px solid rgba(234, 88, 12, 0.12);
            padding: 8px 14px;
            border-radius: 50px;
        }
        .crisis-badge-widget i {
            color: var(--crisis);
            font-size: 1rem;
            animation: crisisRotate 2.5s infinite ease-in-out;
        }
        @@keyframes crisisRotate {
            0%, 100% { transform: rotate(0); }
            50% { transform: rotate(15deg); }
        }
        .crisis-badge-widget div h7 {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--crisis);
            display: block;
            margin: 0;
            line-height: 1.1;
        }
        .crisis-badge-widget div span {
            font-size: 0.65rem;
            color: var(--text-muted);
            display: block;
        }

        /* Split Cards Layout */
        .hero-cards-row {
            display: flex;
            gap: 2rem;
            margin-top: 2rem;
        }
        .hero-promo-card {
            flex: 1;
            border-radius: 24px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 290px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            background-size: 200% 200%;
            animation: gradientShift 6s ease infinite alternate;
            box-shadow: var(--shadow-lg);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .hero-promo-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-xl);
        }
        .hero-promo-card-1 {
            background-image: linear-gradient(135deg, var(--primary) 0%, #0d5c56 60%, #115e59 100%);
        }
        .hero-promo-card-2 {
            background-image: linear-gradient(135deg, var(--secondary) 0%, #0369a1 60%, #075985 100%);
        }
        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }
        .hero-promo-icon {
            position: absolute;
            left: -10px;
            bottom: -20px;
            font-size: 10rem;
            opacity: 0.12;
            transform: rotate(-15deg);
        }
        .hero-promo-badge {
            align-self: flex-start;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(8px);
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 0.82rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.25);
        }
        .hero-promo-title {
            font-size: 2.2rem;
            font-weight: 900;
            margin-bottom: 0.8rem;
            letter-spacing: -0.5px;
