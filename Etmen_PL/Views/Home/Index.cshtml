                        new { Icon="🧬", Title="محرك تقييم ذكي", Desc="حساب مستوى الخطر لكل مريض بناءً على أعراض مخصصة لكل نوع أزمة مع أوزان قابلة للضبط." },
                        new { Icon="🗺️", Title="خريطة التفشي التفاعلية", Desc="رسم مناطق التفشي على الخريطة مع تحديد نطاق الخطر والمستوى لكل منطقة جغرافياً." },
                        new { Icon="⚡", Title="تنبيهات فورية", Desc="إرسال تنبيهات فورية للمرضى في المناطق عالية الخطر مع توصيات طبية مخصصة." },
                        new { Icon="📊", Title="إحصائيات لحظية", Desc="لوحة بيانات تعرض توزيع مستويات الخطر ومؤشرات الأزمة بشكل لحظي للمسؤولين." },
                    };
                }
                @foreach (var (c, i) in crisisCards.Select((x,i)=>(x,i)))
                {
                    <div class="col-md-6 col-lg-3" data-animate data-animate-delay="@(i+1)">
                        <div class="crisis-card">
                            <div class="crisis-card-icon">@c.Icon</div>
