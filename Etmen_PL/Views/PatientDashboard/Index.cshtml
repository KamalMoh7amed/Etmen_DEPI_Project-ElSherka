@model Etmen_PL.Models.ViewModels.Patient.PatientDashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم الصحية";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";

    var riskLevel = Model.LatestRiskAssessment?.RiskLevel.ToString();
    var riskText = riskLevel switch
    {
        "Safe" or "Green" or "Low" => "منخفض",
        "Medium" or "Yellow" => "متوسط",
        "High" or "Orange" => "مرتفع",
        "Emergency" or "Red" => "طارئ",
        _ => "غير مقيم"
    };
    var riskClass = riskLevel switch
    {
        "Safe" or "Green" or "Low" => "status-good",
        "Medium" or "Yellow" => "status-watch",
        "High" or "Orange" => "status-danger",
        "Emergency" or "Red" => "status-danger",
        _ => "status-neutral"
    };
    var bmiCategory = Model.LatestBmiCategory switch
    {
        "Underweight" => "أقل من الطبيعي",
        "Normal" => "طبيعي",
        "Overweight" => "زيادة وزن",
        "Obese" => "سمنة",
        _ => "غير متاح"
    };
}

<style>
    .patient-dashboard {
        display: grid;
        gap: 1.35rem;
    }

    .patient-hero {
        min-height: 270px;
        border-radius: 18px;
        padding: 2rem;
        color: #fff;
        background:
            linear-gradient(135deg, rgba(10, 28, 44, .96), rgba(14, 96, 121, .88)),
            url("https://images.unsplash.com/photo-1584982751601-97dcc096659c?auto=format&fit=crop&w=1600&q=80") center/cover;
        position: relative;
        overflow: hidden;
        box-shadow: 0 22px 52px rgba(10, 28, 44, .18);
        display: grid;
        align-items: end;
    }

    .patient-hero::before {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 88px;
        background: linear-gradient(90deg, transparent, rgba(0, 201, 167, .2), transparent);
        animation: scanLine 4.5s ease-in-out infinite;
    }

    .patient-hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.25rem;
        align-items: end;
    }

    .hero-kicker {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 999px;
        padding: .45rem .85rem;
        font-weight: 800;
        margin-bottom: .85rem;
        backdrop-filter: blur(10px);
    }

    .hero-title {
        font-weight: 900;
        margin-bottom: .55rem;
    }

    .hero-copy {
        color: rgba(255,255,255,.78);
        font-size: 1.05rem;
        max-width: 740px;
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .metric-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.1rem;
        min-height: 150px;
        position: relative;
        overflow: hidden;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        box-shadow: 0 14px 32px rgba(15, 36, 55, .045);
    }

    .metric-card:hover {
        transform: translateY(-4px);
        border-color: rgba(21, 96, 130, .35);
        box-shadow: 0 18px 38px rgba(15, 36, 55, .09);
    }

    .metric-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        margin-bottom: .85rem;
        font-size: 1.1rem;
    }

    .metric-label {
        color: var(--text-muted);
        font-size: .84rem;
        font-weight: 800;
        margin-bottom: .25rem;
    }

    .metric-value {
        color: #102a43;
        font-size: 1.65rem;
        line-height: 1.2;
        font-weight: 900;
        margin: 0;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        border-radius: 999px;
        padding: .35rem .7rem;
        font-size: .8rem;
        font-weight: 900;
        margin-top: .7rem;
    }

    .status-good { background: #e8f8f0; color: #1e6b45; }
    .status-watch { background: #fff6df; color: #8a5b00; }
    .status-danger { background: #fdeceb; color: #a93226; }
    .status-neutral { background: #edf2f7; color: #52616f; }

    .care-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr);
        gap: 1rem;
    }

    .dashboard-panel {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.25rem;
        box-shadow: 0 14px 32px rgba(15, 36, 55, .045);
    }

    .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .panel-title {
        font-weight: 900;
        color: #102a43;
        margin: 0;
    }

    .service-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .85rem;
    }

    .service-card {
        text-decoration: none;
        color: #102a43;
        background: #f8fbfd;
        border: 1px solid #e3ebf2;
        border-radius: 14px;
        padding: 1rem;
        min-height: 132px;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        transition: transform .22s ease, background .22s ease, border-color .22s ease;
    }

    .service-card:hover {
        color: #0d4c8a;
        background: #fff;
        transform: translateY(-3px);
        border-color: rgba(13, 76, 138, .32);
    }

    .service-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: #eaf6ff;
        color: #156082;
        font-size: 1.05rem;
    }

    .timeline-list {
        display: grid;
        gap: .75rem;
    }

    .timeline-item {
        border: 1px solid #e3ebf2;
        border-radius: 14px;
        padding: .9rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        transition: background .2s ease, transform .2s ease;
    }

    .timeline-item:hover {
        background: #f8fbfd;
        transform: translateX(-2px);
    }

    .empty-state {
        text-align: center;
        border: 1px dashed rgba(21, 96, 130, .3);
        border-radius: 14px;
        padding: 2rem 1rem;
        color: var(--text-muted);
    }

    .vital-strip {
        display: grid;
        gap: .7rem;
    }

    .vital-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: .72rem .85rem;
        background: #f8fbfd;
        border: 1px solid #e3ebf2;
        border-radius: 12px;
    }

    @@keyframes scanLine {
        0%, 100% { transform: translateX(-18%); opacity: .25; }
        50% { transform: translateX(18%); opacity: .55; }
    }

    @@media (max-width: 1100px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .care-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .patient-hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-actions {
            justify-content: flex-start;
        }

        .service-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .patient-hero {
            padding: 1.35rem;
        }

        .dashboard-grid,
        .service-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="patient-dashboard">
    <section class="patient-hero animate__animated animate__fadeIn">
        <div class="patient-hero-grid">
            <div>
                <span class="hero-kicker">
                    <i class="fas fa-shield-heart"></i>
                    ملفك الطبي نشط
                </span>
                <h1 class="hero-title">أهلًا @Model.PatientName</h1>
                <p class="hero-copy">لوحة متابعة صحية تجمع القياسات، التنبيهات، تقييم المخاطر، والمواعيد في تجربة واحدة واضحة وسريعة.</p>
            </div>
            <div class="hero-actions">
                <a asp-controller="MedicalRecords" asp-action="Create" class="btn btn-light fw-bold px-4">
                    <i class="fas fa-plus-circle"></i>
                    تسجيل قياس
                </a>
                <a asp-controller="Emergency" asp-action="Index" class="btn btn-danger fw-bold px-4">
                    <i class="fas fa-ambulance"></i>
                    طوارئ
                </a>
            </div>
        </div>
    </section>

    <section class="dashboard-grid animate__animated animate__fadeInUp">
        <article class="metric-card">
            <div class="metric-icon" style="background:#eaf6ff;color:#156082;"><i class="fas fa-weight-scale"></i></div>
            <div class="metric-label">مؤشر كتلة الجسم</div>
            <p class="metric-value">@(Model.LatestBmi.HasValue ? Model.LatestBmi.Value.ToString("0.0") : "--")</p>
            <span class="status-pill @(Model.LatestBmiCategory == "Normal" ? "status-good" : "status-neutral")">@bmiCategory</span>
        </article>

        <article class="metric-card">
            <div class="metric-icon" style="background:#fff6df;color:#b7791f;"><i class="fas fa-notes-medical"></i></div>
            <div class="metric-label">آخر تقييم مخاطر</div>
            <p class="metric-value">@riskText</p>
            <span class="status-pill @riskClass">
                <i class="fas fa-circle" style="font-size:.45rem;"></i>
                @(Model.LatestRiskAssessment == null ? "ابدأ أول تقييم" : Model.LatestRiskAssessment.AssessmentDate.ToString("yyyy/MM/dd"))
            </span>
        </article>

        <article class="metric-card">
            <div class="metric-icon" style="background:#fdeceb;color:#c0392b;"><i class="fas fa-bell"></i></div>
            <div class="metric-label">تنبيهات غير مقروءة</div>
            <p class="metric-value">@Model.UnreadAlertsCount</p>
            <span class="status-pill @(Model.UnreadAlertsCount > 0 ? "status-danger" : "status-good")">
                @(Model.UnreadAlertsCount > 0 ? "تحتاج مراجعة" : "لا توجد تنبيهات عاجلة")
            </span>
        </article>

        <article class="metric-card">
            <div class="metric-icon" style="background:#e8f8f0;color:#1e6b45;"><i class="fas fa-clipboard-list"></i></div>
            <div class="metric-label">سجلات القياسات</div>
            <p class="metric-value">@Model.MedicalRecordsCount</p>
            <span class="status-pill status-neutral">
                آخر تحديث: @(Model.LatestMedicalRecord?.RecordDate.ToString("yyyy/MM/dd") ?? "غير متاح")
            </span>
        </article>
    </section>

    <section class="care-layout animate__animated animate__fadeInUp">
        <div class="dashboard-panel">
            <div class="panel-head">
                <h2 class="panel-title">خدماتك الطبية</h2>
                <a asp-controller="PatientProfile" asp-action="Index" class="btn btn-sm btn-outline-primary fw-bold">تحديث الملف</a>
            </div>

            <div class="service-grid">
                <a asp-controller="MedicalRecords" asp-action="Create" class="service-card">
                    <span class="service-icon"><i class="fas fa-heart-pulse"></i></span>
                    <strong>تسجيل قياس يومي</strong>
                    <small class="text-muted">ضغط، نبض، سكر، حرارة، وأكسجين.</small>
                </a>
                <a asp-controller="RiskAssessment" asp-action="Index" class="service-card">
                    <span class="service-icon"><i class="fas fa-stethoscope"></i></span>
                    <strong>تقييم المخاطر</strong>
                    <small class="text-muted">تحليل سريع للحالة وإرشادات متابعة.</small>
                </a>
                <a asp-controller="LabResults" asp-action="Index" class="service-card">
                    <span class="service-icon"><i class="fas fa-vial"></i></span>
                    <strong>تحاليل OCR</strong>
                    <small class="text-muted">رفع نتائج التحاليل واستخراج البيانات.</small>
                </a>
                <a asp-controller="NearbyProviders" asp-action="Index" class="service-card">
                    <span class="service-icon"><i class="fas fa-location-dot"></i></span>
                    <strong>مقدمو الرعاية</strong>
                    <small class="text-muted">بحث وحجز مواعيد قريبة.</small>
                </a>
                <a asp-controller="PatientAppointments" asp-action="Index" class="service-card">
                    <span class="service-icon"><i class="far fa-calendar-check"></i></span>
                    <strong>مواعيدي</strong>
                    <small class="text-muted">تذاكر الحجز والتفاصيل والإلغاء.</small>
                </a>
                <a asp-controller="FamilyLinking" asp-action="Index" class="service-card">
                    <span class="service-icon"><i class="fas fa-users"></i></span>
                    <strong>الارتباط العائلي</strong>
                    <small class="text-muted">إشراك العائلة في المتابعة عند الحاجة.</small>
                </a>
            </div>
        </div>

        <aside class="dashboard-panel">
            <div class="panel-head">
                <h2 class="panel-title">آخر قياس طبي</h2>
                <a asp-controller="MedicalRecords" asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">السجل</a>
            </div>

            @if (Model.LatestMedicalRecord != null)
            {
                <div class="vital-strip">
                    <div class="vital-row"><span>ضغط الدم</span><strong>@(Model.LatestMedicalRecord.SystolicBP?.ToString("0") ?? "--")/@(Model.LatestMedicalRecord.DiastolicBP?.ToString("0") ?? "--")</strong></div>
                    <div class="vital-row"><span>النبض</span><strong>@(Model.LatestMedicalRecord.HeartRate?.ToString("0") ?? "--")</strong></div>
                    <div class="vital-row"><span>سكر الدم</span><strong>@(Model.LatestMedicalRecord.BloodSugar?.ToString("0") ?? "--")</strong></div>
                    <div class="vital-row"><span>الحرارة</span><strong>@(Model.LatestMedicalRecord.Temperature?.ToString("0.0") ?? "--")</strong></div>
                    <div class="vital-row"><span>الأكسجين</span><strong>@(Model.LatestMedicalRecord.OxygenSaturation?.ToString("0") ?? "--")%</strong></div>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-clipboard-medical text-primary mb-3" style="font-size:2.5rem;"></i>
                    <strong class="d-block mb-2">لا يوجد قياس محفوظ</strong>
                    <p class="mb-3">سجل أول قياس حتى تظهر مؤشراتك هنا.</p>
                    <a asp-controller="MedicalRecords" asp-action="Create" class="btn btn-primary btn-sm fw-bold">تسجيل قياس</a>
                </div>
            }
        </aside>
    </section>

    <section class="care-layout animate__animated animate__fadeInUp">
        <div class="dashboard-panel">
            <div class="panel-head">
                <h2 class="panel-title">المواعيد القادمة</h2>
                <span class="badge bg-primary">@Model.UpcomingAppointmentsCount موعد</span>
            </div>

            @if (Model.UpcomingAppointments.Any())
            {
                <div class="timeline-list">
                    @foreach (var apt in Model.UpcomingAppointments)
                    {
                        <div class="timeline-item">
                            <div>
                                <strong>د. @apt.DoctorName</strong>
                                <span class="d-block text-muted small">@apt.Date.ToString("yyyy/MM/dd - hh:mm tt")</span>
                            </div>
                            <span class="badge @(apt.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark")">@apt.Status</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="far fa-calendar-plus text-primary mb-3" style="font-size:2.4rem;"></i>
                    <strong class="d-block mb-2">لا توجد مواعيد قادمة</strong>
                    <a asp-controller="NearbyProviders" asp-action="Index" class="btn btn-outline-primary btn-sm fw-bold">حجز موعد</a>
                </div>
            }
        </div>

        <aside class="dashboard-panel">
            <div class="panel-head">
                <h2 class="panel-title">آخر التنبيهات</h2>
                <a asp-controller="Alerts" asp-action="Index" class="btn btn-sm btn-outline-secondary fw-bold">عرض الكل</a>
            </div>

            @if (Model.RecentAlerts.Any())
            {
                <div class="timeline-list">
                    @foreach (var alert in Model.RecentAlerts)
                    {
                        <div class="timeline-item">
                            <div>
                                <strong class="@(alert.IsRead ? "" : "text-danger")">@alert.Title</strong>
                                <span class="d-block text-muted small">@alert.CreatedAt.ToString("yyyy/MM/dd - hh:mm tt")</span>
                            </div>
                            <span class="badge @(alert.IsRead ? "bg-light text-muted" : "bg-danger")">@(alert.IsRead ? "مقروء" : "جديد")</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="far fa-bell-slash text-success mb-3" style="font-size:2.4rem;"></i>
                    <strong class="d-block">لا توجد تنبيهات حاليًا</strong>
                    <span class="text-muted small">سنظهر أي توصية طبية هنا فور توفرها.</span>
                </div>
            }
        </aside>
    </section>
</div>
