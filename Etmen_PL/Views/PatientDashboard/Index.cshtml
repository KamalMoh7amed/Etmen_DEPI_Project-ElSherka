</div>

@section Scripts {
    <!-- SignalR Connection for Live Emergency Updates -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const patientUserId = "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";
            if (!patientUserId || patientUserId === "") return;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/emergency")
                .withAutomaticReconnect()
                .build();

            connection.start().then(function () {
                console.log("Connected to EmergencyHub from patient dashboard.");
                connection.invoke("JoinPatientEmergencyGroup", patientUserId).catch(err => console.error(err));
            }).catch(err => console.error(err.toString()));

            connection.on("EmergencyUpdated", function (data) {
                console.log("Patient received emergency update:", data);
                
                // If active emergency card is not on the page, reload to show it
                const emergencyCard = document.getElementById("activeEmergencyCard");
                if (!emergencyCard) {
                    location.reload();
                    return;
                }

                // If status is Completed or Cancelled, reload to clear the card
                if (data.status === "Completed" || data.status === "Cancelled") {
                    location.reload();
                    return;
                }

                // Update Stepper
                let step = 1;
                let statusText = "في انتظار الاستجابة";
                if (data.doctorUserId && data.doctorUserId !== "") {
                    step = 2;
                    statusText = "مقبولة وجاري المتابعة";
                }
                if (data.hospitalName && data.hospitalName !== "جاري تحديد مستشفى..." && data.hospitalName !== "قيد المتابعة والبحث") {
                    step = 3;
                    statusText = "مقبولة وجاري المتابعة";
                }

                // Update progress line width
                const progressLine = document.getElementById("stepperProgressLine");
                if (progressLine) {
                    const widthPercent = step === 1 ? 0 : (step === 2 ? 33 : (step === 3 ? 66 : 100));
                    progressLine.style.width = widthPercent + "%";
                }

                // Update dots styling
                for (let i = 1; i <= 4; i++) {
                    const dot = document.getElementById("step" + i + "-dot");
                    if (dot) {
                        if (i <= step) {
                            dot.className = "rounded-circle d-flex align-items-center justify-content-center border border-2 border-danger text-white bg-danger stepper-dot";
                        } else {
                            dot.className = "rounded-circle d-flex align-items-center justify-content-center border border-2 border-secondary text-white-50 stepper-dot";
                        }
                    }
                }

                // Update Badge text
                const statusBadge = document.getElementById("emergencyStatusBadge");
                if (statusBadge) {
                    statusBadge.innerText = statusText;
                }

                // Update Doctor name & chat link
                const doctorContainer = document.getElementById("emergencyDoctorContainer");
                if (doctorContainer) {
                    if (data.doctorName && data.doctorName !== "") {
                        doctorContainer.innerHTML = `
                            <div class="fw-bold text-dark" style="font-size:1.1rem;"><i class="fas fa-user-md text-primary me-1"></i> د. ` + data.doctorName + `</div>
                        `;
                        
                        // Show/update chat button
                        let chatBtnContainer = document.getElementById("emergencyChatBtnContainer");
                        if (chatBtnContainer) {
                            chatBtnContainer.innerHTML = `
                                <a href="/Chat/Thread?otherUserId=` + data.doctorUserId + `" class="btn btn-sm btn-danger fw-bold d-inline-flex align-items-center gap-2 mt-1 px-3 py-2" style="border-radius:8px; background-color:#ef4444; border-color:#ef4444; color:#fff;">
                                    <i class="fas fa-comments"></i> محادثة الطبيب المتولي لحالتك
                                </a>
                            `;
                        }
                    } else {
                        doctorContainer.innerHTML = `
                            <div class="fw-bold text-warning" style="font-size:1.1rem;"><i class="fas fa-spinner fa-spin me-1"></i> في انتظار تعيين طبيب مسؤول...</div>
                        `;
                    }
                }

                // Update Hospital Name
                const hospitalContainer = document.getElementById("emergencyHospitalName");
                if (hospitalContainer) {
                    hospitalContainer.innerText = data.hospitalName || "جاري تحديد مستشفى...";
                }

                // Update recommendations
                const recsContainer = document.getElementById("emergencyRecommendationsContainer");
                if (recsContainer) {
                    let recsHtml = "";
                    let hasRecs = false;

                    if (data.patientRecommendations && data.patientRecommendations !== "") {
                        recsHtml += `
                            <div class="p-2 rounded-3 bg-white" style="border-right: 4px solid #00c9a7; font-size: 0.85rem; border-left: none; margin-bottom: 8px;">
                                <strong class="text-secondary d-block mb-1">تعليمات للمريض:</strong>
                                <span class="text-dark">` + data.patientRecommendations + `</span>
                            </div>
                        `;
                        hasRecs = true;
                    }
                    if (data.familyRecommendations && data.familyRecommendations !== "") {
                        recsHtml += `
                            <div class="p-2 rounded-3 bg-white" style="border-right: 4px solid #f29c12; font-size: 0.85rem; border-left: none; margin-bottom: 8px;">
                                <strong class="text-secondary d-block mb-1">تعليمات للعائلة والمرافقين:</strong>
                                <span class="text-dark">` + data.familyRecommendations + `</span>
                            </div>
                        `;
                        hasRecs = true;
                    }
                    if (data.prescribedMedications && data.prescribedMedications !== "") {
                        recsHtml += `
                            <div class="p-2 rounded-3 bg-white" style="border-right: 4px solid #ef4444; font-size: 0.85rem; border-left: none; margin-bottom: 8px;">
                                <strong class="text-secondary d-block mb-1">العلاجات والأدوية الطارئة الموصوفة:</strong>
                                <span class="text-dark">` + data.prescribedMedications + `</span>
                            </div>
                        `;
                        hasRecs = true;
                    }

                    if (hasRecs) {
                        recsContainer.innerHTML = recsHtml;
                    } else {
                        recsContainer.innerHTML = `
                            <div class="text-muted text-center py-4 small">
                                <i class="fas fa-info-circle mb-1" style="font-size:1.5rem; display:block;"></i>
                                لا توجد توصيات مكتوبة حتى الآن. سيقوم الطبيب بإرسال الإرشادات فور دراسة حالتك.
                            </div>
                        `;
                    }
                }
            });
        });
    </script>
}