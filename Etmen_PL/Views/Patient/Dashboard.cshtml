@model Etmen_BLL.DTOs.Patient.DashboardDto
@{
    ViewData["Title"] = "لوحة التحكم — إطمن";
    Layout = null;
    var risk = Model?.LatestRiskAssessment;
    string riskColor = risk?.RiskColor ?? "#27AE60";
    string riskLabel = risk?.RiskLabel ?? "لا يوجد تقييم";
    double riskScore = (double)(risk?.RiskScore ?? 0);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
:root{
  --primary:#1A6FBF;--primary-dark:#0D4C8A;--primary-light:#E8F4FD;
  --accent:#00C9A7;--success:#27AE60;--danger:#E74C3C;--warning:#F39C12;
  --dark:#0F1923;--dark-2:#1B2A38;--dark-3:#243342;
  --text:#2C3E50;--text-muted:#7F8C8D;--border:#DDE3EC;--white:#FFFFFF;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Tajawal',sans-serif;background:#F0F4F9;min-height:100vh;display:flex;}

/* ── Sidebar ── */
.sidebar{width:260px;min-height:100vh;background:var(--dark);display:flex;flex-direction:column;position:fixed;right:0;top:0;z-index:100;transition:.3s;}
.sidebar-logo{padding:28px 24px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:12px;}
.sidebar-logo .logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.1rem;}
.sidebar-logo .logo-text{color:#fff;font-weight:800;font-size:1.2rem;}
.sidebar-logo .logo-text span{color:var(--accent);}
.nav-section{padding:20px 16px 8px;color:rgba(255,255,255,.35);font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:12px;padding:12px 20px;color:rgba(255,255,255,.65);text-decoration:none;border-radius:10px;margin:2px 10px;transition:.2s;font-size:.95rem;}
.nav-item:hover,.nav-item.active{background:rgba(26,111,191,.25);color:#fff;}
.nav-item.active{border-right:3px solid var(--primary);}
.nav-item i{width:20px;text-align:center;font-size:1rem;}
.sidebar-footer{margin-top:auto;padding:20px;border-top:1px solid rgba(255,255,255,.08);}
.logout-btn{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.5);text-decoration:none;font-size:.9rem;padding:10px 12px;border-radius:8px;transition:.2s;}
.logout-btn:hover{background:rgba(231,76,60,.15);color:#E74C3C;}

/* ── Main ── */
.main{margin-right:260px;flex:1;padding:0;min-height:100vh;display:flex;flex-direction:column;}
.topbar{background:#fff;padding:16px 32px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;}
.topbar-greeting{font-size:1.05rem;font-weight:600;color:var(--text);}
.topbar-greeting span{color:var(--primary);}
.topbar-actions{display:flex;align-items:center;gap:16px;}
.notif-btn{position:relative;width:40px;height:40px;border-radius:10px;border:1px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;color:var(--text-muted);cursor:pointer;text-decoration:none;transition:.2s;}
.notif-btn:hover{border-color:var(--primary);color:var(--primary);}
.notif-badge{position:absolute;top:-4px;right:-4px;background:var(--danger);color:#fff;font-size:.65rem;font-weight:700;border-radius:50%;width:18px;height:18px;display:flex;align-items:center;justify-content:center;}
.avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1rem;}
.page-body{padding:32px;flex:1;}
.page-header{margin-bottom:28px;}
.page-header h1{font-size:1.6rem;font-weight:800;color:var(--dark);margin-bottom:4px;}
.page-header p{color:var(--text-muted);font-size:.95rem;}

/* ── Stat Cards ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:28px;}
.stat-card{background:#fff;border-radius:16px;padding:24px;border:1px solid var(--border);position:relative;overflow:hidden;transition:.2s;}
.stat-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.08);}
.stat-card::before{content:'';position:absolute;top:0;right:0;width:4px;height:100%;background:var(--card-color,var(--primary));}
.stat-card .icon{width:48px;height:48px;border-radius:12px;background:var(--card-bg,rgba(26,111,191,.1));display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--card-color,var(--primary));margin-bottom:16px;}
.stat-card .value{font-size:1.8rem;font-weight:800;color:var(--dark);line-height:1;}
.stat-card .label{color:var(--text-muted);font-size:.85rem;margin-top:6px;}
.stat-card .sub{font-size:.8rem;color:var(--text-muted);margin-top:8px;}

/* ── Risk Gauge ── */
.risk-card{background:#fff;border-radius:16px;padding:28px;border:1px solid var(--border);margin-bottom:28px;}
.risk-card h3{font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
.risk-gauge-wrap{display:flex;align-items:center;gap:32px;}
.gauge-circle{position:relative;width:140px;height:140px;}
.gauge-circle svg{transform:rotate(-90deg);}
.gauge-bg{fill:none;stroke:#E8F0FE;stroke-width:12;}
.gauge-fill{fill:none;stroke-width:12;stroke-linecap:round;transition:stroke-dashoffset 1s ease;}
.gauge-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.gauge-score{font-size:1.6rem;font-weight:800;color:var(--dark);}
.gauge-label{font-size:.7rem;color:var(--text-muted);margin-top:2px;}
.risk-details{flex:1;}
.risk-level-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:20px;font-weight:700;font-size:.9rem;margin-bottom:16px;}
.recommendations{list-style:none;display:flex;flex-direction:column;gap:8px;}
.recommendations li{display:flex;align-items:flex-start;gap:8px;font-size:.88rem;color:var(--text);}
.recommendations li::before{content:'✓';color:var(--success);font-weight:700;margin-top:1px;flex-shrink:0;}

/* ── Tables ── */
.card-section{background:#fff;border-radius:16px;border:1px solid var(--border);overflow:hidden;margin-bottom:24px;}
.card-section-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-section-header h3{font-size:1rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.card-section-header a{font-size:.85rem;color:var(--primary);text-decoration:none;font-weight:600;}
.data-table{width:100%;border-collapse:collapse;}
.data-table th{background:#F8FAFB;padding:12px 20px;font-size:.8rem;color:var(--text-muted);font-weight:700;text-align:right;border-bottom:1px solid var(--border);}
.data-table td{padding:14px 20px;border-bottom:1px solid rgba(0,0,0,.04);font-size:.9rem;color:var(--text);}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:#F8FAFB;}
.badge-status{padding:4px 12px;border-radius:20px;font-size:.78rem;font-weight:700;}
.badge-upcoming{background:#E8F4FD;color:var(--primary);}
.badge-done{background:#E8F8F0;color:var(--success);}
.badge-cancelled{background:#FDECEA;color:var(--danger);}
.empty-state{padding:40px;text-align:center;color:var(--text-muted);}
.empty-state i{font-size:2.5rem;margin-bottom:12px;opacity:.4;}
.empty-state p{font-size:.9rem;}

/* ── Alert Items ── */
.alert-item{display:flex;align-items:flex-start;gap:14px;padding:16px 24px;border-bottom:1px solid rgba(0,0,0,.04);}
.alert-item:last-child{border-bottom:none;}
.alert-item.unread{background:#FFFBF0;}
.alert-dot{width:10px;height:10px;border-radius:50%;background:var(--warning);margin-top:5px;flex-shrink:0;}
.alert-dot.read{background:var(--border);}
.alert-item-body .title{font-weight:700;font-size:.9rem;color:var(--text);}
.alert-item-body .msg{font-size:.83rem;color:var(--text-muted);margin-top:2px;}
.alert-item-body .time{font-size:.75rem;color:var(--text-muted);margin-top:4px;}

/* ── Emergency Button ── */
.emergency-banner{background:linear-gradient(135deg,#E74C3C,#C0392B);border-radius:16px;padding:24px 28px;display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;color:#fff;}
.emergency-banner h3{font-size:1.05rem;font-weight:700;margin-bottom:4px;}
.emergency-banner p{font-size:.85rem;opacity:.85;}
.btn-emergency{background:#fff;color:#E74C3C;border:none;padding:10px 22px;border-radius:10px;font-family:'Tajawal',sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;display:flex;align-items:center;gap:8px;transition:.2s;white-space:nowrap;}
.btn-emergency:hover{background:#FDECEA;}

/* ── Two column grid ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:24px;}

/* ── Toast ── */
.toast-wrap{position:fixed;bottom:24px;left:24px;z-index:9999;display:flex;flex-direction:column;gap:10px;}
.toast-msg{padding:14px 20px;border-radius:12px;font-size:.9rem;font-weight:600;color:#fff;display:flex;align-items:center;gap:10px;animation:slideIn .3s ease;box-shadow:0 4px 16px rgba(0,0,0,.15);}
.toast-success{background:var(--success);}
.toast-error{background:var(--danger);}
@@keyframes slideIn{from{transform:translateX(-30px);opacity:0;}to{transform:translateX(0);opacity:1;}}

@@media(max-width:1100px){.stats-grid{grid-template-columns:repeat(2,1fr);}}.
@@media(max-width:768px){.sidebar{transform:translateX(260px);}.main{margin-right:0;}.two-col{grid-template-columns:1fr;}}
</style>
</head>
<body>

<!-- ── Sidebar ── -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon"><i class="fas fa-heartbeat"></i></div>
    <div class="logo-text">إط<span>من</span></div>
  </div>

  <span class="nav-section">القائمة الرئيسية</span>
  <a href="/Patient/Dashboard" class="nav-item active"><i class="fas fa-th-large"></i>لوحة التحكم</a>
  <a href="/Patient/Profile"   class="nav-item"><i class="fas fa-user-circle"></i>الملف الشخصي</a>
  <a href="/Patient/RiskAssessment" class="nav-item"><i class="fas fa-shield-virus"></i>تقييم المخاطر</a>

  <span class="nav-section">الرعاية الصحية</span>
  <a href="/Patient/Appointments"  class="nav-item"><i class="fas fa-calendar-alt"></i>المواعيد</a>
  <a href="/Patient/MedicalRecords" class="nav-item"><i class="fas fa-notes-medical"></i>السجلات الطبية</a>
  <a href="/Patient/LabResults"    class="nav-item"><i class="fas fa-flask"></i>نتائج التحاليل</a>

  <span class="nav-section">أخرى</span>
  <a href="/Patient/Alerts"  class="nav-item"><i class="fas fa-bell"></i>التنبيهات</a>
  <a href="/Patient/Nearby"  class="nav-item"><i class="fas fa-map-marker-alt"></i>مقدمو خدمات قريبون</a>

  <div class="sidebar-footer">
    <form method="post" action="/Account/Logout">
      @Html.AntiForgeryToken()
      <button type="submit" class="logout-btn" style="background:none;border:none;width:100%;cursor:pointer;">
        <i class="fas fa-sign-out-alt"></i>تسجيل الخروج
      </button>
    </form>
  </div>
</aside>

<!-- ── Main ── -->
<div class="main">
  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar-greeting">
      مرحباً، <span>@(Model?.PatientName ?? User.Identity?.Name ?? "المريض")</span>
    </div>
    <div class="topbar-actions">
      <a href="/Patient/Alerts" class="notif-btn">
        <i class="fas fa-bell"></i>
        @if((Model?.UnreadAlertsCount ?? 0) > 0)
        {
          <span class="notif-badge">@Model!.UnreadAlertsCount</span>
        }
      </a>
      <div class="avatar">@(((Model?.PatientName ?? "م").Length > 0) ? (Model?.PatientName ?? "م")[0].ToString() : "م")</div>
    </div>
  </div>

  <!-- Body -->
  <div class="page-body">
    <div class="page-header">
      <h1>لوحة التحكم</h1>
      <p>نظرة عامة على حالتك الصحية</p>
    </div>

    <!-- Emergency Banner -->
    <div class="emergency-banner">
      <div>
        <h3><i class="fas fa-ambulance"></i> هل تعاني من حالة طوارئ؟</h3>
        <p>اضغط الزر لإرسال طلب طوارئ فوري إلى أقرب مركز طبي</p>
      </div>
      <form method="post" action="/Patient/Emergency">
        @Html.AntiForgeryToken()
        <input type="hidden" name="EmergencyType" value="General"/>
        <input type="hidden" name="Description" value="طلب طوارئ من التطبيق"/>
        <button type="submit" class="btn-emergency" onclick="return confirm('هل أنت متأكد من إرسال طلب طوارئ؟')">
          <i class="fas fa-phone-alt"></i>طلب طوارئ
        </button>
      </form>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card" style="--card-color:var(--primary);--card-bg:rgba(26,111,191,.1);">
        <div class="icon"><i class="fas fa-calendar-check"></i></div>
        <div class="value">@(Model?.UpcomingAppointmentsCount ?? 0)</div>
        <div class="label">مواعيد قادمة</div>
        <div class="sub"><a href="/Patient/Appointments" style="color:var(--primary);text-decoration:none;">عرض الكل ←</a></div>
      </div>
      <div class="stat-card" style="--card-color:var(--warning);--card-bg:rgba(243,156,18,.1);">
        <div class="icon"><i class="fas fa-bell"></i></div>
        <div class="value">@(Model?.UnreadAlertsCount ?? 0)</div>
        <div class="label">تنبيهات غير مقروءة</div>
        <div class="sub"><a href="/Patient/Alerts" style="color:var(--warning);text-decoration:none;">عرض التنبيهات ←</a></div>
      </div>
      @if(Model?.LatestBmi.HasValue == true)
      {
        <div class="stat-card" style="--card-color:var(--accent);--card-bg:rgba(0,201,167,.1);">
          <div class="icon"><i class="fas fa-weight"></i></div>
          <div class="value">@Model.LatestBmi!.Value.ToString("F1")</div>
          <div class="label">مؤشر كتلة الجسم (BMI)</div>
          <div class="sub">@Model.LatestBmiCategory</div>
        </div>
      }
      else
      {
        <div class="stat-card" style="--card-color:var(--accent);--card-bg:rgba(0,201,167,.1);">
          <div class="icon"><i class="fas fa-weight"></i></div>
          <div class="value">—</div>
          <div class="label">مؤشر كتلة الجسم (BMI)</div>
          <div class="sub"><a href="/Patient/Profile" style="color:var(--accent);text-decoration:none;">أضف بياناتك ←</a></div>
        </div>
      }
      <div class="stat-card" style="--card-color:var(--success);--card-bg:rgba(39,174,96,.1);">
        <div class="icon"><i class="fas fa-shield-alt"></i></div>
        <div class="value" style="color:@riskColor;">@riskLabel</div>
        <div class="label">مستوى الخطورة الحالي</div>
        <div class="sub"><a href="/Patient/RiskAssessment" style="color:var(--success);text-decoration:none;">إجراء تقييم جديد ←</a></div>
      </div>
    </div>

    <!-- Risk + Appointments -->
    <div class="two-col">
      <!-- Risk Gauge -->
      <div class="risk-card">
        <h3><i class="fas fa-shield-virus" style="color:var(--primary);"></i> آخر تقييم للمخاطر</h3>
        @if(risk != null)
        {
          var circ = 3.14159 * 2 * 54;
          var offset = circ - (riskScore / 100.0 * circ);
          <div class="risk-gauge-wrap">
            <div class="gauge-circle">
              <svg width="140" height="140" viewBox="0 0 140 140">
                <circle class="gauge-bg" cx="70" cy="70" r="54"/>
                <circle class="gauge-fill" cx="70" cy="70" r="54"
                        stroke="@riskColor"
                        stroke-dasharray="@circ.ToString("F1")"
                        stroke-dashoffset="@offset.ToString("F1")"/>
              </svg>
              <div class="gauge-text">
                <div class="gauge-score">@riskScore.ToString("F0")<small style="font-size:.8rem;">%</small></div>
                <div class="gauge-label">نسبة الخطورة</div>
              </div>
            </div>
            <div class="risk-details">
              <div class="risk-level-badge" style="background:@(riskColor)22;color:@riskColor;">
                <i class="fas fa-circle" style="font-size:.6rem;"></i> @riskLabel
              </div>
              @if(risk.Recommendations.Any())
              {
                <ul class="recommendations">
                  @foreach(var rec in risk.Recommendations.Take(3))
                  {
                    <li>@rec</li>
                  }
                </ul>
              }
            </div>
          </div>
        }
        else
        {
          <div class="empty-state">
            <i class="fas fa-shield-virus"></i>
            <p>لم تُجرِ تقييماً للمخاطر بعد</p>
            <a href="/Patient/RiskAssessment" style="color:var(--primary);font-weight:600;font-size:.9rem;">ابدأ التقييم الآن ←</a>
          </div>
        }
      </div>

      <!-- Upcoming Appointments -->
      <div class="card-section">
        <div class="card-section-header">
          <h3><i class="fas fa-calendar-alt" style="color:var(--primary);"></i>المواعيد القادمة</h3>
          <a href="/Patient/Appointments">عرض الكل</a>
        </div>
        @if(Model?.UpcomingAppointments.Any() == true)
        {
          <table class="data-table">
            <thead><tr><th>الطبيب</th><th>التاريخ</th><th>الحالة</th></tr></thead>
            <tbody>
            @foreach(var apt in Model.UpcomingAppointments.Take(4))
            {
              <tr>
                <td>@apt.DoctorName</td>
                <td>@apt.Date.ToString("dd/MM/yyyy hh:mm tt")</td>
                <td><span class="badge-status badge-upcoming">@apt.Status</span></td>
              </tr>
            }
            </tbody>
          </table>
        }
        else
        {
          <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <p>لا توجد مواعيد قادمة</p>
          </div>
        }
      </div>
    </div>

    <!-- Recent Alerts -->
    <div class="card-section">
      <div class="card-section-header">
        <h3><i class="fas fa-bell" style="color:var(--warning);"></i>آخر التنبيهات</h3>
        <a href="/Patient/Alerts">عرض الكل</a>
      </div>
      @if(Model?.RecentAlerts.Any() == true)
      {
        @foreach(var alert in Model.RecentAlerts.Take(5))
        {
          <div class="alert-item @(alert.IsRead ? "" : "unread")">
            <div class="alert-dot @(alert.IsRead ? "read" : "")"></div>
            <div class="alert-item-body">
              <div class="title">@alert.Title</div>
              <div class="time">@alert.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")</div>
            </div>
          </div>
        }
      }
      else
      {
        <div class="empty-state">
          <i class="fas fa-bell-slash"></i>
          <p>لا توجد تنبيهات</p>
        </div>
      }
    </div>
  </div><!-- /page-body -->
</div><!-- /main -->

<!-- Toast -->
@if(TempData["Success"] is string successMsg)
{
  <div class="toast-wrap" id="toastWrap">
    <div class="toast-msg toast-success"><i class="fas fa-check-circle"></i>@successMsg</div>
  </div>
}
@if(TempData["Error"] is string errorMsg)
{
  <div class="toast-wrap" id="toastWrap">
    <div class="toast-msg toast-error"><i class="fas fa-exclamation-circle"></i>@errorMsg</div>
  </div>
}

<script>
  setTimeout(()=>{const t=document.getElementById('toastWrap');if(t)t.style.opacity='0';},4000);
</script>
</body>
</html>
