@model Etmen_BLL.DTOs.Risk.RiskInputDto
@{
    ViewData["Title"] = "تقييم المخاطر — إطمن";
    Layout = null;
    var history = ViewBag.History as IEnumerable<Etmen_BLL.DTOs.Risk.RiskResultDto>
                  ?? Enumerable.Empty<Etmen_BLL.DTOs.Risk.RiskResultDto>();
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
:root{--primary:#1A6FBF;--primary-dark:#0D4C8A;--accent:#00C9A7;--success:#27AE60;--danger:#E74C3C;--warning:#F39C12;--dark:#0F1923;--text:#2C3E50;--text-muted:#7F8C8D;--border:#DDE3EC;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Tajawal',sans-serif;background:#F0F4F9;min-height:100vh;display:flex;}
.sidebar{width:260px;min-height:100vh;background:var(--dark);display:flex;flex-direction:column;position:fixed;right:0;top:0;z-index:100;}
.sidebar-logo{padding:28px 24px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:12px;}
.sidebar-logo .logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.1rem;}
.sidebar-logo .logo-text{color:#fff;font-weight:800;font-size:1.2rem;}.sidebar-logo .logo-text span{color:var(--accent);}
.nav-section{padding:20px 16px 8px;color:rgba(255,255,255,.35);font-size:.72rem;font-weight:700;letter-spacing:.08em;}
.nav-item{display:flex;align-items:center;gap:12px;padding:12px 20px;color:rgba(255,255,255,.65);text-decoration:none;border-radius:10px;margin:2px 10px;transition:.2s;font-size:.95rem;}
.nav-item:hover,.nav-item.active{background:rgba(26,111,191,.25);color:#fff;}.nav-item.active{border-right:3px solid var(--primary);}
.nav-item i{width:20px;text-align:center;}
.sidebar-footer{margin-top:auto;padding:20px;border-top:1px solid rgba(255,255,255,.08);}
.logout-btn{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.5);text-decoration:none;font-size:.9rem;padding:10px 12px;border-radius:8px;transition:.2s;background:none;border:none;width:100%;cursor:pointer;}
.logout-btn:hover{background:rgba(231,76,60,.15);color:#E74C3C;}
.main{margin-right:260px;flex:1;padding:32px;min-height:100vh;}
.page-header{margin-bottom:28px;}
.page-header h1{font-size:1.6rem;font-weight:800;color:var(--dark);margin-bottom:4px;}
.page-header p{color:var(--text-muted);font-size:.95rem;}
.layout{display:grid;grid-template-columns:1fr 380px;gap:24px;}
/* Form card */
.form-card{background:#fff;border-radius:16px;border:1px solid var(--border);overflow:hidden;}
.form-card-header{padding:20px 28px;border-bottom:1px solid var(--border);background:linear-gradient(135deg,rgba(26,111,191,.05),rgba(0,201,167,.03));display:flex;align-items:center;gap:12px;}
.form-card-header .icon{width:40px;height:40px;border-radius:12px;background:rgba(26,111,191,.1);display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:1.1rem;}
.form-card-header h3{font-size:1rem;font-weight:700;color:var(--text);}
.form-body{padding:28px;}
.vitals-section{margin-bottom:28px;}
.section-title{font-size:.88rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.vitals-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group label{font-size:.83rem;font-weight:600;color:var(--text);display:flex;align-items:center;gap:6px;}
.input-wrap{position:relative;}
.input-wrap i{position:absolute;right:13px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:.9rem;}
.form-control{width:100%;padding:11px 38px 11px 14px;border:1.5px solid var(--border);border-radius:10px;font-family:'Tajawal',sans-serif;font-size:.9rem;color:var(--text);background:#fff;outline:none;transition:.2s;}
.form-control:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(26,111,191,.1);}
.symptoms-input{padding:11px 14px;resize:none;}
.unit{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:.78rem;color:var(--text-muted);background:#F8FAFB;padding:2px 6px;border-radius:4px;}
.location-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;}
.btn-assess{width:100%;padding:14px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:12px;font-family:'Tajawal',sans-serif;font-size:1.05rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:.2s;margin-top:24px;}
.btn-assess:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(26,111,191,.4);}
.btn-assess.loading{opacity:.7;pointer-events:none;}
/* History sidebar */
.history-card{background:#fff;border-radius:16px;border:1px solid var(--border);overflow:hidden;}
.history-header{padding:16px 20px;border-bottom:1px solid var(--border);font-weight:700;font-size:.95rem;color:var(--text);display:flex;align-items:center;gap:8px;}
.history-list{max-height:600px;overflow-y:auto;}
.history-item{padding:16px 20px;border-bottom:1px solid rgba(0,0,0,.04);display:flex;align-items:center;gap:14px;}
.history-item:last-child{border-bottom:none;}
.risk-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;}
.history-item-body{flex:1;}
.history-item-label{font-weight:700;font-size:.88rem;}
.history-item-score{font-size:.8rem;color:var(--text-muted);}
.history-item-date{font-size:.75rem;color:var(--text-muted);margin-top:2px;}
.empty-history{padding:32px;text-align:center;color:var(--text-muted);font-size:.88rem;}
/* Validation */
.validation-msg{color:var(--danger);font-size:.8rem;margin-top:4px;}
.error-summary{background:#FDECEA;border:1px solid #F5B7B1;border-radius:12px;padding:14px 20px;color:var(--danger);margin-bottom:20px;}
</style>
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon"><i class="fas fa-heartbeat"></i></div>
    <div class="logo-text">إط<span>من</span></div>
  </div>
  <span class="nav-section">القائمة الرئيسية</span>
  <a href="/Patient/Dashboard"      class="nav-item"><i class="fas fa-th-large"></i>لوحة التحكم</a>
  <a href="/Patient/Profile"        class="nav-item"><i class="fas fa-user-circle"></i>الملف الشخصي</a>
  <a href="/Patient/RiskAssessment" class="nav-item active"><i class="fas fa-shield-virus"></i>تقييم المخاطر</a>
  <span class="nav-section">الرعاية الصحية</span>
  <a href="/Patient/Appointments"   class="nav-item"><i class="fas fa-calendar-alt"></i>المواعيد</a>
  <a href="/Patient/MedicalRecords" class="nav-item"><i class="fas fa-notes-medical"></i>السجلات الطبية</a>
  <a href="/Patient/LabResults"     class="nav-item"><i class="fas fa-flask"></i>نتائج التحاليل</a>
  <span class="nav-section">أخرى</span>
  <a href="/Patient/Alerts"  class="nav-item"><i class="fas fa-bell"></i>التنبيهات</a>
  <a href="/Patient/Nearby"  class="nav-item"><i class="fas fa-map-marker-alt"></i>مقدمو خدمات</a>
  <div class="sidebar-footer">
    <form method="post" action="/Account/Logout">
      @Html.AntiForgeryToken()
      <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i>تسجيل الخروج</button>
    </form>
  </div>
</aside>

<div class="main">
  <div class="page-header">
    <h1>تقييم المخاطر الصحية</h1>
    <p>أدخل مؤشراتك الحيوية الآن لتحصل على تقييم فوري لحالتك</p>
  </div>

  @if(!ViewData.ModelState.IsValid)
  {
    <div class="error-summary">
      <i class="fas fa-exclamation-circle"></i>
      يرجى مراجعة الحقول المطلوبة قبل الإرسال.
    </div>
  }

  <div class="layout">
    <!-- Form -->
    <div class="form-card">
      <div class="form-card-header">
        <div class="icon"><i class="fas fa-shield-virus"></i></div>
        <h3>أدخل مؤشراتك الحيوية</h3>
      </div>
      <div class="form-body">
        <form method="post" asp-action="RiskAssessment" asp-controller="Patient" id="riskForm">
          @Html.AntiForgeryToken()

          <div class="vitals-section">
            <div class="section-title"><i class="fas fa-heartbeat"></i>المؤشرات الحيوية</div>
            <div class="vitals-grid">
              <div class="form-group">
                <label><i class="fas fa-heart" style="color:var(--danger);"></i>معدل ضربات القلب</label>
                <div class="input-wrap">
                  <i class="fas fa-heart"></i>
                  <input asp-for="HeartRate" type="number" step="0.1" min="30" max="250" class="form-control" placeholder="72"/>
                  <span class="unit">bpm</span>
                </div>
              </div>
              <div class="form-group">
                <label><i class="fas fa-thermometer-half" style="color:var(--warning);"></i>درجة الحرارة</label>
                <div class="input-wrap">
                  <i class="fas fa-thermometer-half"></i>
                  <input asp-for="Temperature" type="number" step="0.1" min="30" max="45" class="form-control" placeholder="36.5"/>
                  <span class="unit">°C</span>
                </div>
              </div>
              <div class="form-group">
                <label>ضغط الدم الانقباضي</label>
                <div class="input-wrap">
                  <i class="fas fa-tachometer-alt"></i>
                  <input asp-for="SystolicBP" type="number" step="0.1" class="form-control" placeholder="120"/>
                  <span class="unit">mmHg</span>
                </div>
              </div>
              <div class="form-group">
                <label>ضغط الدم الانبساطي</label>
                <div class="input-wrap">
                  <i class="fas fa-tachometer-alt"></i>
                  <input asp-for="DiastolicBP" type="number" step="0.1" class="form-control" placeholder="80"/>
                  <span class="unit">mmHg</span>
                </div>
              </div>
              <div class="form-group">
                <label><i class="fas fa-lungs" style="color:var(--accent);"></i>تشبع الأكسجين</label>
                <div class="input-wrap">
                  <i class="fas fa-lungs"></i>
                  <input asp-for="OxygenSaturation" type="number" step="0.1" min="50" max="100" class="form-control" placeholder="98"/>
                  <span class="unit">%</span>
                </div>
              </div>
              <div class="form-group">
                <label><i class="fas fa-tint" style="color:#E74C3C;"></i>سكر الدم</label>
                <div class="input-wrap">
                  <i class="fas fa-tint"></i>
                  <input asp-for="BloodSugar" type="number" step="0.1" class="form-control" placeholder="100"/>
                  <span class="unit">mg/dL</span>
                </div>
              </div>
            </div>
          </div>

          <div class="vitals-section">
            <div class="section-title"><i class="fas fa-comment-medical"></i>الأعراض</div>
            <div class="form-group">
              <textarea asp-for="Symptoms" class="form-control symptoms-input" rows="3"
                        placeholder="صف أعراضك الحالية... مثال: صداع شديد، دوخة، ضيق تنفس"></textarea>
            </div>
          </div>

          <div class="vitals-section" style="margin-bottom:0;">
            <div class="section-title"><i class="fas fa-map-marker-alt"></i>موقعك (اختياري)</div>
            <div class="location-row">
              <div class="form-group">
                <label>خط العرض</label>
                <input asp-for="Latitude" type="number" step="any" class="form-control" id="lat" placeholder="30.0444"/>
              </div>
              <div class="form-group">
                <label>خط الطول</label>
                <input asp-for="Longitude" type="number" step="any" class="form-control" id="lng" placeholder="31.2357"/>
              </div>
            </div>
            <button type="button" onclick="getLocation()" style="margin-top:10px;background:none;border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-family:'Tajawal',sans-serif;font-size:.85rem;color:var(--primary);cursor:pointer;display:flex;align-items:center;gap:6px;">
              <i class="fas fa-crosshairs"></i>تحديد موقعي تلقائياً
            </button>
          </div>

          <button type="submit" class="btn-assess" id="assessBtn">
            <i class="fas fa-shield-virus"></i>إجراء التقييم الآن
          </button>
        </form>
      </div>
    </div>

    <!-- History Sidebar -->
    <div class="history-card">
      <div class="history-header">
        <i class="fas fa-history" style="color:var(--primary);"></i>
        سجل التقييمات السابقة
      </div>
      @if(!history.Any())
      {
        <div class="empty-history">لا توجد تقييمات سابقة</div>
      }
      else
      {
        <div class="history-list">
        @foreach(var h in history)
        {
          <div class="history-item">
            <div class="risk-dot" style="background:@h.RiskColor;"></div>
            <div class="history-item-body">
              <div class="history-item-label" style="color:@h.RiskColor;">@h.RiskLabel</div>
              <div class="history-item-score">النتيجة: @h.RiskScore.ToString("F0")%</div>
            </div>
          </div>
        }
        </div>
      }
    </div>
  </div>
</div>

<script>
document.getElementById('riskForm').addEventListener('submit', function(){
  const btn = document.getElementById('assessBtn');
  btn.classList.add('loading');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>جاري التقييم...';
});
function getLocation(){
  if(!navigator.geolocation) return;
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById('lat').value = pos.coords.latitude.toFixed(6);
    document.getElementById('lng').value = pos.coords.longitude.toFixed(6);
  });
}
</script>
</body>
</html>
