@model Etmen_PL.Models.ViewModels.Account.ForcePasswordChangeViewModel
@{
    ViewData["Title"] = "تحديث كلمة المرور الإجباري";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="col-lg-5 col-md-7 col-12 animate__animated animate__fadeIn">
        <div class="card shadow-lg border-0 rounded-4 p-5" style="background: white; border: 1px solid rgba(0,0,0,0.05) !important;">
            <div class="text-center mb-4">
                <div class="text-warning fs-1 mb-2">
                    <i class="fas fa-key animate__animated animate__shakeY"></i>
                </div>
                <h3 class="fw-black text-dark mb-1" style="font-weight: 900;">تحديث كلمة المرور</h3>
                <p class="text-muted small">هذا هو تسجيل دخولك الأول باستخدام كلمة المرور المؤقتة. يرجى اختيار كلمة مرور جديدة قوية لضمان أمان حسابك.</p>
            </div>

            <form asp-controller="Account" asp-action="ForcePasswordChange" method="post" class="needs-validation">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-bold small text-dark">كلمة المرور الجديدة</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="NewPassword" type="password" class="form-control bg-light border-0 rounded-start-pill" required placeholder="أدخل كلمة مرور قوية" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold small text-dark">تأكيد كلمة المرور الجديدة</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-0 rounded-start-pill" required placeholder="أعد إدخال كلمة المرور" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-2 shadow-sm">
                    <i class="fas fa-save me-1"></i> حفظ كلمة المرور والمتابعة
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
