@model Etmen_BLL.DTOs.Auth.ResetPasswordDto
@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور — إطمن";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --primary: #1A6FBF;
            --primary-dark: #0D4C8A;
            --accent: #00C9A7;
            --success: #27AE60;
            --danger: #E74C3C;
            --dark: #0F1923;
            --text: #2C3E50;
            --text-muted: #7F8C8D;
            --border: #DDE3EC;
            --border-focus: rgba(26, 111, 191, 0.4);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(26, 111, 191, 0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(26, 111, 191, 0.06) 1px, transparent 1px);
            background-size: 55px 55px;
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.12;
            animation: float 8s ease-in-out infinite;
        }

        .o1 {
            width: 400px;
            height: 400px;
            background: var(--primary);
            top: -100px;
            left: -100px;
        }

        .o2 {
            width: 300px;
            height: 300px;
            background: var(--accent);
            bottom: -50px;
            right: -50px;
            animation-delay: -4s;
        }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(20px, -20px); }
        }

        .card {
            position: relative;
            z-index: 2;
            background: white;
            border-radius: 24px;
            padding: 50px 46px;
            max-width: 480px;
            width: 92%;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.4);
            animation: cardIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @@keyframes cardIn {
            from { opacity: 0; transform: scale(0.92) translateY(16px); }
            to { opacity: 1; transform: none; }
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            left: 0;
            height: 4px;
            border-radius: 24px 24px 0 0;
            background: linear-gradient(90deg, var(--primary), var(--accent));
        }

        .icon-wrap {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, #E8F4FD, #D0EAFC);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--primary);
        }

        h1 {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--text);
            text-align: center;
            margin-bottom: 0.4rem;
        }

        .desc {
            color: var(--text-muted);
            font-size: 0.9rem;
            text-align: center;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .field-label {
            display: block;
            font-size: 0.84rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .required {
            color: var(--danger);
            margin-right: 2px;
        }

        .field-wrapper {
            position: relative;
            margin-bottom: 1.2rem;
        }

        .field-icon {
            position: absolute;
            top: 50%;
            right: 15px;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 0.9rem;
            pointer-events: none;
            z-index: 2;
        }

        .toggle-pass {
            position: absolute;
            top: 50%;
            left: 14px;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px;
            font-size: 0.9rem;
            z-index: 3;
            transition: color 0.2s;
        }

        .toggle-pass:hover {
            color: var(--primary);
        }

        .field-input {
            width: 100%;
            height: 50px;
            padding: 0 46px 0 14px;
            background: #F8FAFC;
            border: 1.5px solid var(--border);
            border-radius: 11px;
            font-family: 'Tajawal', sans-serif;
            font-size: 0.93rem;
            color: var(--text);
            transition: all 0.25s;
            outline: none;
            direction: ltr;
            text-align: right;
        }

        .field-input.has-toggle {
            padding-left: 46px;
        }

        .field-input::placeholder {
            color: rgba(127, 140, 141, 0.6);
        }

        .field-input:focus {
            background: white;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--border-focus);
        }

        .field-input:focus ~ .field-icon {
            color: var(--primary);
        }

        .field-input.is-invalid {
            border-color: var(--danger);
            background: #fff8f8;
        }

        .field-input.is-invalid:focus {
            box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.15);
        }

        .field-error {
            display: flex;
            align-items: center;
            gap: 5px;
            color: var(--danger);
            font-size: 0.78rem;
            margin-top: 4px;
            font-weight: 500;
        }

        .password-strength {
            margin-top: 0.5rem;
            display: flex;
            gap: 4px;
            height: 4px;
        }

        .strength-bar {
            flex: 1;
            background: #E0E0E0;
            border-radius: 2px;
            transition: background-color 0.3s;
        }

        .strength-bar.active-weak {
            background: #E74C3C;
        }

        .strength-bar.active-fair {
            background: #F39C12;
        }

        .strength-bar.active-good {
            background: #F1C40F;
        }

        .strength-bar.active-strong {
            background: #27AE60;
        }

        .strength-text {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .alert-error {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: #FEF2F2;
            border: 1px solid #FECACA;
            border-right: 4px solid var(--danger);
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 1.5rem;
            font-size: 0.84rem;
            color: #991B1B;
        }

        .alert-error i {
            flex-shrink: 0;
            margin-top: 2px;
        }

        .btn-submit {
            width: 100%;
            height: 52px;
            background: linear-gradient(135deg, var(--primary), #1a8fbf);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 6px 22px rgba(26, 111, 191, 0.35);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(26, 111, 191, 0.45);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .back-link {
            text-align: center;
            margin-top: 1.2rem;
            font-size: 0.87rem;
            color: var(--text-muted);
        }

        .back-link a {
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
            margin: 0 4px;
        }

        .back-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="orb o1"></div>
    <div class="orb o2"></div>

    <div class="card">
        <div class="icon-wrap">
            <i class="fas fa-lock"></i>
        </div>
        <h1>إعادة تعيين كلمة المرور</h1>
        <p class="desc">أدخل كلمة المرور الجديدة لحسابك</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
        {
            <div class="alert-error" role="alert">
                <i class="fas fa-exclamation-circle"></i>
                <div>
                    @foreach (var e in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div>@e.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form method="post" asp-action="ResetPassword" asp-controller="Account" novalidate id="resetForm">
            @Html.AntiForgeryToken()

            <!-- Hidden fields for token and email -->
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <!-- Password -->
            <div class="field-wrapper">
                <label class="field-label" for="Password">
                    كلمة المرور الجديدة <span class="required">*</span>
                </label>
                <div style="position: relative;">
                    <input asp-for="Password"
                           type="password"
                           id="Password"
                           class="field-input has-toggle @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="أدخل كلمة المرور الجديدة"
                           autocomplete="new-password" />
                    <i class="fas fa-lock-open field-icon"></i>
                    <button type="button" class="toggle-pass" id="togglePass" aria-label="إظهار كلمة المرور">
                        <i class="fas fa-eye" id="togglePassIcon"></i>
                    </button>
                </div>
                <div class="password-strength" id="passwordStrength">
                    <div class="strength-bar"></div>
                    <div class="strength-bar"></div>
                    <div class="strength-bar"></div>
                    <div class="strength-bar"></div>
                </div>
                <div class="strength-text" id="strengthText"></div>
                @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                {
                    <div class="field-error">
                        <i class="fas fa-circle-exclamation"></i>
                        <span asp-validation-for="Password"></span>
                    </div>
                }
            </div>

            <!-- Confirm Password -->
            <div class="field-wrapper">
                <label class="field-label" for="ConfirmPassword">
                    تأكيد كلمة المرور <span class="required">*</span>
                </label>
                <div style="position: relative;">
                    <input asp-for="ConfirmPassword"
                           type="password"
                           id="ConfirmPassword"
                           class="field-input has-toggle @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="أكد كلمة المرور"
                           autocomplete="new-password" />
                    <i class="fas fa-check-double field-icon"></i>
                    <button type="button" class="toggle-pass" id="toggleConfirm" aria-label="إظهار كلمة المرور">
                        <i class="fas fa-eye" id="toggleConfirmIcon"></i>
                    </button>
                </div>
                @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0)
                {
                    <div class="field-error">
                        <i class="fas fa-circle-exclamation"></i>
                        <span asp-validation-for="ConfirmPassword"></span>
                    </div>
                }
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-check-circle"></i> إعادة تعيين كلمة المرور
            </button>
        </form>

        <div class="back-link">
            <a href="@Url.Action("Login", "Account")"><i class="fas fa-sign-in-alt"></i>&#32;تسجيل الدخول</a>
            |
            <a href="@Url.Action("SelectUserType", "Account")"><i class="fas fa-arrow-left"></i>&#32;تغيير النوع</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // ── Password visibility toggle ───────────────────────
        document.getElementById('togglePass').addEventListener('click', function(e) {
            e.preventDefault();
            const input = document.getElementById('Password');
            const icon = document.getElementById('togglePassIcon');
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            icon.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
        });

        document.getElementById('toggleConfirm').addEventListener('click', function(e) {
            e.preventDefault();
            const input = document.getElementById('ConfirmPassword');
            const icon = document.getElementById('toggleConfirmIcon');
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            icon.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
        });

        // ── Password strength meter ──────────────────────────
        document.getElementById('Password').addEventListener('input', function() {
            const password = this.value;
            const strengthBars = document.querySelectorAll('.strength-bar');
            const strengthText = document.getElementById('strengthText');
            let strength = 0;

            // Reset all bars
            strengthBars.forEach(bar => {
                bar.className = 'strength-bar';
            });

            if (password.length === 0) {
                strengthText.textContent = '';
                return;
            }

            // Check password criteria
            if (password.length >= 6) strength++;
            if (password.length >= 10) strength++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
            if (/\d/.test(password) && /[!@@#$%^&*]/.test(password)) strength++;

            // Activate bars
            if (strength > 0) strengthBars[0].classList.add('active-weak');
            if (strength > 1) strengthBars[1].classList.add('active-fair');
            if (strength > 2) strengthBars[2].classList.add('active-good');
            if (strength > 3) strengthBars[3].classList.add('active-strong');

            // Update text
            const texts = {
                1: 'ضعيفة جداً',
                2: 'ضعيفة',
                3: 'متوسطة',
                4: 'قوية'
            };
            strengthText.textContent = texts[strength] || '';
            strengthText.style.color = strength === 4 ? '#27AE60' : strength === 3 ? '#F1C40F' : '#E74C3C';
        });
    </script>
</body>
</html>
