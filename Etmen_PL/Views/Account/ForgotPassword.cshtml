@* ═══════════════════════════════════════════════════════════
   ForgotPassword.cshtml
   ═══════════════════════════════════════════════════════════ *@
@model Etmen_BLL.DTOs.Auth.ForgotPasswordDto
@{
    ViewData["Title"] = "استعادة كلمة المرور — إطمن";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root { --primary:#1A6FBF; --accent:#00C9A7; --dark:#0F1923; --text:#2C3E50; --muted:#7F8C8D; --border:#DDE3EC; --danger:#E74C3C; }
        *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
        body {
            font-family:'Tajawal',sans-serif; background:var(--dark);
            min-height:100vh; display:flex; align-items:center; justify-content:center; position:relative;
        }
        body::before {
            content:''; position:absolute; inset:0;
            background-image:linear-gradient(rgba(26,111,191,0.06) 1px,transparent 1px),
                            linear-gradient(90deg,rgba(26,111,191,0.06) 1px,transparent 1px);
            background-size:55px 55px;
        }
        .orb { position:absolute;border-radius:50%;filter:blur(80px);opacity:.12; }
        .o1 { width:380px;height:380px;background:var(--primary);top:-80px;left:-80px; }
        .o2 { width:250px;height:250px;background:var(--accent);bottom:-40px;right:-40px; }

        .card {
            position:relative;z-index:2;background:white;border-radius:24px;
            padding:50px 46px;max-width:460px;width:92%;
            box-shadow:0 24px 80px rgba(0,0,0,0.4);
            animation:in .45s cubic-bezier(.34,1.56,.64,1);
        }
        @@keyframes in { from{opacity:0;transform:scale(.92) translateY(16px)} to{opacity:1;transform:none} }
        .card::before { content:'';position:absolute;top:0;right:0;left:0;height:4px;border-radius:24px 24px 0 0;background:linear-gradient(90deg,var(--primary),var(--accent)); }

        .icon-wrap {
            width:80px;height:80px;margin:0 auto 1.5rem;
            background:linear-gradient(135deg,#E8F4FD,#D0EAFC);
            border-radius:50%;display:flex;align-items:center;justify-content:center;
            font-size:2rem;color:var(--primary);
        }
        h1 { font-size:1.6rem;font-weight:900;color:var(--text);text-align:center;margin-bottom:.4rem; }
        .desc { color:var(--muted);font-size:.9rem;text-align:center;line-height:1.7;margin-bottom:2rem; }

        .field-label { display:block;font-size:.84rem;font-weight:700;color:var(--text);margin-bottom:5px; }
        .field-wrapper { position:relative; }
        .field-icon { position:absolute;top:50%;right:15px;transform:translateY(-50%);color:var(--muted);font-size:.9rem;pointer-events:none; }
        .field-input {
            width:100%;height:50px;padding:0 46px 0 14px;background:#F8FAFC;
            border:1.5px solid var(--border);border-radius:11px;
            font-family:'Tajawal',sans-serif;font-size:.93rem;color:var(--text);
            transition:all .25s;outline:none;direction:ltr;text-align:right;
        }
        .field-input:focus { background:white;border-color:var(--primary);box-shadow:0 0 0 4px rgba(26,111,191,.25); }
        .field-input.is-invalid { border-color:var(--danger); }

        .field-error { display:flex;align-items:center;gap:5px;color:var(--danger);font-size:.78rem;margin-top:4px;font-weight:500; }

        .btn-submit {
            width:100%;height:52px;background:linear-gradient(135deg,var(--primary),#1a8fbf);
            color:white;border:none;border-radius:12px;
            font-family:'Tajawal',sans-serif;font-size:1rem;font-weight:800;
            cursor:pointer;transition:all .3s;margin-top:1.5rem;
            display:flex;align-items:center;justify-content:center;gap:10px;
            box-shadow:0 6px 22px rgba(26,111,191,.35);
        }
        .btn-submit:hover { transform:translateY(-2px);box-shadow:0 10px 30px rgba(26,111,191,.45); }

        .back-link { text-align:center;margin-top:1.2rem;font-size:.87rem;color:var(--muted); }
        .back-link a { color:var(--primary);font-weight:700;text-decoration:none; }
        .back-link a:hover { text-decoration:underline; }
    </style>
</head>
<body>
    <div class="orb o1"></div>
    <div class="orb o2"></div>
    <div class="card">
        <div class="icon-wrap"><i class="fas fa-key"></i></div>
        <h1>استعادة كلمة المرور</h1>
        <p class="desc">أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة تعيين كلمة المرور</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
        {
            <div style="background:#FEF2F2;border:1px solid #FECACA;border-right:4px solid var(--danger);border-radius:10px;padding:12px 14px;margin-bottom:1.2rem;font-size:.84rem;color:#991B1B;">
                @foreach (var e in ViewData.ModelState[string.Empty]!.Errors) { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form method="post" asp-area="Auth" asp-controller="Account" asp-action="ForgotPassword" novalidate>
            @Html.AntiForgeryToken()
            <div style="margin-bottom:1rem;">
                <label class="field-label" for="Email">البريد الإلكتروني <span style="color:var(--danger);">*</span></label>
                <div class="field-wrapper">
                    <input asp-for="Email" type="email" id="Email"
                           class="field-input @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="example@email.com" />
                    <i class="fas fa-envelope field-icon"></i>
                </div>
                @if (ViewData.ModelState["Email"]?.Errors.Count > 0)
                {
                    <div class="field-error"><i class="fas fa-circle-exclamation"></i><span asp-validation-for="Email"></span></div>
                }
            </div>
            <button type="submit" class="btn-submit">
                <i class="fas fa-paper-plane"></i> إرسال رابط الاستعادة
            </button>
        </form>

        <div class="back-link">
            <a href="/Account/Login"><i class="fas fa-arrow-right"></i> العودة لتسجيل الدخول</a>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
