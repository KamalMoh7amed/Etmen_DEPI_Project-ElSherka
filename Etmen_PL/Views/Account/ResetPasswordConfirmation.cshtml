@{
    ViewData["Title"] = "تم إعادة تعيين كلمة المرور — إطمن";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --primary: #1A6FBF;
            --accent: #00C9A7;
            --success: #27AE60;
            --dark: #0F1923;
            --text: #2C3E50;
            --muted: #7F8C8D;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(26, 111, 191, 0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(26, 111, 191, 0.06) 1px, transparent 1px);
            background-size: 55px 55px;
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.12;
            animation: float 8s ease-in-out infinite;
        }

        .o1 {
            width: 400px;
            height: 400px;
            background: var(--primary);
            top: -100px;
            left: -100px;
        }

        .o2 {
            width: 300px;
            height: 300px;
            background: var(--accent);
            bottom: -50px;
            right: -50px;
            animation-delay: -4s;
        }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(20px, -20px); }
        }

        .card {
            position: relative;
            z-index: 2;
            background: white;
            border-radius: 24px;
            padding: 60px 48px;
            max-width: 500px;
            width: 92%;
            text-align: center;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.4);
            animation: cardIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @@keyframes cardIn {
            from { opacity: 0; transform: scale(0.9) translateY(20px); }
            to { opacity: 1; transform: none; }
        }

        .icon-wrap {
            width: 120px;
            height: 120px;
            margin: 0 auto 2rem;
            background: linear-gradient(135deg, #E8F4FD, #D0EAFC);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: var(--primary);
            box-shadow: 0 8px 30px rgba(26, 111, 191, 0.2);
            animation: iconPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s backwards;
        }

        @@keyframes iconPop {
            from { transform: scale(0) rotate(-30deg); opacity: 0; }
            to { transform: scale(1) rotate(0); opacity: 1; }
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--success);
            margin-bottom: 0.8rem;
        }

        .subtitle {
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .success-badge {
            display: inline-block;
            background: #F0FDF4;
            border: 2px solid var(--success);
            border-radius: 50%;
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            animation: badgePulse 2s ease-in-out infinite;
        }

        @@keyframes badgePulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(39, 174, 96, 0.4); }
            50% { box-shadow: 0 0 0 8px rgba(39, 174, 96, 0); }
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary), #1a8fbf);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 6px 22px rgba(26, 111, 191, 0.35);
            text-decoration: none;
            margin-bottom: 1rem;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(26, 111, 191, 0.45);
        }

        .info-box {
            background: #F0F7FF;
            border: 1px solid #C0D8F0;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
            color: var(--primary);
            line-height: 1.6;
        }

        .info-box i {
            margin-left: 6px;
            color: var(--primary);
        }

        .back-link {
            font-size: 0.85rem;
            color: var(--muted);
            margin-top: 1rem;
        }

        .back-link a {
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
            margin: 0 4px;
        }

        .back-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="orb o1"></div>
    <div class="orb o2"></div>

    <div class="card">
        <div class="success-badge">
            <i class="fas fa-check" style="color: var(--success); font-size: 2rem;"></i>
        </div>
        <h1>تم بنجاح!</h1>
        <p class="subtitle">تم إعادة تعيين كلمة المرور بنجاح</p>

        <div class="info-box">
            <i class="fas fa-info-circle"></i>
            يمكنك الآن تسجيل الدخول باستخدام كلمة المرور الجديدة
        </div>

        <a href="@Url.Action("Login", "Account")" class="btn-login">
            <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
        </a>

        <div class="back-link">
            أو قم بـ
            <a href="@Url.Action("SelectUserType", "Account")">تغيير نوع الحساب</a>
        </div>
    </div>
</body>
</html>
