@{
    ViewData["Title"] = "اختر نوع حسابك — إطمن";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --primary: #1A6FBF;
            --primary-dark: #0D4C8A;
            --accent: #00C9A7;
            --success: #27AE60;
            --danger: #E74C3C;
            --dark: #0F1923;
            --dark-2: #1B2A38;
            --text: #2C3E50;
            --text-muted: #7F8C8D;
            --border: #DDE3EC;
            --white: #FFFFFF;
            --glass: rgba(255, 255, 255, 0.06);
            --glass-border: rgba(255, 255, 255, 0.12);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            display: flex;
            min-height: 100vh;
            overflow: hidden;
        }

        /* ══ LEFT PANEL ═════════════════════════════ */
        .brand-panel {
            flex: 0 0 55%;
            position: relative;
            background: linear-gradient(145deg, var(--dark) 0%, #0a1e30 40%, #051525 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            padding: 60px 70px;
            overflow: hidden;
        }

        /* Animated mesh grid */
        .brand-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(26, 111, 191, 0.07) 1px, transparent 1px),
                linear-gradient(90deg, rgba(26, 111, 191, 0.07) 1px, transparent 1px);
            background-size: 55px 55px;
            animation: gridDrift 20s linear infinite;
        }

        @@keyframes gridDrift {
            0% { background-position: 0 0; }
            100% { background-position: 55px 55px; }
        }

        /* Glow orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.15;
            animation: orbFloat 10s ease-in-out infinite;
        }

        .orb-1 {
            width: 500px;
            height: 500px;
            background: var(--primary);
            top: -150px;
            left: -100px;
        }

        .orb-2 {
            width: 300px;
            height: 300px;
            background: var(--accent);
            bottom: -60px;
            right: 5%;
            animation-delay: -4s;
        }

        .orb-3 {
            width: 200px;
            height: 200px;
            background: #9B59B6;
            top: 40%;
            left: 40%;
            opacity: 0.08;
            animation-delay: -7s;
        }

        @@keyframes orbFloat {
            0%, 100% { transform: translate(0, 0); }
            33% { transform: translate(20px, -25px); }
            66% { transform: translate(-15px, 15px); }
        }

        .brand-content {
            position: relative;
            z-index: 2;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 60px;
            text-decoration: none;
        }

        .brand-logo-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: white;
            box-shadow: 0 0 30px rgba(26, 111, 191, 0.4);
        }

        .brand-logo-text {
            font-size: 1.8rem;
            font-weight: 900;
            color: white;
        }

        .brand-logo-text span {
            color: var(--accent);
        }

        .brand-title {
            font-size: clamp(2rem, 3.5vw, 3.2rem);
            font-weight: 900;
            color: white;
            line-height: 1.15;
            margin-bottom: 1.2rem;
            letter-spacing: -0.5px;
        }

        .brand-title .gradient-text {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-subtitle {
            font-size: 1.05rem;
            color: rgba(255, 255, 255, 0.55);
            line-height: 1.8;
            max-width: 420px;
            margin-bottom: 3rem;
        }

        /* ══ RIGHT PANEL ═════════════════════════════ */
        .form-panel {
            flex: 0 0 45%;
            position: relative;
            background: var(--white);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            overflow-y: auto;
        }

        .form-card {
            width: 100%;
            max-width: 420px;
            animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: none;
            }
        }

        .form-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .form-header h1 {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* User Type Options */
        .user-type-options {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 2rem;
        }

        .user-type-option {
            position: relative;
        }

        .user-type-option input[type="radio"] {
            display: none;
        }

        .user-type-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
            border: 2px solid var(--border);
            border-radius: 16px;
            background: white;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
            min-height: 180px;
        }

        .user-type-option input[type="radio"]:checked + .user-type-label {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(26, 111, 191, 0.08), rgba(0, 201, 167, 0.08));
            box-shadow: 0 0 0 4px rgba(26, 111, 191, 0.15);
        }

        .user-type-label:hover {
            border-color: var(--primary);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        }

        .user-type-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
            color: var(--primary);
            transition: all 0.3s ease;
        }

        .user-type-option input[type="radio"]:checked + .user-type-label .user-type-icon {
            color: var(--accent);
            transform: scale(1.15);
        }

        .user-type-text {
            font-weight: 700;
            font-size: 1rem;
            color: var(--text);
            text-align: center;
        }

        .user-type-description {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-align: center;
            margin-top: 6px;
        }

        /* Form */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .btn-submit {
            width: 100%;
            height: 52px;
            background: linear-gradient(135deg, var(--primary), #1a8fbf);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 6px 22px rgba(26, 111, 191, 0.35);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(26, 111, 191, 0.45);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .form-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .form-footer a {
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
            transition: color 0.3s;
        }

        .form-footer a:hover {
            color: var(--primary-dark);
        }

        .error-message {
            background: #FEF2F2;
            border: 1px solid #FECACA;
            border-right: 4px solid var(--danger);
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 1.5rem;
            font-size: 0.84rem;
            color: #991B1B;
            display: none;
        }

        .error-message.show {
            display: block;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .brand-panel {
                flex: 0 0 50%;
                padding: 40px;
            }

            .form-panel {
                flex: 0 0 50%;
            }
        }

        @@media (max-width: 768px) {
            body {
                flex-direction: column;
                overflow-y: auto;
            }

            .brand-panel {
                flex: none;
                min-height: 200px;
                padding: 40px 20px;
            }

            .form-panel {
                flex: none;
                min-height: auto;
                padding: 30px 20px;
            }

            .brand-title {
                font-size: 1.6rem;
            }

            .brand-subtitle {
                margin-bottom: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="brand-panel">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="brand-content">
            <a href="/" class="brand-logo">
                <div class="brand-logo-icon">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <div class="brand-logo-text">إ<span>طمن</span></div>
            </a>

            <h1 class="brand-title">
                منصة صحية <span class="gradient-text">متكاملة</span>
            </h1>

            <p class="brand-subtitle">
                احصل على أفضل الخدمات الطبية والاستشارات من متخصصين معتمدين في أي وقت وأي مكان
            </p>
        </div>
    </div>

    <div class="form-panel">
        <div class="form-card">
            <div class="form-header">
                <h1>اختر نوع حسابك</h1>
                <p>اختر بين أنك دكتور أم مريض لتتمكن من الاستفادة من الخدمات المناسبة لك</p>
            </div>

            <form method="post" asp-action="SelectUserType" asp-controller="Account" id="userTypeForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="error-message" id="errorMessage"></div>

                <div class="form-group">
                    <div class="user-type-options">
                        <!-- Doctor Option -->
                        <div class="user-type-option">
                            <input type="radio" id="doctorOption" name="userType" value="Doctor" />
                            <label for="doctorOption" class="user-type-label">
                                <div class="user-type-icon">
                                    <i class="fas fa-stethoscope"></i>
                                </div>
                                <div class="user-type-text">دكتور</div>
                                <div class="user-type-description">متخصص طبي</div>
                            </label>
                        </div>

                        <!-- Patient Option -->
                        <div class="user-type-option">
                            <input type="radio" id="patientOption" name="userType" value="Patient" />
                            <label for="patientOption" class="user-type-label">
                                <div class="user-type-icon">
                                    <i class="fas fa-user-injured"></i>
                                </div>
                                <div class="user-type-text">مريض</div>
                                <div class="user-type-description">طالب خدمة طبية</div>
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-arrow-left"></i>
                    <span>المتابعة</span>
                </button>
            </form>

            <div class="form-footer">
                هل لديك حساب بالفعل؟
                <a href="@Url.Action("Login", "Account")">تسجيل دخول</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('userTypeForm').addEventListener('submit', function(e) {
            const selectedOption = document.querySelector('input[name="userType"]:checked');
            const errorMessage = document.getElementById('errorMessage');

            if (!selectedOption) {
                e.preventDefault();
                errorMessage.textContent = 'يرجى اختيار نوع الحساب قبل المتابعة';
                errorMessage.classList.add('show');
                return false;
            }

            errorMessage.classList.remove('show');
            return true;
        });

        // Clear error message when user selects an option
        document.querySelectorAll('input[name="userType"]').forEach(radio => {
            radio.addEventListener('change', function() {
                document.getElementById('errorMessage').classList.remove('show');
            });
        });
    </script>
</body>
</html>
