@model Etmen_PL.Models.ViewModels.Admin.AdminDashboardViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لوحة القيادة والتحكم المركزي — إطمن</title>
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            /* Light Theme Palette (WellNest) */
            --light-bg: #F4F7F9;
            --light-card-bg: #FFFFFF;
            --light-border: #E2E8F0;
            --light-text: #2C3E50;
            --light-text-muted: #7F8C8D;
            --light-accent: #3cd5cb;
            --light-primary: #1A6FBF;
            --light-primary-dark: #125393;
            --light-primary-light: #E8F4FD;
            --light-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
            --light-gradient: linear-gradient(135deg, #1A6FBF 0%, #3cd5cb 100%);


            /* Dark Theme Palette (Crisis Analytical tools) */
            --dark-bg: #0B0E14;
            --dark-card-bg: #151A22;
            --dark-border: #21262D;
            --dark-text: #ECF0F1;
            --dark-text-muted: #8B949E;
            --dark-accent: #00E676;
            --dark-primary: #00B0FF;
            --dark-primary-light: rgba(0, 176, 255, 0.1);
            --dark-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);

            --danger: #E74C3C;
            --success: #27AE60;
            --warning: #F39C12;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            transition: all 0.5s ease-in-out;
        }

        /* ═══ THEME APPLIERS ═══════════════════════════════════ */
        body.theme-light {
            background-color: #f5f8fa;
            background-image: radial-gradient(circle at 0% 0%, rgba(26, 111, 191, 0.04) 0%, transparent 50%), radial-gradient(circle at 100% 100%, rgba(60, 213, 203, 0.04) 0%, transparent 50%);
            color: var(--light-text);
        }
        body.theme-dark {
            background-color: var(--dark-bg);
            color: var(--dark-text);
        }

        /* Navbars */
        .admin-navbar {
            padding: 0.9rem 2.5rem;
            border-bottom: 1px solid;
            transition: all 0.5s;
        }
        body.theme-light .admin-navbar {
            background: #FFFFFF;
            border-color: var(--light-border);
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
        }
        body.theme-dark .admin-navbar {
            background: #161B22;
            border-color: var(--dark-border);
            box-shadow: 0 4px 30px rgba(0,0,0,0.3);
        }

        .brand-section {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: inherit;
        }
        .brand-icon-box {
            width: 38px; height: 38px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.15rem;
            transition: all 0.5s;
        }
        body.theme-light .brand-icon-box {
            background: linear-gradient(135deg, var(--light-primary), var(--light-accent));
        }
        body.theme-dark .brand-icon-box {
            background: linear-gradient(135deg, var(--dark-primary), var(--dark-accent));
        }
        .brand-title {
            font-size: 1.4rem; font-weight: 900; margin: 0; line-height: 1;
        }
        .brand-subtitle {
            font-size: 0.65rem; display: block; font-weight: 500; margin-top: 2px;
        }
        body.theme-light .brand-title span { color: var(--light-primary); }
        body.theme-dark .brand-title span { color: var(--dark-accent); }
        body.theme-light .brand-subtitle { color: var(--light-text-muted); }
        body.theme-dark .brand-subtitle { color: var(--dark-text-muted); }

        /* Search input from WellNest */
        .search-bar-container {
            position: relative;
            width: 300px;
        }
        .search-input {
            width: 100%;
            border-radius: 12px;
            padding: 8px 16px 8px 40px;
            font-size: 0.85rem;
            border: 1px solid;
            outline: none;
            transition: all 0.3s;
        }
        body.theme-light .search-input {
            background: #F0F4F8;
            border-color: transparent;
            color: var(--light-text);
        }
        body.theme-light .search-input:focus {
            background: white;
            border-color: var(--light-primary);
        }
        body.theme-dark .search-input {
            background: #21262D;
            border-color: transparent;
            color: var(--dark-text);
        }
        body.theme-dark .search-input:focus {
            background: #161B22;
            border-color: var(--dark-primary);
        }

        /* Cards */
        .dashboard-card {
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
        }
        body.theme-light .dashboard-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-color: rgba(226, 232, 240, 0.8);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        }
        body.theme-light .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(26, 111, 191, 0.06);
            border-color: rgba(26, 111, 191, 0.15);
        }
        body.theme-dark .dashboard-card {
            background: var(--dark-card-bg);
            border-color: var(--dark-border);
            box-shadow: var(--dark-shadow);
        }
        body.theme-dark .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(0, 230, 118, 0.1);
            border-color: rgba(0, 230, 118, 0.3);
        }

        .card-header-sm {
            display: flex;
            justify-content: justify;
            align-items: center;
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 18px;
        }
        body.theme-light .card-header-sm { color: var(--light-text); }
        body.theme-dark .card-header-sm { color: var(--dark-text); }

        /* Stats Blocks */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }
        .stat-card {
            border-radius: 20px;
            padding: 24px;
            border: 1px solid;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all 0.3s;
        }
        body.theme-light .stat-card {
            background: rgba(255, 255, 255, 0.9);
            border-color: rgba(226, 232, 240, 0.8);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.02);
        }
        body.theme-light .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(26, 111, 191, 0.08);
            border-color: rgba(26, 111, 191, 0.2);
        }
        body.theme-dark .stat-card {
            background: var(--dark-card-bg);
            border-color: var(--dark-border);
            box-shadow: var(--dark-shadow);
        }
        .stat-card-title {
            font-size: 0.82rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: justify;
            gap: 8px;
            margin-bottom: 12px;
        }
        body.theme-light .stat-card-title { color: var(--light-text-muted); }
        body.theme-dark .stat-card-title { color: var(--dark-text-muted); }
        
        .stat-card-val {
            font-size: 2.1rem;
            font-weight: 900;
            font-family: 'Outfit', sans-serif;
            line-height: 1;
        }
        body.theme-light .stat-card-val { color: var(--light-text); }
        body.theme-dark .stat-card-val { color: var(--dark-text); }

        .trend-pill {
            font-size: 0.7rem;
            font-weight: 800;
            padding: 3px 8px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-family: 'Outfit', sans-serif;
            width: fit-content;
            margin-top: 8px;
        }
        .trend-up { background: #E8F8F5; color: #27AE60; }
        .trend-down { background: #FDE8E8; color: #E74C3C; }

        /* Digital Calendar widget */
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 12px;
        }
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
            text-align: center;
            font-size: 0.8rem;
        }
        .calendar-day-label {
            font-weight: 800;
            padding: 4px 0;
        }
        body.theme-light .calendar-day-label { color: var(--light-text-muted); }
        body.theme-dark .calendar-day-label { color: var(--dark-text-muted); }
        
        .calendar-day {
            padding: 6px 0;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        body.theme-light .calendar-day { color: var(--light-text); }
        body.theme-light .calendar-day:hover { background: var(--light-primary-light); }
        body.theme-dark .calendar-day { color: var(--dark-text); }
        body.theme-dark .calendar-day:hover { background: var(--dark-primary-light); }
        
        .calendar-day.active {
            color: white !important;
            font-weight: 800;
        }
        body.theme-light .calendar-day.active { background: var(--light-primary); }
        body.theme-dark .calendar-day.active { background: var(--dark-primary); }
        
        .calendar-day.muted {
            color: #BDC3C7;
        }

        /* Recent Activity Feed */
        .activity-item {
            display: flex;
            gap: 15px;
            margin-bottom: 18px;
            position: relative;
        }
        .activity-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 0.8rem;
            flex-shrink: 0;
        }
        .activity-details {
            font-size: 0.8rem;
            font-weight: 600;
            line-height: 1.4;
        }
        .activity-time {
            font-size: 0.72rem;
            margin-top: 2px;
        }
        body.theme-light .activity-time { color: var(--light-text-muted); }
        body.theme-dark .activity-time { color: var(--dark-text-muted); }

        /* Admin Launchpad Controls - POWER OVER EVERYTHING */
        .launchpad-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }
        .launchpad-card {
            border-radius: 18px;
            padding: 24px;
            border: 1px solid;
            text-decoration: none;
            color: inherit;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s;
        }
        body.theme-light .launchpad-card {
            background: #FFFFFF;
            border-color: var(--light-border);
            box-shadow: var(--light-shadow);
        }
        body.theme-light .launchpad-card:hover {
            transform: translateY(-3px);
            border-color: var(--light-primary);
            box-shadow: 0 10px 25px rgba(26, 111, 191, 0.1);
        }
        body.theme-dark .launchpad-card {
            background: #1F2937;
            border-color: var(--dark-border);
            box-shadow: var(--dark-shadow);
        }
        body.theme-dark .launchpad-card:hover {
            transform: translateY(-3px);
            border-color: var(--dark-accent);
            box-shadow: 0 10px 25px rgba(0, 230, 118, 0.15);
        }

        .launch-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: white;
            flex-shrink: 0;
            transition: all 0.3s;
        }
        body.theme-light .launch-icon { background: linear-gradient(135deg, var(--light-primary), var(--light-accent)); }
        body.theme-dark .launch-icon { background: linear-gradient(135deg, var(--dark-primary), var(--dark-accent)); }
        .launchpad-card:hover .launch-icon {
            transform: scale(1.08) rotate(5deg);
        }

        .launch-title {
            font-size: 1rem; font-weight: 800; margin: 0 0 4px 0;
        }
        .launch-desc {
            font-size: 0.78rem; margin: 0; line-height: 1.4;
        }
        body.theme-light .launch-desc { color: var(--light-text-muted); }
        body.theme-dark .launch-desc { color: var(--dark-text-muted); }

        /* Switch Mode Alert Banner */
        .mode-banner {
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            border: 1px solid;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        body.theme-light .mode-banner {
            background: #FFFFFF;
            border-color: var(--light-border);
        }
        body.theme-dark .mode-banner {
            background: #1C2128;
            border-color: var(--dark-border);
        }

        .btn-premium {
            background: linear-gradient(135deg, var(--light-primary) 0%, var(--light-primary-dark) 100%);
            color: white; border: none; border-radius: 12px;
            padding: 10px 20px; font-weight: 700; font-size: 0.9rem;
            box-shadow: 0 4px 15px rgba(26, 111, 191, 0.2);
            transition: all 0.3s; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 111, 191, 0.3);
            color: white;
        }

        .btn-premium-danger {
            background: linear-gradient(135deg, var(--danger) 0%, #C0392B 100%);
            box-shadow: 0 4px 15px rgba(231, 76, 60, 0.2);
        }
        .btn-premium-danger:hover {
            box-shadow: 0 6px 20px rgba(231, 76, 60, 0.3);
            color: white;
        }

        /* Map Embed Card */
        #embedMap {
            width: 100%;
            height: 250px;
            border-radius: 16px;
            border: 1px solid;
        }
        body.theme-light #embedMap { border-color: var(--light-border); }
        body.theme-dark #embedMap { border-color: var(--dark-border); }

        .pulse-dot {
            width: 12px; height: 12px; border-radius: 50%;
            display: inline-block; animation: pulse-ring 1.5s infinite;
        }
        .pulse-dot.danger { background: var(--danger); box-shadow: 0 0 10px var(--danger); }
        .pulse-dot.success { background: var(--success); box-shadow: 0 0 10px var(--success); }
        
        @@keyframes pulse-ring {
            0% { transform: scale(0.95); opacity: 0.4; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.4; }
        }
        
        @@keyframes heartBeat {
            0% { transform: scale(1); }
            14% { transform: scale(1.1); }
            28% { transform: scale(1); }
            42% { transform: scale(1.1); }
            70% { transform: scale(1); }
        }
    </style>
</head>
<body class="@(Model.IsCrisisModeActive ? "theme-dark" : "theme-light")">

    <!-- Navbar -->
    <nav class="admin-navbar">
        <div class="container-fluid d-flex align-items-center justify-content-between">
            <a href="/AdminDashboard" class="brand-section">
                <div class="brand-icon-box">
                    <i class="fas fa-shield-halved"></i>
                </div>
                <div>
                    <h1 class="brand-title">إطمن <span>الرعاية الذكية</span></h1>
                    <span class="brand-subtitle">نظام الإدارة والتحكم المركزي</span>
                </div>
            </a>

            <!-- Search box -->
            <div class="search-bar-container d-none d-md-block">
                <i class="fas fa-search position-absolute top-50 translate-middle-y" style="right: 15px; opacity:0.5;"></i>
                <input type="text" class="search-input" placeholder="بحث عن أطباء، مرضى، بلاغات..." />
            </div>

            <!-- Profile and Controls -->
            <div class="d-flex align-items-center gap-3">
                <span class="badge @(Model.IsCrisisModeActive ? "bg-danger" : "bg-primary") px-3 py-2 rounded-pill font-monospace" style="border: 1px solid rgba(255,255,255,0.2);">
                    <i class="fas fa-user-shield me-1"></i> مدير النظام
                </span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="container-fluid px-4 py-4">
        
        <!-- Dynamic Header Switch Banner -->
        <div class="mode-banner animate__animated animate__fadeIn">
            <div class="d-flex align-items-center gap-3">
                <span class="pulse-dot @(Model.IsCrisisModeActive ? "danger" : "success")"></span>
                <div>
                    <h2 class="h5 fw-900 m-0" style="font-weight: 800;">
                        @(Model.IsCrisisModeActive ? $"وضع الأزمات مفعّل حالياً: {Model.ActiveCrisisName}" : "النظام مستقر وفي الوضع العادي")
                    </h2>
                    <p class="small text-muted mb-0">يمكن للأدمن التبديل والتحكم بوضع الطوارئ بالمشروع لزيادة التعبئة وتوجيه عربات الإسعاف.</p>
                </div>
            </div>
            <div>
                <!-- Direct action to manage crises (switch mode) -->
                <a href="/AdminCrisis" class="btn-premium @(Model.IsCrisisModeActive ? "btn-premium-danger" : "")">
                    <i class="fas fa-shuffle"></i>
                    تعديل وضع الأزمات والأوبئة
                </a>
            </div>
        </div>

        <!-- Telemetry Counters Grid -->
        <div class="stats-grid animate__animated animate__fadeIn">
            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-users" style="color:var(--light-primary);"></i>
                        <span>إجمالي المستخدمين</span>
                    </div>
                    <div class="stat-card-val">@Model.TotalUsers</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +2.14% اليوم
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-user-md" style="color:var(--light-accent);"></i>
                        <span>الأطباء النشطين</span>
                    </div>
                    <div class="stat-card-val">@Model.ActiveDoctors</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +3.78% اليوم
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-hospital-user" style="color:var(--success);"></i>
                        <span>المرضى النشطين</span>
                    </div>
                    <div class="stat-card-val">@Model.ActivePatients</div>
                </div>
                <div class="trend-pill trend-down">
                    <i class="fas fa-arrow-trend-down"></i> -1.56% أمس
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-bell" style="color:var(--danger);"></i>
                        <span>حالات الطوارئ معلقة</span>
                    </div>
                    <div class="stat-card-val">@Model.PendingEmergencyRequests</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +1.64% اليوم
                </div>
            </div>
        </div>

        <!-- Middle Layout Row -->
        <div class="row g-4 mb-4">
            
            <!-- Center Section (Charts & Launchpad) -->
            <div class="col-lg-8">
                
                <!-- Graphic Telemetry Charts Card -->
                <div class="dashboard-card animate__animated animate__fadeInUp">
                    <h3 class="card-header-sm">
                        <i class="fas fa-chart-line text-primary me-2"></i>
                        نظرة عامة على Telemetry العمليات ومعدل التدهور الوبائي
                    </h3>

                    <!-- SVG Chart that dynamically updates styles -->
                    @if (Model.IsCrisisModeActive)
                    {
                        <!-- Futuristic Dark Crisis Chart (from Analytical tools image) -->
                        <div class="text-center py-2">
                            <span class="badge bg-danger rounded-pill px-3 py-1 mb-3">Temporal Trend Graphs</span>
                            <svg viewBox="0 0 600 200" width="100%" height="100%" style="background:transparent; border-radius:12px;">
                                <defs>
                                    <linearGradient id="cyanGrad" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#00B0FF" stop-opacity="0.4"/>
                                        <stop offset="100%" stop-color="#00B0FF" stop-opacity="0"/>
                                    </linearGradient>
                                    <linearGradient id="greenGrad" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#00E676" stop-opacity="0.4"/>
                                        <stop offset="100%" stop-color="#00E676" stop-opacity="0"/>
                                    </linearGradient>
                                </defs>
                                <grid stroke="#21262D" stroke-width="0.5"/>
                                <!-- Grid Lines -->
                                <line x1="0" y1="50" x2="600" y2="50" stroke="#21262D" stroke-dasharray="3,3" />
                                <line x1="0" y1="100" x2="600" y2="100" stroke="#21262D" stroke-dasharray="3,3" />
                                <line x1="0" y1="150" x2="600" y2="150" stroke="#21262D" stroke-dasharray="3,3" />
                                
                                <!-- Wave 1 -->
                                <path d="M 0 100 Q 150 40 300 120 T 600 80 L 600 200 L 0 200 Z" fill="url(#cyanGrad)" stroke="#00B0FF" stroke-width="2" />
                                <!-- Wave 2 -->
                                <path d="M 0 140 Q 150 80 300 150 T 600 120 L 600 200 L 0 200 Z" fill="url(#greenGrad)" stroke="#00E676" stroke-width="2" />
                                
                                <!-- Text labels -->
                                <text x="10" y="25" fill="#8B949E" font-size="8">معدل انتقال العدوى</text>
