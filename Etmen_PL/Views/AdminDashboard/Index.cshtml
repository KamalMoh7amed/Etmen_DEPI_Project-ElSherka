        </footer>

    </div>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <!-- Leaflet map integration script for crisis mode widget -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        $(document).ready(function() {
            function checkLiveAlerts(stats) {
                if (!stats || !Array.isArray(stats)) return;
                const highRiskGovs = stats
                    .filter(s => s.threatLevel === 'خطر مرتفع جداً')
                    .map(s => s.governorate);
                
                if (highRiskGovs.length > 0) {
                    $('#dangerGovNames').text(highRiskGovs.join('، '));
                    $('#liveAlertBanner').slideDown(300);
                } else {
                    $('#liveAlertBanner').slideUp(200);
                }
            }
            window.checkLiveAlerts = checkLiveAlerts;

            window.selectCalendarQuickFilter = function(filter) {
                const now = new Date();
                const year = now.getFullYear();
                const month = now.getMonth() + 1; // 1-indexed for backend
                
                if (filter === 'today') {
                    calMode = 'single';
                    $('#calendarModeBtn').removeClass('active').html('<i class="fas fa-calendar-week me-1"></i> نطاق');
                    selectedSingleDay = now.getDate();
                    rangeStart = null;
                    rangeEnd = null;
                    calMonth = now.getMonth();
                    calYear = now.getFullYear();
                    renderCalendar();
                    fetchDailyStats(year, month, selectedSingleDay);
                } else if (filter === 'week') {
                    calMode = 'range';
                    $('#calendarModeBtn').addClass('active').html('<i class="fas fa-calendar-day me-1"></i> يوم');
                    selectedSingleDay = null;
                    const weekAgo = new Date();
                    weekAgo.setDate(now.getDate() - 7);
                    
                    calMonth = now.getMonth();
                    calYear = now.getFullYear();
                    
                    rangeStart = weekAgo.getDate();
                    rangeEnd = now.getDate();
                    renderCalendar();
                    
                    const fromStr = `${weekAgo.getFullYear()}-${String(weekAgo.getMonth() + 1).padStart(2, '0')}-${String(weekAgo.getDate()).padStart(2, '0')}`;
                    const toStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
                    
                    const monthNames = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
                    $.getJSON('/AdminDashboard/GetRangeStats', { from: fromStr, to: toStr }, function(data) {
                        if (data && data.success) {
                            $('#statsPanelTitleText').text(`إحصائيات آخر ٧ أيام (${toArabicNum(rangeStart)} - ${toArabicNum(rangeEnd)} ${monthNames[calMonth]})`);
                            $('#statsEmergencies').text(data.emergencies);
                            $('#statsAppointments').text(data.appointments);
                            $('#statsDoctors').text(data.activeDoctors);
                            $('#statsBeds').text(data.totalBeds);
                            
                            const isCrisisMode = $('body').hasClass('theme-dark');
                            $('#statsSecondLabel').text(isCrisisMode ? 'الحالات الحرجة' : 'المواعيد المحجوزة');
                            
                            if ($('#dailyStatsPanel').is(':hidden')) {
                                $('#dailyStatsPanel').slideDown(300);
                            } else {
                                $('#dailyStatsPanel').removeClass('animate__fadeInRight').addClass('animate__pulse');
                                setTimeout(() => $('#dailyStatsPanel').removeClass('animate__pulse'), 500);
                            }
                        }
                    });
                } else if (filter === 'month') {
                    calMode = 'range';
                    $('#calendarModeBtn').addClass('active').html('<i class="fas fa-calendar-day me-1"></i> يوم');
                    selectedSingleDay = null;
                    
                    calMonth = now.getMonth();
                    calYear = now.getFullYear();
                    
                    rangeStart = 1;
                    rangeEnd = new Date(year, month, 0).getDate();
                    renderCalendar();
                    
                    fetchRangeStats(year, month, rangeStart, rangeEnd);
                }
            };

            // Initialize map centered on Cairo
            const map = L.map('embedMap', {
                zoomControl: true,
                attributionControl: false
            }).setView([30.0444, 31.2357], 11);

            const isDark = $('body').hasClass('theme-dark');
            const tileUrl = isDark 
                ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
                : 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png';

            L.tileLayer(tileUrl, {
                maxZoom: 20
            }).addTo(map);

            @if (Model.IsCrisisModeActive)
            {
                <text>
                // Add a mock pulsing crisis circle
                L.circle([30.0444, 31.2357], {
                    color: '#E74C3C',
                    fillColor: '#E74C3C',
                    fillOpacity: 0.25,
                    radius: 2000,
                    weight: 2
                }).addTo(map);
                </text>
            }
            else
            {
                <text>
                // Load normal mode markers asynchronously via API
                $.getJSON('/AdminDashboard/GetMapData', function(data) {
                    if (data && data.success) {
                        
                        // 1. Plot Healthcare Providers (Clinics & Hospitals)
                        data.providers.forEach(function(item) {
                            let color = item.type === 'Hospital' ? '#e74c3c' : '#3498db';
                            let markerHtml = `<div style="background-color: ${color}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.5);"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [12, 12],
                                iconAnchor: [6, 6]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>${item.name}</strong><br/>نوع المنشأة: ${item.type === 'Hospital' ? 'مستشفى' : 'عيادة'}<br/>العنوان: ${item.address || '-'}`)
                                .addTo(map);
                        });

                        // 2. Plot Registered Doctors
                        data.doctors.forEach(function(item) {
                            let markerHtml = `<div style="background-color: #2ecc71; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.5);"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [12, 12],
                                iconAnchor: [6, 6]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>د. ${item.name}</strong><br/>التخصص: ${item.specialization || '-'}<br/>رسوم الاستشارة: ${item.consultationFee || '-'} ج.م.`)
                                .addTo(map);
                        });

                        // 3. Plot Critical Cases (Emergency requests or critical risk assessments)
                        data.criticalCases.forEach(function(item) {
                            let markerHtml = `<div style="background-color: #f1c40f; width: 14px; height: 14px; border-radius: 50%; border: 2px solid red; box-shadow: 0 0 8px rgba(231, 76, 60, 0.8); animation: pulse 1.5s infinite;"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [14, 14],
                                iconAnchor: [7, 7]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>حالة طارئة: ${item.patientName}</strong><br/>النوع: ${item.emergencyType || '-'}<br/>التفاصيل: ${item.description || '-'}<br/>الأولوية: ${item.priorityScore}`)
                                .addTo(map);
                        });
                    }
                });
                </text>
            }

            // Load Normal Mode Charts
            @if (!Model.IsCrisisModeActive)
            {
                <text>
                $.getJSON('/AdminDashboard/GetDashboardProjectCharts', function(data) {
                    if (data && data.success) {
                        // 1. Resource Distribution
                        const resourceCtx = document.getElementById('resourceChart').getContext('2d');
                        new Chart(resourceCtx, {
                            type: 'doughnut',
                            data: {
                                labels: ['مستشفيات', 'عيادات', 'أطباء'],
                                datasets: [{
                                    data: [data.resourceDistribution.hospitals, data.resourceDistribution.clinics, data.resourceDistribution.doctors],
                                    backgroundColor: ['#e74c3c', '#3498db', '#2ecc71'],
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom',
                                        labels: { boxWidth: 10, font: { family: 'Tajawal', size: 9 } }
                                    }
                                }
                            }
                        });

                        // 2. Beds by Governorate
                        const bedsCtx = document.getElementById('bedsGovChart').getContext('2d');
                        new Chart(bedsCtx, {
                            type: 'bar',
                            data: {
                                labels: data.bedsByGov.map(b => b.governorate),
                                datasets: [{
                                    label: 'الأسرة الشاغرة',
                                    data: data.bedsByGov.map(b => b.beds),
                                    backgroundColor: 'rgba(26, 111, 191, 0.75)',
                                    borderColor: 'rgba(26, 111, 191, 1)',
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
