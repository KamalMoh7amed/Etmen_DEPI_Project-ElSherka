                }
            }

            // SignalR Connection for Real-Time Telemetry
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/queue")
                .withAutomaticReconnect()
                .build();

            connection.on("NewEmergencyRequest", function(request) {
                console.log("SignalR: New emergency request received.");
                reloadGovernorateRiskTable();
                reloadTelemetryStats();
                reloadRecentActivities();
                reloadStatsGrid();
                if (window.reloadDispatchMap) window.reloadDispatchMap();
            });

            connection.on("EmergencyRequestUpdated", function(update) {
                console.log("SignalR: Emergency request status updated.");
                reloadGovernorateRiskTable();
                reloadTelemetryStats();
                reloadRecentActivities();
                reloadStatsGrid();
                if (window.reloadDispatchMap) window.reloadDispatchMap();
            });

            connection.on("HospitalBedsUpdated", function(update) {
                console.log("SignalR: Hospital beds count updated.");
                reloadGovernorateRiskTable();
                reloadTelemetryStats();
                reloadRecentActivities();
                reloadStatsGrid();
                if (window.reloadDispatchMap) window.reloadDispatchMap();
            });

            connection.start().then(function() {
                console.log("SignalR connected to QueueHub in Admin Dashboard.");
            }).catch(function(err) {
                console.error("SignalR connection error in Admin Dashboard:", err);
            });
        });
    </script>
