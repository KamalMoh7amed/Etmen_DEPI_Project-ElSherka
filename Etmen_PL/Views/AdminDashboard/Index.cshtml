                    <div class="p-3 rounded-3 text-center" style="background:#eff6ff;border:1px solid #bfdbfe;">
                        <div class="fw-900" style="font-size:1.6rem;color:#3b82f6;" id="ambStatAvgEta">—</div>
                        <div class="text-muted small fw-700">متوسط ETA (دقيقة)</div>
