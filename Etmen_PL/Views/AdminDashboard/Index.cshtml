            <!-- Map -->
            <div class="position-relative">
                <div class="map-overlay-header">
                    <div class="overlay-icon"><i class="fas fa-star-of-life"></i></div>
                    <div class="overlay-details">
                        <div class="overlay-title">EMERGENCY MEDICAL DASHBOARD</div>
                        <div class="overlay-status"><span class="utc-clock">--:--:-- UTC</span> | <span class="live-indicator">LIVE</span></div>
                    </div>
                </div>
                <div id="globalAmbMap" style="height:450px;border-radius:16px;overflow:hidden;
                     border:2.5px solid @(Model.IsCrisisModeActive ? "#ef4444" : "#1e293b");
                     box-shadow:0 0 30px rgba(0, 240, 255, 0.15);"></div>
            </div>

            <!-- Dispatch table -->
            <div class="mt-3 table-responsive">
                <table class="table table-sm align-middle" style="font-size:.82rem;" id="globalDispatchTable">
                    <thead class="table-light">
                        <tr>
                            <th>المستشفى</th>
                            <th>المريض</th>
                            <th>نوع الطوارئ</th>
                            <th class="text-center">المسافة</th>
                            <th class="text-center">ETA</th>
                            <th class="text-center">الحالة</th>
                        </tr>
                    </thead>
                    <tbody id="globalDispatchBody">
                        <tr><td colspan="6" class="text-center text-muted py-3">
                            <i class="fas fa-spinner fa-spin me-1"></i> جاري تحميل بيانات الطوارئ النشطة...
