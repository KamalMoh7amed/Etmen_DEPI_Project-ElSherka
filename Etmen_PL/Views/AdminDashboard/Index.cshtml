                        <div class="fw-900" style="font-size:1.6rem;color:#ef4444;" id="ambStatTotal">—</div>
                        <div class="text-muted small fw-700">إجمالي طلبات نشطة</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="p-3 rounded-3 text-center" style="background:#fef9f2;border:1px solid #fde68a;">
                        <div class="fw-900" style="font-size:1.6rem;color:#f59e0b;" id="ambStatEnRoute">—</div>
                        <div class="text-muted small fw-700">إسعاف في الطريق</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="p-3 rounded-3 text-center" style="background:#f0fdf4;border:1px solid #bbf7d0;">
                        <div class="fw-900" style="font-size:1.6rem;color:#22c55e;" id="ambStatHospitals">—</div>
                        <div class="text-muted small fw-700">مستشفيات نشطة</div>
                    </div>
