@model Etmen_PL.Models.ViewModels.Admin.AdminDashboardViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لوحة القيادة والتحكم المركزي — إطمن</title>
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            /* Light Theme Palette (WellNest) */
            --light-bg: #F4F7F9;
            --light-card-bg: #FFFFFF;
            --light-border: #E2E8F0;
            --light-text: #2C3E50;
            --light-text-muted: #7F8C8D;
            --light-accent: #3cd5cb;
            --light-primary: #1A6FBF;
            --light-primary-dark: #125393;
            --light-primary-light: #E8F4FD;
            --light-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
            --light-gradient: linear-gradient(135deg, #1A6FBF 0%, #3cd5cb 100%);


            /* Dark Theme Palette (Crisis Analytical tools) */
            --dark-bg: #0B0E14;
            --dark-card-bg: #151A22;
            --dark-border: #21262D;
            --dark-text: #ECF0F1;
            --dark-text-muted: #8B949E;
            --dark-accent: #00E676;
            --dark-primary: #00B0FF;
            --dark-primary-light: rgba(0, 176, 255, 0.1);
            --dark-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);

            --danger: #E74C3C;
            --success: #27AE60;
            --warning: #F39C12;
        }

        body.theme-light .theme-input {
            background-color: #ffffff !important;
            border-color: var(--light-border) !important;
            color: var(--light-text) !important;
        }
        body.theme-dark .theme-input {
            background-color: #21262d !important;
            border-color: var(--dark-border) !important;
            color: var(--dark-text) !important;
        }
        body.theme-light .theme-input-group-text {
            background-color: #f8fafc !important;
            border-color: var(--light-border) !important;
            color: var(--light-text-muted) !important;
        }
        body.theme-dark .theme-input-group-text {
            background-color: #161b22 !important;
            border-color: var(--dark-border) !important;
            color: var(--dark-text-muted) !important;
        }

        body.theme-light .text-muted {
            color: var(--light-text-muted) !important;
        }
        body.theme-dark .text-muted {
            color: var(--dark-text-muted) !important;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            transition: all 0.5s ease-in-out;
        }

        /* ═══ THEME APPLIERS ═══════════════════════════════════ */
        body.theme-light {
            background-color: #f5f8fa;
            background-image: radial-gradient(circle at 0% 0%, rgba(26, 111, 191, 0.04) 0%, transparent 50%), radial-gradient(circle at 100% 100%, rgba(60, 213, 203, 0.04) 0%, transparent 50%);
            color: var(--light-text);
        }
        body.theme-dark {
            background-color: var(--dark-bg);
            color: var(--dark-text);
        }

        /* Navbars */
        .admin-navbar {
            padding: 0.9rem 2.5rem;
            border-bottom: 1px solid;
            transition: all 0.5s;
        }
        body.theme-light .admin-navbar {
            background: #FFFFFF;
            border-color: var(--light-border);
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
        }
        body.theme-dark .admin-navbar {
            background: #161B22;
            border-color: var(--dark-border);
            box-shadow: 0 4px 30px rgba(0,0,0,0.3);
        }

        .brand-section {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: inherit;
        }
        .brand-icon-box {
            width: 38px; height: 38px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.15rem;
            transition: all 0.5s;
        }
        body.theme-light .brand-icon-box {
            background: linear-gradient(135deg, var(--light-primary), var(--light-accent));
        }
        body.theme-dark .brand-icon-box {
            background: linear-gradient(135deg, var(--dark-primary), var(--dark-accent));
        }
        .brand-title {
            font-size: 1.4rem; font-weight: 900; margin: 0; line-height: 1;
        }
        .brand-subtitle {
            font-size: 0.65rem; display: block; font-weight: 500; margin-top: 2px;
        }
        body.theme-light .brand-title span { color: var(--light-primary); }
        body.theme-dark .brand-title span { color: var(--dark-accent); }
        body.theme-light .brand-subtitle { color: var(--light-text-muted); }
        body.theme-dark .brand-subtitle { color: var(--dark-text-muted); }

        /* Search input from WellNest */
        .search-bar-container {
            position: relative;
            width: 300px;
        }
        .search-input {
            width: 100%;
            border-radius: 12px;
            padding: 8px 16px 8px 40px;
            font-size: 0.85rem;
            border: 1px solid;
            outline: none;
            transition: all 0.3s;
        }
        body.theme-light .search-input {
            background: #F0F4F8;
            border-color: transparent;
            color: var(--light-text);
        }
        body.theme-light .search-input:focus {
            background: white;
            border-color: var(--light-primary);
        }
        body.theme-dark .search-input {
            background: #21262D;
            border-color: transparent;
            color: var(--dark-text);
        }
        body.theme-dark .search-input:focus {
            background: #161B22;
            border-color: var(--dark-primary);
        }

        /* Cards */
        .dashboard-card {
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
        }
        body.theme-light .dashboard-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-color: rgba(226, 232, 240, 0.8);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        }
        body.theme-light .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(26, 111, 191, 0.06);
            border-color: rgba(26, 111, 191, 0.15);
        }
        body.theme-dark .dashboard-card {
            background: rgba(21, 26, 34, 0.85);
            backdrop-filter: blur(12px);
            border-color: rgba(231, 76, 60, 0.2);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }
        body.theme-dark .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(231, 76, 60, 0.12);
            border-color: rgba(231, 76, 60, 0.45);
        }

        .card-header-sm {
            display: flex;
            justify-content: justify;
            align-items: center;
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 18px;
        }
        body.theme-light .card-header-sm { color: var(--light-text); }
        body.theme-dark .card-header-sm { color: var(--dark-text); }

        /* Stats Blocks */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }
        .stat-card {
            border-radius: 20px;
            padding: 24px;
            border: 1px solid;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all 0.3s;
        }
        body.theme-light .stat-card {
            background: rgba(255, 255, 255, 0.9);
            border-color: rgba(226, 232, 240, 0.8);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.02);
        }
        body.theme-light .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(26, 111, 191, 0.08);
            border-color: rgba(26, 111, 191, 0.2);
        }
        body.theme-dark .stat-card {
            background: rgba(21, 26, 34, 0.9);
            border-color: rgba(33, 38, 45, 0.8);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
            transition: all 0.3s ease;
        }
        body.theme-dark .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(231, 76, 60, 0.15);
            border-color: rgba(231, 76, 60, 0.4);
        }
        .stat-card-title {
            font-size: 0.82rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: justify;
            gap: 8px;
            margin-bottom: 12px;
        }
        body.theme-light .stat-card-title { color: var(--light-text-muted); }
        body.theme-dark .stat-card-title { color: var(--dark-text-muted); }
        
        .stat-card-val {
            font-size: 2.1rem;
            font-weight: 900;
            font-family: 'Outfit', sans-serif;
            line-height: 1;
        }
        body.theme-light .stat-card-val { color: var(--light-text); }
        body.theme-dark .stat-card-val { color: var(--dark-text); }

        .trend-pill {
            font-size: 0.7rem;
            font-weight: 800;
            padding: 3px 8px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-family: 'Outfit', sans-serif;
            width: fit-content;
            margin-top: 8px;
        }
        .trend-up { background: #E8F8F5; color: #27AE60; }
        .trend-down { background: #FDE8E8; color: #E74C3C; }

        /* Digital Calendar widget */
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 12px;
        }
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
            text-align: center;
            font-size: 0.8rem;
        }
        .calendar-day-label {
            font-weight: 800;
            padding: 4px 0;
        }
        body.theme-light .calendar-day-label { color: var(--light-text-muted); }
        body.theme-dark .calendar-day-label { color: var(--dark-text-muted); }
        
        .calendar-day {
            padding: 6px 0;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        body.theme-light .calendar-day { color: var(--light-text); }
        body.theme-light .calendar-day:hover { background: var(--light-primary-light); }
        body.theme-dark .calendar-day { color: var(--dark-text); }
        body.theme-dark .calendar-day:hover { background: var(--dark-primary-light); }
        
        .calendar-day.active {
            color: white !important;
            font-weight: 800;
        }
        body.theme-light .calendar-day.active { background: var(--light-primary); }
        body.theme-dark .calendar-day.active { background: var(--dark-primary); }
        
        .calendar-day.muted {
            color: #BDC3C7;
        }

        /* Calendar range selection */
        .calendar-day.range-start {
            color: white !important;
            font-weight: 800;
            border-radius: 8px 0 0 8px;
        }
        body.theme-light .calendar-day.range-start { background: var(--light-primary); }
        body.theme-dark .calendar-day.range-start { background: var(--dark-primary); }
        .calendar-day.range-end {
            color: white !important;
            font-weight: 800;
            border-radius: 0 8px 8px 0;
        }
        body.theme-light .calendar-day.range-end { background: var(--light-primary); }
        body.theme-dark .calendar-day.range-end { background: var(--dark-primary); }
        .calendar-day.in-range {
            border-radius: 0;
        }
        body.theme-light .calendar-day.in-range { background: rgba(26, 111, 191, 0.15); color: var(--light-primary) !important; }
        body.theme-dark .calendar-day.in-range { background: rgba(0, 176, 255, 0.15); color: var(--dark-primary) !important; }
        .calendar-mode-toggle {
            font-size: 0.7rem;
            padding: 3px 10px;
            border-radius: 20px;
            cursor: pointer;
            border: 1px solid;
            transition: all 0.3s;
            font-weight: 700;
        }
        body.theme-light .calendar-mode-toggle { border-color: var(--light-primary); color: var(--light-primary); background: transparent; }
        body.theme-light .calendar-mode-toggle:hover, body.theme-light .calendar-mode-toggle.active { background: var(--light-primary); color: white; }
        body.theme-dark .calendar-mode-toggle { border-color: var(--dark-primary); color: var(--dark-primary); background: transparent; }
        body.theme-dark .calendar-mode-toggle:hover, body.theme-dark .calendar-mode-toggle.active { background: var(--dark-primary); color: white; }

        /* Recent Activity Feed */
        .activity-item {
            display: flex;
            gap: 15px;
            margin-bottom: 18px;
            position: relative;
        }
        .activity-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 0.8rem;
            flex-shrink: 0;
        }
        .activity-details {
            font-size: 0.8rem;
            font-weight: 600;
            line-height: 1.4;
        }
        /* Theme-aware activity name text */
        body.theme-light .activity-name { color: var(--light-text); }
        body.theme-dark .activity-name { color: var(--dark-text); }
        .activity-time {
            font-size: 0.72rem;
            margin-top: 2px;
        }
        body.theme-light .activity-time { color: var(--light-text-muted); }
        body.theme-dark .activity-time { color: var(--dark-text-muted); }

        /* Admin Launchpad Controls - POWER OVER EVERYTHING */
        .launchpad-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }
        .launchpad-card {
            border-radius: 18px;
            padding: 24px;
            border: 1px solid;
            text-decoration: none;
            color: inherit;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s;
        }
        body.theme-light .launchpad-card {
            background: #FFFFFF;
            border-color: var(--light-border);
            box-shadow: var(--light-shadow);
        }
        body.theme-light .launchpad-card:hover {
            transform: translateY(-3px);
            border-color: var(--light-primary);
            box-shadow: 0 10px 25px rgba(26, 111, 191, 0.1);
        }
        body.theme-dark .launchpad-card {
            background: #1F2937;
            border-color: var(--dark-border);
            box-shadow: var(--dark-shadow);
        }
        body.theme-dark .launchpad-card:hover {
            transform: translateY(-3px);
            border-color: var(--dark-accent);
            box-shadow: 0 10px 25px rgba(0, 230, 118, 0.15);
        }

        .launch-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: white;
            flex-shrink: 0;
            transition: all 0.3s;
        }
        body.theme-light .launch-icon { background: linear-gradient(135deg, var(--light-primary), var(--light-accent)); }
        body.theme-dark .launch-icon { background: linear-gradient(135deg, var(--dark-primary), var(--dark-accent)); }
        .launchpad-card:hover .launch-icon {
            transform: scale(1.08) rotate(5deg);
        }

        .launch-title {
            font-size: 1rem; font-weight: 800; margin: 0 0 4px 0;
        }
        .launch-desc {
            font-size: 0.78rem; margin: 0; line-height: 1.4;
        }
        body.theme-light .launch-desc { color: var(--light-text-muted); }
        body.theme-dark .launch-desc { color: var(--dark-text-muted); }

        /* Switch Mode Alert Banner */
        .mode-banner {
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            border: 1px solid;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        body.theme-light .mode-banner {
            background: #FFFFFF;
            border-color: var(--light-border);
        }
        body.theme-dark .mode-banner {
            background: #1C2128;
            border-color: var(--dark-border);
        }

        .btn-premium {
            background: linear-gradient(135deg, var(--light-primary) 0%, var(--light-primary-dark) 100%);
            color: white; border: none; border-radius: 12px;
            padding: 10px 20px; font-weight: 700; font-size: 0.9rem;
            box-shadow: 0 4px 15px rgba(26, 111, 191, 0.2);
            transition: all 0.3s; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 111, 191, 0.3);
            color: white;
        }

        .btn-premium-danger {
            background: linear-gradient(135deg, var(--danger) 0%, #C0392B 100%);
            box-shadow: 0 4px 15px rgba(231, 76, 60, 0.2);
        }
        .btn-premium-danger:hover {
            box-shadow: 0 6px 20px rgba(231, 76, 60, 0.3);
            color: white;
        }

        /* Map Embed Card */
        #embedMap {
            width: 100%;
            height: 250px;
            border-radius: 16px;
            border: 1px solid;
        }
        body.theme-light #embedMap { border-color: var(--light-border); }
        body.theme-dark #embedMap { border-color: var(--dark-border); }

        body.theme-dark .bg-dark-glass {
            background: rgba(18, 22, 31, 0.85);
            backdrop-filter: blur(10px);
        }

        /* Daily Stats Panel CSS adaptive styling */
        body.theme-light #dailyStatsPanel {
            border-color: var(--light-primary) !important;
            background: linear-gradient(135deg, #ffffff, #f7fafc) !important;
        }
        body.theme-light #dailyStatsPanel .theme-box {
            background-color: #ffffff !important;
            border-color: #e2e8f0 !important;
        }
        body.theme-light .text-primary-theme {
            color: var(--light-primary) !important;
        }
        body.theme-light #dailyStatsPanel strong.text-primary-theme {
            color: var(--light-primary) !important;
        }

        body.theme-dark #dailyStatsPanel {
            border-color: rgba(231, 76, 60, 0.35) !important;
            background: linear-gradient(135deg, #151a22, #1c2330) !important;
            color: #ffffff !important;
        }
        body.theme-dark #dailyStatsPanel .theme-box {
            background-color: #0b0e14 !important;
            border-color: rgba(231, 76, 60, 0.2) !important;
        }
        body.theme-dark .text-primary-theme {
            color: #ff5252 !important;
        }
        body.theme-dark #dailyStatsPanel strong.text-primary-theme {
            color: #00b0ff !important;
        }

        .pulse-dot {
            width: 12px; height: 12px; border-radius: 50%;
            display: inline-block; animation: pulse-ring 1.5s infinite;
        }
        .pulse-dot.danger { background: var(--danger); box-shadow: 0 0 10px var(--danger); }
        .pulse-dot.success { background: var(--success); box-shadow: 0 0 10px var(--success); }
        
        @@keyframes pulse-ring {
            0% { transform: scale(0.95); opacity: 0.4; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.4; }
        }
        
        @@keyframes heartBeat {
            0% { transform: scale(1); }
            14% { transform: scale(1.1); }
            28% { transform: scale(1); }
            42% { transform: scale(1.1); }
            70% { transform: scale(1); }
        }
    </style>
</head>
<body class="@(Model.IsCrisisModeActive ? "theme-dark" : "theme-light")">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center py-2 px-3 fw-bold m-0 border-0 rounded-0" style="z-index: 9999; font-size: 0.95rem; background-color: #2ec4b6; color: white;">
            <i class="fas fa-check-circle me-1"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center py-2 px-3 fw-bold m-0 border-0 rounded-0" style="z-index: 9999; font-size: 0.95rem; background-color: #e74c3c; color: white;">
            <i class="fas fa-exclamation-triangle me-1"></i> @TempData["Error"]
        </div>
    }

    <!-- Top Live Alert Banner -->
    <div id="liveAlertBanner" class="bg-danger text-white text-center py-2 px-3 fw-bold" style="display: none; z-index: 9999; font-size: 0.95rem; border-bottom: 2px solid white; animation: pulse 2s infinite;">
        <span class="d-flex align-items-center justify-content-center gap-2">
            <i class="fas fa-triangle-exclamation animate__animated animate__swing animate__infinite me-1"></i>
            تحذير صحي عاجل: تم رصد مستوى (خطر مرتفع جداً) في المحافظات التالية: 
            <span id="dangerGovNames" class="badge bg-white text-danger px-2 py-1 mx-2" style="font-size:0.85rem; font-weight:800;"></span>
            - يرجى توجيه عربات الإسعاف وتفعيل فرز الطوارئ فوراً.
        </span>
    </div>

    <!-- Navbar -->
    <nav class="admin-navbar">
        <div class="container-fluid d-flex align-items-center justify-content-between">
            <a href="/AdminDashboard" class="brand-section">
                <div class="brand-icon-box">
                    <i class="fas fa-shield-halved"></i>
                </div>
                <div>
                    <h1 class="brand-title">إطمن <span>الرعاية الذكية</span></h1>
                    <span class="brand-subtitle">نظام الإدارة والتحكم المركزي</span>
                </div>
            </a>

            <!-- Search box -->
            <div class="search-bar-container d-none d-md-block">
                <i class="fas fa-search position-absolute top-50 translate-middle-y" style="right: 15px; opacity:0.5;"></i>
                <input type="text" class="search-input" placeholder="بحث عن أطباء، مرضى، بلاغات..." />
            </div>

            <!-- Profile and Controls -->
            <div class="d-flex align-items-center gap-3">
                <span class="badge @(Model.IsCrisisModeActive ? "bg-danger" : "bg-primary") px-3 py-2 rounded-pill font-monospace" style="border: 1px solid rgba(255,255,255,0.2);">
                    <i class="fas fa-user-shield me-1"></i> مدير النظام
                </span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="container-fluid px-4 py-4">
        
        <!-- Dynamic Header Switch Banner -->
        <div class="mode-banner animate__animated animate__fadeIn">
            <div class="d-flex align-items-center gap-3">
                <span class="pulse-dot @(Model.IsCrisisModeActive ? "danger" : "success")"></span>
                <div>
                    <h2 class="h5 fw-900 m-0" style="font-weight: 800;">
                        @(Model.IsCrisisModeActive ? $"وضع الأزمات مفعّل حالياً: {Model.ActiveCrisisName}" : "النظام مستقر وفي الوضع العادي")
                    </h2>
                    <p class="small text-muted mb-0">يمكن للأدمن التبديل والتحكم بوضع الطوارئ بالمشروع لزيادة التعبئة وتوجيه عربات الإسعاف.</p>
                </div>
            </div>
            <div>
                <!-- Direct action to manage crises (switch mode) -->
                <a href="/AdminCrisis" class="btn-premium @(Model.IsCrisisModeActive ? "btn-premium-danger" : "")">
                    <i class="fas fa-shuffle"></i>
                    تعديل وضع الأزمات والأوبئة
                </a>
            </div>
        </div>

        <!-- Telemetry Counters Grid -->
        <div class="stats-grid animate__animated animate__fadeIn" id="adminStatsGrid">
            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-users" style="color:var(--light-primary);"></i>
                        <span>إجمالي المستخدمين</span>
                    </div>
                    <div class="stat-card-val">@Model.TotalUsers</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +2.14% اليوم
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-user-md" style="color:var(--light-accent);"></i>
                        <span>الأطباء النشطين</span>
                    </div>
                    <div class="stat-card-val">@Model.ActiveDoctors</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +3.78% اليوم
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-hospital-user" style="color:var(--success);"></i>
                        <span>المرضى النشطين</span>
                    </div>
                    <div class="stat-card-val">@Model.ActivePatients</div>
                </div>
                <div class="trend-pill trend-down">
                    <i class="fas fa-arrow-trend-down"></i> -1.56% أمس
                </div>
            </div>

            <div class="stat-card">
                <div>
                    <div class="stat-card-title">
                        <i class="fas fa-bell" style="color:var(--danger);"></i>
                        <span>حالات الطوارئ معلقة</span>
                    </div>
                    <div class="stat-card-val">@Model.PendingEmergencyRequests</div>
                </div>
                <div class="trend-pill trend-up">
                    <i class="fas fa-arrow-trend-up"></i> +1.64% اليوم
                </div>
            </div>
        </div>

        <!-- Middle Layout Row -->
        <div class="row g-4 mb-4">
            
            <!-- Center Section (Charts & Launchpad) -->
            <div class="col-lg-8">
                
                <!-- Graphic Telemetry Charts Card -->
                <div class="dashboard-card animate__animated animate__fadeInUp">
                    <h3 class="card-header-sm">
                        <i class="fas fa-chart-line text-primary me-2"></i>
                        نظرة عامة على Telemetry العمليات ومعدل التدهور الوبائي
                    </h3>

                    <!-- SVG Chart that dynamically updates styles -->
                    @if (Model.IsCrisisModeActive)
                    {
                        <!-- Complex Crisis Mode Charts Grid -->
                        <div class="row g-3 py-2">
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-dark-glass shadow-lg" style="border-color: rgba(231, 76, 60, 0.25);">
                                    <h4 class="h6 text-center mb-3 fw-bold text-danger animate__animated animate__pulse animate__infinite" style="font-size: 0.82rem;">
                                        <i class="fas fa-biohazard me-1 animate-spin"></i> تفشي الوباء بالمحافظات
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="crisisOutbreakChart"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-dark-glass shadow-lg" style="border-color: rgba(231, 76, 60, 0.25);">
                                    <h4 class="h6 text-center mb-3 fw-bold text-warning" style="font-size: 0.82rem;">
                                        <i class="fas fa-stethoscope me-1"></i> الأعراض الأكثر انتشاراً
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="crisisSymptomsChart"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-dark-glass shadow-lg" style="border-color: rgba(231, 76, 60, 0.25);">
                                    <h4 class="h6 text-center mb-3 fw-bold text-info" style="font-size: 0.82rem;">
                                        <i class="fas fa-chart-line me-1"></i> معدل التدهور الوبائي الأسبوعي
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="crisisTrendsChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Complex Normal Mode Charts Grid -->
                        <div class="row g-3 py-2">
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-white shadow-sm">
                                    <h4 class="h6 text-center mb-3 fw-bold text-dark" style="font-size: 0.82rem;">
                                        <i class="fas fa-chart-pie text-primary me-1"></i> توزيع الموارد الطبية
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="resourceChart"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-white shadow-sm">
                                    <h4 class="h6 text-center mb-3 fw-bold text-dark" style="font-size: 0.82rem;">
                                        <i class="fas fa-chart-bar text-success me-1"></i> سعة الأسرة بالمحافظات
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="bedsGovChart"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="chart-container-wrapper p-3 border rounded-3 bg-white shadow-sm">
                                    <h4 class="h6 text-center mb-3 fw-bold text-dark" style="font-size: 0.82rem;">
                                        <i class="fas fa-chart-line text-warning me-1"></i> حجز المواعيد الأسبوعي
                                    </h4>
                                    <div style="position: relative; height: 160px; width: 100%;">
                                        <canvas id="appointmentsTrendChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Admin Launchpad Controls (POWER OVER EVERYTHING) -->
                <div class="dashboard-card animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
                    <h3 class="card-header-sm">
                        <i class="fas fa-toolbox text-primary me-2"></i>
                        لوحة التحكم الشاملة والعمليات الطبية (Control Center)
                    </h3>
                    
                    <div class="launchpad-grid">
                        @if (Model.IsCrisisModeActive)
                        {
                            <!-- Outbreak Heatmap -->
                            <a href="/AdminCrisis/Heatmap" class="launchpad-card">
                                <div class="launch-icon bg-danger">
                                    <i class="fas fa-map-location-dot"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-danger">خريطة البؤر الوبائية التفاعلية</h4>
                                    <p class="launch-desc">عرض ورصد جغرافي حي لمدن انتشار الفيروس ومعدلات انتقال العدوى ومواقع المرضى.</p>
                                </div>
                            </a>

                            <!-- Command Center -->
                            <a href="/AdminCrisis/CommandCenter" class="launchpad-card">
                                <div class="launch-icon bg-danger">
                                    <i class="fas fa-tower-observation"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-danger">مركز العمليات وإدارة الأزمات</h4>
                                    <p class="launch-desc">مراقبة الـ Telemetry، حساب أوقات انتظار عربات الإسعاف ومعدل استجابة المستشفيات.</p>
                                </div>
                            </a>

                            <!-- Crisis Settings -->
                            <a href="/AdminCrisis" class="launchpad-card">
                                <div class="launch-icon bg-danger">
                                    <i class="fas fa-viruses"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-danger">إعدادات الأوبئة والأعراض</h4>
                                    <p class="launch-desc">تعديل أوزان الأعراض (Symptom Weights)، تعيين عتبات المخاطر والتحكم بتفعيل الأزمات.</p>
                                </div>
                            </a>

                            <!-- Maintenance Settings -->
                            <a href="#" class="launchpad-card" data-bs-toggle="modal" data-bs-target="#maintenanceSettingsModal">
                                <div class="launch-icon" style="background:#f39c12;color:white;">
                                    <i class="fas fa-toolbox"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-warning">التحكم في وضع الصيانة</h4>
                                    <p class="launch-desc">تفعيل/إلغاء وضع الصيانة للمرضى وموظفي المستشفيات، وكتابة رسائل التنبيه والتحكم بالقفل.</p>
                                </div>
                            </a>
                        }
                        else
                        {
                            <!-- Normal Mode Map Link -->
                            <a href="/AdminDashboard/NormalMap" class="launchpad-card">
                                <div class="launch-icon bg-primary">
                                    <i class="fas fa-map-location-dot"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-primary">خريطة المراكز الطبية والموارد الشاملة</h4>
                                    <p class="launch-desc">عرض تفاعلي متكامل لجميع المستشفيات، العيادات، الأطباء، وحالات الطوارئ الميدانية.</p>
                                </div>
                            </a>

                            <!-- Providers manager -->
                            <a href="/AdminProviders" class="launchpad-card">
                                <div class="launch-icon bg-primary">
                                    <i class="fas fa-hospital"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-primary">مقدمي الخدمات والمستشفيات</h4>
                                    <p class="launch-desc">مراجعة المستشفيات والعيادات، واعتماد تراخيصهم ومراقبة سعة الأسرة الشاغرة لديهم.</p>
                                </div>
                            </a>

                            <!-- Users manager -->
                            <a href="/AdminUsers" class="launchpad-card">
                                <div class="launch-icon bg-primary">
                                    <i class="fas fa-users-gear"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-primary">الحسابات والكوادر الطبية</h4>
                                    <p class="launch-desc">تأكيد هويات الأطباء، مراجعة تصاريح مزاولة المهنة وتوزيع صلاحيات طواقم المستشفيات.</p>
                                </div>
                            </a>

                            <!-- Reports manager -->
                            <a href="/AdminReports" class="launchpad-card">
                                <div class="launch-icon bg-primary">
                                    <i class="fas fa-chart-pie"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-primary">سجلات النظام والتقارير الذكية</h4>
                                    <p class="launch-desc">توليد تقارير أداء الكادر الطبي، إحصائيات العدوى وسجلات الاستجابة للحالات الحرجة.</p>
                                </div>
                            </a>

                            <!-- Maintenance Settings -->
                            <a href="#" class="launchpad-card" data-bs-toggle="modal" data-bs-target="#maintenanceSettingsModal">
                                <div class="launch-icon" style="background:#1A6FBF;color:white;">
                                    <i class="fas fa-toolbox"></i>
                                </div>
                                <div>
                                    <h4 class="launch-title text-primary">التحكم في وضع الصيانة</h4>
                                    <p class="launch-desc">تفعيل/إلغاء وضع الصيانة للمرضى وموظفي المستشفيات، وكتابة رسائل التنبيه والتحكم بالقفل.</p>
                                </div>
                            </a>
                        }
                    </div>
                </div>

            </div>

            <!-- Right Section (Calendar & Activity Widgets) -->
            <div class="col-lg-4">
                
                <!-- Dynamic Digital Calendar Widget -->
                <div class="dashboard-card animate__animated animate__fadeInRight">
                    <div class="calendar-header">
                        <span id="calendarMonthLabel"></span>
                        <div class="d-flex gap-2 align-items-center">
                            <button id="calendarModeBtn" class="calendar-mode-toggle" title="تبديل وضع النطاق">
                                <i class="fas fa-calendar-week me-1"></i> نطاق
                            </button>
                            <button id="calendarPrev" class="btn btn-xs btn-light rounded-circle" style="padding: 2px 7px;"><i class="fas fa-chevron-right text-muted" style="font-size:0.75rem;"></i></button>
                            <button id="calendarNext" class="btn btn-xs btn-light rounded-circle" style="padding: 2px 7px;"><i class="fas fa-chevron-left text-muted" style="font-size:0.75rem;"></i></button>
                        </div>
                    </div>
                    <div id="calendarGrid" class="calendar-grid">
                        <!-- Rendered dynamically by JS -->
                    </div>
                    <div class="d-flex gap-1 justify-content-between mt-3" style="font-size: 0.72rem;">
                        <button type="button" class="btn btn-xs btn-outline-primary w-100 rounded-pill px-1 py-1" onclick="selectCalendarQuickFilter('today')">اليوم</button>
                        <button type="button" class="btn btn-xs btn-outline-primary w-100 rounded-pill px-1 py-1" onclick="selectCalendarQuickFilter('week')">آخر 7 أيام</button>
                        <button type="button" class="btn btn-xs btn-outline-primary w-100 rounded-pill px-1 py-1" onclick="selectCalendarQuickFilter('month')">الشهر الحالي</button>
                    </div>
                </div>

                <!-- Interactive Calendar Stats Panel -->
                <div id="dailyStatsPanel" class="dashboard-card animate__animated animate__fadeInRight mt-3" style="display:none;">
                    <h4 id="statsPanelTitle" class="card-header-sm mb-3 text-primary-theme" style="font-size: 0.92rem;">
                        <i class="fas fa-calendar-check me-1"></i> <span id="statsPanelTitleText">إحصائيات اليوم</span>
                    </h4>
                    <div class="row g-2 text-center" style="font-size: 0.82rem;">
                        <div class="col-6">
                            <div class="p-2 border rounded theme-box">
                                <small class="text-muted d-block">حالات الطوارئ</small>
                                <strong id="statsEmergencies" class="text-danger h5 m-0 d-block font-monospace mt-1">0</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 border rounded theme-box">
                                <small id="statsSecondLabel" class="text-muted d-block">المواعيد المحجوزة</small>
                                <strong id="statsAppointments" class="text-primary-theme h5 m-0 d-block font-monospace mt-1">0</strong>
                            </div>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="p-2 border rounded theme-box">
                                <small class="text-muted d-block">الأطباء النشطين</small>
                                <strong id="statsDoctors" class="text-success h5 m-0 d-block font-monospace mt-1">0</strong>
                            </div>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="p-2 border rounded theme-box">
                                <small class="text-muted d-block">إجمالي الأسرة المتاحة</small>
                                <strong id="statsBeds" class="text-warning h5 m-0 d-block font-monospace mt-1">0</strong>
                            </div>
                        </div>
                    </div>
                </div>

                    <!-- Outbreak Settings Panel -->
                    <div class="dashboard-card animate__animated animate__fadeInRight mt-3">
                        <h4 class="card-header-sm mb-3 text-danger" style="font-size: 0.95rem;">
                            <i class="fas fa-sliders-h me-1"></i> معايير تجميع البؤر الوبائية
                        </h4>
                        <form action="/AdminCrisis/SaveOutbreakSettings" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label small text-muted">نصف قطر التجميع الجغرافي (كم):</label>
                                <div class="input-group">
                                    <span class="input-group-text theme-input-group-text" style="border-radius: 0 8px 8px 0;"><i class="fas fa-expand-arrows-alt"></i></span>
                                    <input type="number" step="0.5" name="radius" class="form-control theme-input" style="border-radius: 8px 0 0 8px;" value="@(Etmen_BLL.Helpers.OutbreakSettingsHelper.ClusteringRadiusKm)" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted">الحد الأدنى من الحالات لتكوين بؤرة صفراء (خطورة متوسطة):</label>
                                <div class="input-group">
                                    <span class="input-group-text theme-input-group-text" style="border-radius: 0 8px 8px 0;"><i class="fas fa-head-side-cough"></i></span>
                                    <input type="number" name="minCases" class="form-control theme-input" style="border-radius: 8px 0 0 8px;" value="@(Etmen_BLL.Helpers.OutbreakSettingsHelper.MinCasesPerZone)" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted">الحد الأدنى من الحالات لتكوين بؤرة برتقالية (خطورة عالية):</label>
                                <div class="input-group">
                                    <span class="input-group-text theme-input-group-text" style="border-radius: 0 8px 8px 0;"><i class="fas fa-exclamation-triangle"></i></span>
                                    <input type="number" name="highRiskCases" class="form-control theme-input" style="border-radius: 8px 0 0 8px;" value="@(Etmen_BLL.Helpers.OutbreakSettingsHelper.HighRiskThresholdCases)" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted">الحد الأدنى من الحالات لتكوين بؤرة حمراء (خطورة طارئة):</label>
                                <div class="input-group">
                                    <span class="input-group-text theme-input-group-text" style="border-radius: 0 8px 8px 0;"><i class="fas fa-biohazard"></i></span>
                                    <input type="number" name="emergencyCases" class="form-control theme-input" style="border-radius: 8px 0 0 8px;" value="@(Etmen_BLL.Helpers.OutbreakSettingsHelper.EmergencyRiskThresholdCases)" required />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-sm btn-danger w-100 rounded-pill py-2 fw-bold">
                                <i class="fas fa-sync-alt me-1"></i> حفظ وتحديث معايير البؤر
                            </button>
                        </form>
                    </div>

                <!-- Recent Activity Feed (Real Data via AJAX) -->
                <div class="dashboard-card animate__animated animate__fadeInRight" style="animation-delay: 0.1s;">
                    <h3 class="card-header-sm" style="font-size: 1rem; margin-bottom: 20px;">
                        <i class="fas fa-bolt text-warning me-2"></i>
                        سجل النشاطات الفورية للنظام
                    </h3>
                    <div id="activityFeed" class="d-flex flex-column">
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-spinner fa-spin me-1"></i> جاري تحميل النشاطات...
                        </div>
                    </div>
                </div>

                <!-- Leaflet interactive mini-map widget -->
                <div class="dashboard-card animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                    <h3 class="card-header-sm" style="font-size: 0.95rem; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                        @if (Model.IsCrisisModeActive)
                        {
                            <i class="fas fa-map-location-dot text-danger animate-pulse"></i>
                            <span class="text-danger">خريطة البؤر المصابة المصغرة (Crisis Map)</span>
                        }
                        else
                        {
                            <i class="fas fa-map-location-dot text-primary"></i>
                            <span>خريطة المراكز والحالات النشطة (Normal Mode Map)</span>
                        }
                    </h3>
                    <div id="embedMap" style="cursor: pointer;" onclick="window.location.href='@(Model.IsCrisisModeActive ? "/AdminCrisis/Heatmap" : "/AdminDashboard/NormalMap")'"></div>
                    <div class="text-center mt-3">
                        @if (Model.IsCrisisModeActive)
                        {
                            <a href="/AdminCrisis/Heatmap" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                <i class="fas fa-expand-arrows-alt"></i> عرض خريطة الأزمات بكامل الشاشة
                            </a>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-items-center gap-2">
                                <span class="text-muted small">
                                    <span class="ms-2"><i class="fas fa-circle" style="color: #e74c3c; font-size: 0.8rem;"></i> مستشفى</span>
                                    <span class="ms-2"><i class="fas fa-circle" style="color: #3498db; font-size: 0.8rem;"></i> عيادة</span>
                                    <span class="ms-2"><i class="fas fa-circle" style="color: #2ecc71; font-size: 0.8rem;"></i> طبيب</span>
                                    <span class="ms-2"><i class="fas fa-circle" style="color: #f1c40f; font-size: 0.8rem;"></i> حالة طارئة</span>
                                </span>
                                <a href="/AdminDashboard/NormalMap" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fas fa-expand-arrows-alt"></i> عرض خريطة الموارد بكامل الشاشة
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        @if (!Model.IsCrisisModeActive)
        {
            <!-- Normal Mode Telemetry Read-out & Governorate Risks -->
            <div class="row g-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                <div class="col-lg-6">
                    <div class="dashboard-card h-100">
                        <h3 class="card-header-sm">
