            // ══════════════════════════════════════════════════════════════
            // DYNAMIC CALENDAR ENGINE
            // ══════════════════════════════════════════════════════════════
            const arabicMonths = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
            const dayLabels = ['ح','ن','ث','ر','خ','ج','س'];
            function toArabicNum(n) {
                const arabicDigits = ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'];
                return String(n).split('').map(d => arabicDigits[parseInt(d)] || d).join('');
            }

            let calYear = new Date().getFullYear();
            let calMonth = new Date().getMonth(); // 0-indexed
            let calMode = 'single'; // 'single' or 'range'
            let rangeStart = null;
            let rangeEnd = null;
            let selectedSingleDay = null;

            function renderCalendar() {
                const grid = $('#calendarGrid');
                grid.empty();

                // Month label
                $('#calendarMonthLabel').text(arabicMonths[calMonth] + ' ' + toArabicNum(calYear));

                // Day labels row
                dayLabels.forEach(label => {
                    grid.append(`<div class="calendar-day-label">${label}</div>`);
                });

                const firstDay = new Date(calYear, calMonth, 1).getDay();
                const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
                const prevMonthDays = new Date(calYear, calMonth, 0).getDate();
                const today = new Date();

                // Previous month filler days
                for (let i = firstDay - 1; i >= 0; i--) {
                    grid.append(`<div class="calendar-day muted">${toArabicNum(prevMonthDays - i)}</div>`);
                }

                // Current month days
                for (let d = 1; d <= daysInMonth; d++) {
                    let classes = 'calendar-day clickable-day';
                    const thisDate = new Date(calYear, calMonth, d);
                    
                    // Highlight today
                    const isToday = (d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear());

                    if (calMode === 'single') {
                        if (selectedSingleDay === d) {
                            classes += ' active';
                        } else if (isToday && selectedSingleDay === null) {
                            classes += ' active';
                        }
                    } else {
                        // Range mode
                        if (rangeStart && rangeEnd) {
                            const startDate = new Date(calYear, calMonth, rangeStart);
                            const endDate = new Date(calYear, calMonth, rangeEnd);
                            if (d === rangeStart) classes += ' range-start active';
                            else if (d === rangeEnd) classes += ' range-end active';
                            else if (d > rangeStart && d < rangeEnd) classes += ' in-range';
                        } else if (rangeStart && d === rangeStart) {
                            classes += ' range-start active';
                        }
                    }

                    grid.append(`<div class="${classes}" data-day="${d}" data-month="${calMonth + 1}" data-year="${calYear}">${toArabicNum(d)}</div>`);
                }

                // Next month filler
                const totalCells = firstDay + daysInMonth;
                const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
                for (let i = 1; i <= remaining; i++) {
                    grid.append(`<div class="calendar-day muted">${toArabicNum(i)}</div>`);
                }

                // Bind click events
                bindCalendarClicks();
            }

            function bindCalendarClicks() {
                $('.clickable-day').off('click').on('click', function() {
                    const day = parseInt($(this).data('day'));
                    const month = parseInt($(this).data('month'));
                    const year = parseInt($(this).data('year'));

                    if (calMode === 'single') {
                        selectedSingleDay = day;
                        renderCalendar();
                        fetchDailyStats(year, month, day);
                    } else {
                        // Range mode
                        if (!rangeStart || (rangeStart && rangeEnd)) {
                            // Start new range
                            rangeStart = day;
                            rangeEnd = null;
                            selectedSingleDay = null;
                            renderCalendar();
                            $('#dailyStatsPanel').slideUp(200);
                        } else {
                            // Set end of range
                            if (day < rangeStart) {
                                rangeEnd = rangeStart;
                                rangeStart = day;
                            } else {
                                rangeEnd = day;
                            }
                            renderCalendar();
                            fetchRangeStats(year, month, rangeStart, rangeEnd);
                        }
                    }
                });
            }

            function fetchDailyStats(year, month, day) {
                const monthNames = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
                $.getJSON('/AdminDashboard/GetDailyStats', { year: year, month: month, day: day }, function(data) {
                    if (data && data.success) {
                        $('#statsPanelTitleText').text(`إحصائيات يوم ${toArabicNum(day)} ${monthNames[month - 1]} ${toArabicNum(year)}`);
                        $('#statsEmergencies').text(data.emergencies);
                        $('#statsAppointments').text(data.appointments);
                        $('#statsDoctors').text(data.activeDoctors);
                        $('#statsBeds').text(data.totalBeds);
                        
                        const isCrisisMode = $('body').hasClass('theme-dark');
                        $('#statsSecondLabel').text(isCrisisMode ? 'الحالات الحرجة' : 'المواعيد المحجوزة');
                        
                        if ($('#dailyStatsPanel').is(':hidden')) {
                            $('#dailyStatsPanel').slideDown(300);
                        } else {
                            $('#dailyStatsPanel').removeClass('animate__fadeInRight').addClass('animate__pulse');
                            setTimeout(() => $('#dailyStatsPanel').removeClass('animate__pulse'), 500);
                        }
                    }
                });
            }

            function fetchRangeStats(year, month, startDay, endDay) {
                const monthNames = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
                const fromStr = `${year}-${String(month).padStart(2, '0')}-${String(startDay).padStart(2, '0')}`;
                const toStr = `${year}-${String(month).padStart(2, '0')}-${String(endDay).padStart(2, '0')}`;

                $.getJSON('/AdminDashboard/GetRangeStats', { from: fromStr, to: toStr }, function(data) {
                    if (data && data.success) {
                        $('#statsPanelTitleText').text(`إحصائيات من ${toArabicNum(startDay)} إلى ${toArabicNum(endDay)} ${monthNames[month - 1]} ${toArabicNum(year)}`);
                        $('#statsEmergencies').text(data.emergencies);
                        $('#statsAppointments').text(data.appointments);
                        $('#statsDoctors').text(data.activeDoctors);
                        $('#statsBeds').text(data.totalBeds);
                        
                        const isCrisisMode = $('body').hasClass('theme-dark');
                        $('#statsSecondLabel').text(isCrisisMode ? 'الحالات الحرجة' : 'المواعيد المحجوزة');
                        
                        if ($('#dailyStatsPanel').is(':hidden')) {
                            $('#dailyStatsPanel').slideDown(300);
                        } else {
                            $('#dailyStatsPanel').removeClass('animate__fadeInRight').addClass('animate__pulse');
                            setTimeout(() => $('#dailyStatsPanel').removeClass('animate__pulse'), 500);
                        }
                    }
                });
            }

            // Calendar navigation
            $('#calendarPrev').on('click', function() {
                calMonth--;
                if (calMonth < 0) { calMonth = 11; calYear--; }
                rangeStart = null; rangeEnd = null; selectedSingleDay = null;
                $('#dailyStatsPanel').slideUp(200);
                renderCalendar();
            });
            $('#calendarNext').on('click', function() {
                calMonth++;
                if (calMonth > 11) { calMonth = 0; calYear++; }
                rangeStart = null; rangeEnd = null; selectedSingleDay = null;
                $('#dailyStatsPanel').slideUp(200);
                renderCalendar();
            });

            // Calendar mode toggle
            $('#calendarModeBtn').on('click', function() {
                if (calMode === 'single') {
                    calMode = 'range';
                    $(this).addClass('active').html('<i class="fas fa-calendar-day me-1"></i> يوم');
                    rangeStart = null; rangeEnd = null; selectedSingleDay = null;
                } else {
                    calMode = 'single';
                    $(this).removeClass('active').html('<i class="fas fa-calendar-week me-1"></i> نطاق');
                    rangeStart = null; rangeEnd = null;
                }
                $('#dailyStatsPanel').slideUp(200);
                renderCalendar();
            });

            // Initial calendar render
            renderCalendar();

            // ══════════════════════════════════════════════════════════════
            // LOAD REAL ACTIVITY FEED
            // ══════════════════════════════════════════════════════════════
            $.getJSON('/AdminDashboard/GetRecentActivities', function(data) {
                if (data && data.success && data.activities.length > 0) {
                    let html = '';
                    data.activities.forEach(function(act) {
                        const timeAgo = getTimeAgo(act.timestamp);
                        const isEmergency = act.type === 'emergency' && act.status === 'Pending';
                        const animClass = isEmergency ? ' animate__animated animate__flash animate__infinite' : '';
                        html += `
                            <div class="activity-item">
                                <div class="activity-avatar ${act.color}${animClass}">
                                    <i class="fas ${act.icon}"></i>
                                </div>
                                <div class="activity-details">
                                    <span class="fw-800 activity-name">${act.title}</span> ${act.description}
                                    <div class="activity-time font-monospace text-muted">${timeAgo}</div>
                                </div>
                            </div>
                        `;
                    });
                    $('#activityFeed').html(html);
                } else {
                    $('#activityFeed').html('<div class="text-center text-muted py-3"><i class="fas fa-inbox me-1"></i> لا توجد نشاطات حديثة</div>');
                }
            });

            function getTimeAgo(dateStr) {
                const date = new Date(dateStr);
                const now = new Date();
                const diffMs = now - date;
                const diffMins = Math.floor(diffMs / 60000);
                const diffHours = Math.floor(diffMs / 3600000);
                const diffDays = Math.floor(diffMs / 86400000);

                if (diffMins < 1) return 'الآن';
                if (diffMins < 60) return `منذ ${toArabicNum(diffMins)} دقيقة`;
                if (diffHours < 24) return `منذ ${toArabicNum(diffHours)} ساعة`;
                if (diffDays < 7) return `منذ ${toArabicNum(diffDays)} يوم`;
                return date.toLocaleDateString('ar-EG');
            }

