                            <div class="table-responsive">
                                <table class="table table-sm table-dark table-hover align-middle m-0" style="font-size: 0.85rem; background: transparent;">
                                    <thead class="table-dark" style="border-bottom: 1px solid rgba(231, 76, 60, 0.3);">
                                        <tr>
                                            <th>المحافظة</th>
