    <!-- ════ Global Ambulance Dispatch Map JS ════ -->
    <script>
    (function() {
        const AVG_KMH  = 40;
        const SPEEDUP  = 12;
        const ANIM_FPS = 15;

        function hvKm(lat1,lng1,lat2,lng2){
            const R=6371,dLat=(lat2-lat1)*Math.PI/180,dLng=(lng2-lng1)*Math.PI/180;
            const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
            return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
        }

        // Default center Egypt
        const gMap = L.map('globalAmbMap').setView([26.8206, 30.8025], 6);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
            {attribution:'&copy; OpenStreetMap &copy; CartoDB'}).addTo(gMap);

        // Live UTC Clock updater
        setInterval(() => {
            const clocks = document.querySelectorAll('.utc-clock');
            if (clocks.length) {
                const now = new Date();
                const pad = (n) => String(n).padStart(2, '0');
                const timeStr = `${pad(now.getUTCHours())}:${pad(now.getUTCMinutes())}:${pad(now.getUTCSeconds())} UTC`;
                clocks.forEach(c => c.textContent = timeStr);
            }
        }, 1000);

        function clearMapLayers() {
            gMap.eachLayer(function (layer) {
                if (layer instanceof L.Marker || layer instanceof L.Polyline) {
                    gMap.removeLayer(layer);
                }
            });
        }

        function initGlobalDispatchMap(data) {
            if (!data || !data.success) return;
            const dispatches = data.dispatches || [];
            const hospitals  = data.hospitals  || [];

            // Clear map layers before rendering new ones
            clearMapLayers();

            // ── Stats ──
            document.getElementById('ambStatTotal').textContent     = dispatches.length;
            document.getElementById('ambStatEnRoute').textContent   = dispatches.length;
            document.getElementById('ambStatHospitals').textContent = hospitals.length;

            let totalEta = 0;
            dispatches.forEach(d => { totalEta += d.etaMinutes || 0; });
            document.getElementById('ambStatAvgEta').textContent =
                dispatches.length > 0 ? Math.round(totalEta / dispatches.length) : 0;

            // ── Hospital markers ──
            hospitals.forEach(h => {
                if (!h.latitude || !h.longitude) return;
                L.marker([h.latitude, h.longitude], {
                    icon: L.divIcon({
                        className:'',
                        html:`<div class="hosp-glow-marker"><i class="fas fa-hospital"></i></div>`,
                        iconSize:[24,24], iconAnchor:[12,12]
                    })
                }).addTo(gMap).bindPopup(`<b>${h.name}</b><br>الأسرة: ${h.availableBeds}`);
            });

            // ── Dispatch ambulances ──
            let tableHtml = '';
            dispatches.forEach((d, idx) => {
                if (!d.patientLat || !d.patientLng || !d.hospitalLat || !d.hospitalLng) return;

                const dist   = hvKm(d.hospitalLat, d.hospitalLng, d.patientLat, d.patientLng);
                const etaMin = Math.round((dist / AVG_KMH) * 60);
                const simMs  = (etaMin * 60000) / SPEEDUP;
                const stepMs = 1000 / ANIM_FPS;
                const steps  = Math.max(1, Math.ceil(simMs / stepMs));

                // Patient marker
                L.marker([d.patientLat, d.patientLng], {
                    icon: L.divIcon({
                        className:'',
                        html:`<div class="patient-glow-marker"><div class="patient-pulse"></div></div>`,
                        iconSize:[14,14], iconAnchor:[7,7]
                    })
                }).addTo(gMap).bindPopup(`<b>${d.patientName}</b><br>${d.emergencyType}`);

                // Route line (Glowing double polyline: back glow + front line)
                const isCyan = (idx % 2 === 0);
                const neonColor = isCyan ? '#00f0ff' : '#ff9f00';
                L.polyline([[d.hospitalLat, d.hospitalLng],[d.patientLat, d.patientLng]], {
                    color: neonColor, weight: 8, opacity: 0.18
                }).addTo(gMap);
                L.polyline([[d.hospitalLat, d.hospitalLng],[d.patientLat, d.patientLng]], {
                    color: neonColor, weight: 2.5, opacity: 0.85
                }).addTo(gMap);

                // Ambulance marker (glowing badge styled exactly like the concept mockup)
                const badgeColorClass = isCyan ? '' : 'orange';
                const ambM = L.marker([d.hospitalLat, d.hospitalLng], {
                    icon: L.divIcon({
                        className:'',
                        html:`<div class="glow-badge ${badgeColorClass}">
                                  <div class="pulse-dot"></div>
                                  <div class="badge-icon">🚑</div>
                                  <div class="badge-text">
                                      <div class="badge-title">AMB-0${idx+1}</div>
                                      <div class="badge-sub">ETA ${etaMin}m to Hosp</div>
                                  </div>
                              </div>`,
                        iconSize:[120,34], iconAnchor:[15,17]
                    }),
                    zIndexOffset: 1000 + idx
                }).addTo(gMap).bindPopup(`إسعاف → ${d.patientName}`);

                // Animate hospital → patient
                let step = 0;
                const timer = setInterval(() => {
                    step = Math.min(step + 1, steps);
                    const t    = step / steps;
                    const ease = t < .5 ? 2*t*t : -1+(4-2*t)*t;
                    ambM.setLatLng([
                        d.hospitalLat + (d.patientLat - d.hospitalLat) * ease,
                        d.hospitalLng + (d.patientLng - d.hospitalLng) * ease
                    ]);
                    if (step >= steps) {
                        clearInterval(timer);
                        // Return to hospital simulation
                        setTimeout(() => {
                            let rs = 0;
                            const rt = setInterval(() => {
                                rs = Math.min(rs + 1, steps);
                                const re = rs < steps ? rs/steps : 1;
                                const ree = re < .5 ? 2*re*re : -1+(4-2*re)*re;
                                ambM.setLatLng([
                                    d.patientLat + (d.hospitalLat - d.patientLat) * ree,
                                    d.patientLng + (d.hospitalLng - d.patientLng) * ree
                                ]);
                                if (rs >= steps) clearInterval(rt);
                            }, stepMs);
                        }, 4000);
                    }
                }, stepMs);

                // Table row
                tableHtml += `<tr>
                    <td><i class="fas fa-hospital-alt text-primary me-1"></i>${d.hospitalName}</td>
                    <td><b>${d.patientName}</b></td>
                    <td><span class="badge bg-light text-dark border">${d.emergencyType}</span></td>
                    <td class="text-center fw-700 text-info">${dist.toFixed(1)} كم</td>
                    <td class="text-center"><span class="badge bg-warning text-dark">${etaMin} د</span></td>
                    <td class="text-center"><span class="badge bg-success">متحرك 🚑</span></td>
                </tr>`;
            });

            if (dispatches.length === 0) {
                tableHtml = `<tr><td colspan="6" class="text-center text-success py-3 fw-700">
                    <i class="fas fa-check-circle me-1"></i> لا توجد سيارات إسعاف متحركة حالياً — الجميع في المستشفيات
                </td></tr>`;
            }

            document.getElementById('globalDispatchBody').innerHTML = tableHtml;

            // Fit map to markers
            if (dispatches.length > 0) {
                const bounds = dispatches.map(d => [[d.patientLat, d.patientLng],[d.hospitalLat,d.hospitalLng]]).flat();
                gMap.fitBounds(bounds, {padding:[30,30]});
            }
        }

        // Expose dispatch map reloading globally
        window.reloadDispatchMap = function() {
            $.getJSON('/AdminDashboard/GetActiveDispatchMap', function(data) {
                initGlobalDispatchMap(data);
            }).fail(function() {
                // Fallback: show map with hospitals only from GetGovernorateRiskStats
                document.getElementById('globalDispatchBody').innerHTML =
                    '<tr><td colspan="6" class="text-center text-muted py-3">لا توجد بيانات طوارئ نشطة متاحة حالياً</td></tr>';
                document.getElementById('ambStatTotal').textContent     = 0;
                document.getElementById('ambStatEnRoute').textContent   = 0;
                document.getElementById('ambStatHospitals').textContent = 0;
                document.getElementById('ambStatAvgEta').textContent    = 0;
                clearMapLayers();
            });
        };

        // Run initial load
        window.reloadDispatchMap();

    })();
    </script>
    <!-- Modal: Control Maintenance Mode -->
    <div class="modal fade" id="maintenanceSettingsModal" tabindex="-1" aria-labelledby="maintenanceSettingsModalLabel" aria-hidden="true" style="direction: rtl;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg text-dark" style="border-radius: 20px; overflow: hidden; background: #ffffff;">
                <div class="modal-header text-white" style="background: linear-gradient(135deg, #1A6FBF 0%, #3cd5cb 100%); border-bottom: none; padding: 20px;">
                    <h5 class="modal-title fw-bold" id="maintenanceSettingsModalLabel">
                        <i class="fas fa-toolbox me-2"></i> التحكم في وضع الصيانة والتنبيهات
                    </h5>
                    <button type="button" class="btn-close btn-close-white ms-0 me-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/AdminDashboard/UpdateMaintenanceSettings" method="post" id="maintenanceForm">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4" style="background-color: #F4F7F9;">
                        
                        <!-- Patient Maintenance -->
                        <div class="card border-0 shadow-sm mb-4 p-3" style="border-radius: 12px; background-color: #ffffff;">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="fw-bold text-primary mb-0"><i class="fas fa-user-injured me-1"></i> صيانة بوابة المرضى</h6>
                                <div class="form-check form-switch p-0 m-0">
                                    <input class="form-check-input ms-0" type="checkbox" name="IsPatientMaintenanceActive" id="IsPatientMaintenanceActive" value="true" @(Etmen_BLL.Helpers.MaintenanceSettingsHelper.IsPatientMaintenanceActive ? "checked" : "") style="width: 45px; height: 22px; cursor: pointer;">
                                </div>
                            </div>
                            <div class="mb-2">
                                <label for="PatientMaintenanceMessage" class="form-label small fw-bold text-muted">رسالة التنبيه للمرضى:</label>
                                <textarea class="form-control" name="PatientMaintenanceMessage" id="PatientMaintenanceMessage" rows="3" style="border-radius: 8px; font-size: 0.9rem;" required>@Etmen_BLL.Helpers.MaintenanceSettingsHelper.PatientMaintenanceMessage</textarea>
                            </div>
                        </div>

                        <!-- Staff Maintenance -->
                        <div class="card border-0 shadow-sm p-3" style="border-radius: 12px; background-color: #ffffff;">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="fw-bold text-primary mb-0"><i class="fas fa-user-tie me-1"></i> صيانة بوابة الموظفين</h6>
                                <div class="form-check form-switch p-0 m-0">
                                    <input class="form-check-input ms-0" type="checkbox" name="IsStaffMaintenanceActive" id="IsStaffMaintenanceActive" value="true" @(Etmen_BLL.Helpers.MaintenanceSettingsHelper.IsStaffMaintenanceActive ? "checked" : "") style="width: 45px; height: 22px; cursor: pointer;">
                                </div>
                            </div>
                            <div class="mb-2">
                                <label for="StaffMaintenanceMessage" class="form-label small fw-bold text-muted">رسالة التنبيه للموظفين:</label>
                                <textarea class="form-control" name="StaffMaintenanceMessage" id="StaffMaintenanceMessage" rows="3" style="border-radius: 8px; font-size: 0.9rem;" required>@Etmen_BLL.Helpers.MaintenanceSettingsHelper.StaffMaintenanceMessage</textarea>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer border-0 p-3" style="background-color: #F4F7F9;">
                        <button type="button" class="btn btn-secondary fw-bold px-4" data-bs-dismiss="modal" style="border-radius: 10px;">إلغاء</button>
                        <button type="submit" class="btn btn-primary fw-bold px-4" style="background: linear-gradient(135deg, #1A6FBF 0%, #3cd5cb 100%); border: none; border-radius: 10px; color: white;">حفظ التغييرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
