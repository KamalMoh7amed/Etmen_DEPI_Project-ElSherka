    <script>
        $(document).ready(function() {
            // Initialize map centered on Cairo
            const map = L.map('embedMap', {
                zoomControl: true,
                attributionControl: false
            }).setView([30.0444, 31.2357], 11);

            const isDark = $('body').hasClass('theme-dark');
            const tileUrl = isDark 
                ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
                : 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png';

            L.tileLayer(tileUrl, {
                maxZoom: 20
            }).addTo(map);

            @if (Model.IsCrisisModeActive)
            {
                <text>
                // Add a mock pulsing crisis circle
                L.circle([30.0444, 31.2357], {
                    color: '#E74C3C',
                    fillColor: '#E74C3C',
                    fillOpacity: 0.25,
                    radius: 2000,
                    weight: 2
                }).addTo(map);
                </text>
            }
            else
            {
                <text>
                // Load normal mode markers asynchronously via API
                $.getJSON('/AdminDashboard/GetMapData', function(data) {
                    if (data && data.success) {
                        
                        // 1. Plot Healthcare Providers (Clinics & Hospitals)
                        data.providers.forEach(function(item) {
                            let color = item.type === 'Hospital' ? '#e74c3c' : '#3498db';
                            let markerHtml = `<div style="background-color: ${color}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.5);"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [12, 12],
                                iconAnchor: [6, 6]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>${item.name}</strong><br/>نوع المنشأة: ${item.type === 'Hospital' ? 'مستشفى' : 'عيادة'}<br/>العنوان: ${item.address || '-'}`)
                                .addTo(map);
                        });

                        // 2. Plot Registered Doctors
                        data.doctors.forEach(function(item) {
                            let markerHtml = `<div style="background-color: #2ecc71; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.5);"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [12, 12],
                                iconAnchor: [6, 6]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>د. ${item.name}</strong><br/>التخصص: ${item.specialization || '-'}<br/>رسوم الاستشارة: ${item.consultationFee || '-'} ج.م.`)
                                .addTo(map);
                        });

                        // 3. Plot Critical Cases (Emergency requests or critical risk assessments)
                        data.criticalCases.forEach(function(item) {
                            let markerHtml = `<div style="background-color: #f1c40f; width: 14px; height: 14px; border-radius: 50%; border: 2px solid red; box-shadow: 0 0 8px rgba(231, 76, 60, 0.8); animation: pulse 1.5s infinite;"></div>`;
                            let customIcon = L.divIcon({
                                html: markerHtml,
                                className: 'custom-div-icon',
                                iconSize: [14, 14],
                                iconAnchor: [7, 7]
                            });

                            let marker = L.marker([item.latitude, item.longitude], { icon: customIcon })
                                .bindPopup(`<strong>حالة طارئة: ${item.patientName}</strong><br/>النوع: ${item.emergencyType || '-'}<br/>التفاصيل: ${item.description || '-'}<br/>الأولوية: ${item.priorityScore}`)
                                .addTo(map);
                        });
                    }
                });
                </text>
            }

            // Load Normal Mode Charts
            @if (!Model.IsCrisisModeActive)
            {
                <text>
                $.getJSON('/AdminDashboard/GetDashboardProjectCharts', function(data) {
                    if (data && data.success) {
                        // 1. Resource Distribution
                        const resourceCtx = document.getElementById('resourceChart').getContext('2d');
                        new Chart(resourceCtx, {
                            type: 'doughnut',
                            data: {
                                labels: ['مستشفيات', 'عيادات', 'أطباء'],
                                datasets: [{
                                    data: [data.resourceDistribution.hospitals, data.resourceDistribution.clinics, data.resourceDistribution.doctors],
                                    backgroundColor: ['#e74c3c', '#3498db', '#2ecc71'],
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom',
                                        labels: { boxWidth: 10, font: { family: 'Tajawal', size: 9 } }
                                    }
                                }
                            }
                        });

                        // 2. Beds by Governorate
                        const bedsCtx = document.getElementById('bedsGovChart').getContext('2d');
                        new Chart(bedsCtx, {
                            type: 'bar',
                            data: {
                                labels: ['القاهرة', 'الجيزة', 'الأسكندرية', 'الشرقية'],
                                datasets: [{
                                    label: 'الأسرة الشاغرة',
                                    data: [data.bedsByGov.cairo, data.bedsByGov.giza, data.bedsByGov.alex, data.bedsByGov.sharqia],
                                    backgroundColor: 'rgba(26, 111, 191, 0.75)',
                                    borderColor: 'rgba(26, 111, 191, 1)',
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: { beginAtZero: true, ticks: { font: { size: 9 } } },
                                    x: { ticks: { font: { size: 9, family: 'Tajawal' } } }
                                },
                                plugins: {
                                    legend: { display: false }
                                }
                            }
                        });

                        // 3. Appointments Trend
                        const dayNamesArabic = {
                            'Sunday': 'الأحد',
                            'Monday': 'الاثنين',
                            'Tuesday': 'الثلاثاء',
                            'Wednesday': 'الأربعاء',
                            'Thursday': 'الخميس',
                            'Friday': 'الجمعة',
                            'Saturday': 'السبت'
                        };
                        const trendLabels = data.appointmentsTrend.map(t => dayNamesArabic[t.Day] || t.Day);
                        const trendValues = data.appointmentsTrend.map(t => t.Count);

                        const trendCtx = document.getElementById('appointmentsTrendChart').getContext('2d');
                        new Chart(trendCtx, {
                            type: 'line',
                            data: {
                                labels: trendLabels.length ? trendLabels : ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'],
                                datasets: [{
                                    label: 'الحجوزات',
                                    data: trendValues.length ? trendValues : [0, 0, 0, 0, 0, 0, 0],
                                    fill: true,
                                    backgroundColor: 'rgba(60, 213, 203, 0.15)',
                                    borderColor: '#3cd5cb',
                                    borderWidth: 2,
                                    tension: 0.3
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: { ticks: { font: { size: 9 } } },
                                    x: { ticks: { font: { size: 9, family: 'Tajawal' } } }
                                },
                                plugins: {
                                    legend: { display: false }
                                }
                            }
                        });
                    }
                });

                // Load Governorate Risk Stats
                $.getJSON('/AdminDashboard/GetGovernorateRiskStats', function(data) {
                    if (data && data.success) {
                        let rowsHtml = '';
                        data.stats.forEach(function(item) {
                            let badgeClass = 'bg-success';
                            if (item.threatLevel === 'خطر مرتفع جداً') {
                                badgeClass = 'bg-danger';
                            } else if (item.threatLevel === 'متوسط الخطورة') {
                                badgeClass = 'bg-warning text-dark';
                            }
                            rowsHtml += `
                                <tr>
                                    <td><strong>${item.governorate}</strong></td>
                                    <td class="text-center font-monospace">${item.totalCases}</td>
                                    <td class="text-center font-monospace text-danger">${item.criticalCases}</td>
                                    <td><span class="badge ${badgeClass}">${item.threatLevel}</span></td>
                                </tr>
                            `;
                        });
                        $('#govRiskTableBody').html(rowsHtml);
                    } else {
                        $('#govRiskTableBody').html('<tr><td colspan="4" class="text-center text-danger">فشل تحميل البيانات</td></tr>');
                    }
                });
                </text>
            }

            // Click handler for interactive calendar days
            $('.clickable-day').on('click', function() {
                $('.calendar-day').removeClass('active');
                $(this).addClass('active');
                const selectedDay = $(this).data('day');
                
                // Fetch daily stats
                $.getJSON('/AdminDashboard/GetDailyStats', { day: selectedDay }, function(data) {
                    if (data && data.success) {
                        $('#statsSelectedDay').text(data.day);
                        $('#statsEmergencies').text(data.emergencies);
                        $('#statsAppointments').text(data.appointments);
                        $('#statsDoctors').text(data.activeDoctors);
                        $('#statsBeds').text(data.occupiedBeds);
                        
                        if ($('#dailyStatsPanel').is(':hidden')) {
                            $('#dailyStatsPanel').slideDown(300);
                        } else {
                            $('#dailyStatsPanel').removeClass('animate__fadeInRight').addClass('animate__pulse');
                            setTimeout(function() {
                                $('#dailyStatsPanel').removeClass('animate__pulse');
                            }, 500);
                        }
                    }
                });
            });
        });
    </script>
    <style>
        @@keyframes pulse {
            0% {
                transform: scale(0.9);
                box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.7);
            }
            70% {
                transform: scale(1.1);
                box-shadow: 0 0 0 10px rgba(231, 76, 60, 0);
            }
            100% {
                transform: scale(0.9);
                box-shadow: 0 0 0 0 rgba(231, 76, 60, 0);
            }
        }
    </style>
</body>
</html>
