@model Etmen_PL.Models.ViewModels.Patient.PatientProfileViewModel
@using Etmen_Domain.Enums
@{
    ViewData["Title"] = "الملف الشخصي والطبي";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";

    // Calculate BMI for card preview
    decimal bmi = 0;
    if (Model.Height.HasValue && Model.Weight.HasValue && Model.Height.Value > 0)
    {
        var h = Model.Height.Value / 100;
        bmi = Math.Round(Model.Weight.Value / (h * h), 1);
    }
}

<style>
    /* Premium Digital Medical Card Design */
    .digital-med-card {
        background: linear-gradient(135deg, var(--dark) 0%, #152A3F 100%);
        color: white;
        border-radius: 24px;
        padding: 2.2rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(15,25,35,0.2);
    }
    
    .digital-med-card::before {
        content: '';
        position: absolute;
        width: 250px; height: 250px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        opacity: 0.25;
        border-radius: 50%;
        bottom: -80px;
        right: -80px;
        filter: blur(40px);
    }

    .med-card-chip {
        width: 50px;
        height: 38px;
        background: linear-gradient(135deg, #f1c40f, #f39c12);
        border-radius: 8px;
        margin-bottom: 2rem;
        position: relative;
        box-shadow: inset 0 1px 4px rgba(255,255,255,0.3);
    }

    .med-card-chip::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-image: 
            linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px);
        background-size: 8px 8px;
    }

    .med-card-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 800;
        letter-spacing: 1.5px;
        margin-bottom: 4px;
    }

    .med-card-value {
        font-weight: 800;
        color: white;
    }

    .bmi-indicator-bar {
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        overflow: hidden;
        margin-top: 10px;
    }
    .bmi-indicator-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.5s ease;
    }

    /* Tabbed navigation design */
    .profile-tabs {
        border-bottom: 2px solid var(--border);
        margin-bottom: 2rem;
    }
    .profile-tab-btn {
        background: none;
        border: none;
        padding: 12px 20px;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--text-muted);
        position: relative;
        transition: all 0.3s;
    }
    .profile-tab-btn:hover {
        color: var(--primary);
    }
    .profile-tab-btn.active {
        color: var(--primary);
    }
    .profile-tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: -2px; left: 0; right: 0;
        height: 3px;
        background-color: var(--primary);
        border-radius: 3px;
    }

    .profile-section-pane {
        animation: fadeIn 0.4s ease;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: var(--primary);
    }
</style>

<div class="row g-4 mb-4">
    <!-- Page Header -->
    <div class="col-12 animate__animated animate__fadeInUp">
        <h2 class="fw-black text-dark"><i class="fas fa-id-card-alt text-primary"></i> إدارة الملف الطبي والشخصي</h2>
        <p class="text-muted">قم بتحديث قياساتك وسجل الأمراض المزمنة بانتظام لضمان دقة الرعاية في الحالات الطارئة.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Right Column: Split Tab Form -->
    <div class="col-lg-8 order-lg-1 order-2 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="med-card">
            <!-- Form Tabs -->
            <div class="profile-tabs d-flex gap-2">
                <button type="button" class="profile-tab-btn active" onclick="switchTab('basic')"><i class="fas fa-user"></i> البيانات الأساسية</button>
                <button type="button" class="profile-tab-btn" onclick="switchTab('vitals')"><i class="fas fa-heartbeat"></i> القياسات الطبية</button>
                <button type="button" class="profile-tab-btn" onclick="switchTab('medical')"><i class="fas fa-notes-medical"></i> السجل المرضي</button>
            </div>

            <!-- Profile Update Form -->
            <form method="post" asp-controller="PatientProfile" asp-action="Index" id="profileForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Pane 1: Basic Info -->
                <div id="tab-basic" class="profile-section-pane">
                    <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-id-card"></i> المعلومات الشخصية العامة</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-bold">الاسم الكامل</label>
                            <input asp-for="FullName" class="form-control" id="formFullName" placeholder="أدخل اسمك بالكامل" required />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-bold">تاريخ الميلاد</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label fw-bold">الجنس</label>
                            <select asp-for="Gender" class="form-select" id="formGender">
                                <option value="">اختر الجنس</option>
                                <option value="Male">ذكر</option>
                                <option value="Female">أنثى</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BloodType" class="form-label fw-bold">فصيلة الدم</label>
                            <select asp-for="BloodType" class="form-select" id="formBloodType">
                                <option value="">اختر فصيلة الدم</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Pane 2: Vitals & Measures -->
                <div id="tab-vitals" class="profile-section-pane" style="display:none;">
                    <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-weight-hanging"></i> المؤشرات الفيزيائية ومستوى الحركة</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Height" class="form-label fw-bold">الطول (سم)</label>
                            <input asp-for="Height" type="number" step="0.1" class="form-control" id="formHeight" placeholder="مثال: 175" />
                            <span asp-validation-for="Height" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Weight" class="form-label fw-bold">الوزن (كجم)</label>
                            <input asp-for="Weight" type="number" step="0.1" class="form-control" id="formWeight" placeholder="مثال: 72" />
                            <span asp-validation-for="Weight" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ActivityLevel" class="form-label fw-bold">مستوى النشاط البدني</label>
                            <select asp-for="ActivityLevel" class="form-select">
                                <option value="@PhysicalActivityLevel.Sedentary">خامل / قليل الحركة جداً</option>
                                <option value="@PhysicalActivityLevel.Light">نشاط بدني خفيف (تمارين خفيفة 1-3 أيام في الأسبوع)</option>
                                <option value="@PhysicalActivityLevel.Moderate">نشاط بدني متوسط (تمارين معتدلة 3-5 أيام في الأسبوع)</option>
                                <option value="@PhysicalActivityLevel.Active">نشط جداً (رياضة قوية يومياً)</option>
                                <option value="@PhysicalActivityLevel.VeryActive">نشط للغاية (تمارين شاقة أو عمل بدني شاق)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Pane 3: Medical History -->
                <div id="tab-medical" class="profile-section-pane" style="display:none;">
                    <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-stethoscope"></i> الحساسيات والأمراض المزمنة والأدوية</h5>
                    
                    <div class="mb-4">
                        <div class="form-check form-switch p-0 pe-4 mb-3">
                            <input asp-for="HasChronicDiseases" class="form-check-input float-end" type="checkbox" id="chronicSwitch">
                            <label class="form-check-label fw-bold me-4" for="chronicSwitch">هل تم تشخيصك بأمراض مزمنة؟</label>
                        </div>
                        
                        <div class="mb-3" id="chronicNotesBox" style="display: @(Model.HasChronicDiseases ? "block" : "none");">
                            <label asp-for="ChronicDiseasesNotes" class="form-label fw-bold">تفاصيل وأسماء الأمراض المزمنة</label>
                            <textarea asp-for="ChronicDiseasesNotes" class="form-control" rows="3" placeholder="مثال: ضغط الدم المرتفع، السكري من النوع الثاني..."></textarea>
                            <span asp-validation-for="ChronicDiseasesNotes" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Allergies" class="form-label fw-bold">حالات الحساسية (شاملة الغذاء والدواء)</label>
                            <textarea asp-for="Allergies" class="form-control" rows="3" placeholder="مثال: حساسية شديدة من البنسلين، الفول السوداني..."></textarea>
                            <span asp-validation-for="Allergies" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CurrentMedications" class="form-label fw-bold">الأدوية والعلاجات الحالية</label>
                            <textarea asp-for="CurrentMedications" class="form-control" rows="3" placeholder="اكتب جرعات وأسماء الأدوية اليومية الحالية..."></textarea>
                            <span asp-validation-for="CurrentMedications" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <button type="submit" class="btn btn-submit w-100 py-3"><i class="fas fa-save"></i> حفظ وتحديث الملف الصحي</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Left Column: Interactive Health Card -->
    <div class="col-lg-4 order-lg-2 order-1 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <div class="digital-med-card">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="fw-bold fs-5"><i class="fas fa-shield-heart text-accent"></i> هوية إطمن الصحية</span>
                <span class="badge bg-success py-1.5 px-3" style="font-size: 0.75rem; border-radius: 6px;">نشط</span>
            </div>

            <!-- Chip decoration -->
            <div class="med-card-chip"></div>

            <!-- Name -->
            <div class="mb-3">
                <div class="med-card-label">اسم المريض</div>
                <div class="fs-4 fw-black text-white" id="cardName">@(string.IsNullOrEmpty(Model.FullName) ? "اسم المريض" : Model.FullName)</div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <div class="med-card-label">الجنس</div>
                    <div class="fw-bold text-white-50" id="cardGender">
                        @(Model.Gender == "Male" ? "ذكر" : Model.Gender == "Female" ? "أنثى" : "—")
                    </div>
                </div>
                <div class="col-6">
                    <div class="med-card-label">فصيلة الدم</div>
                    <div class="fw-bold text-white fs-5" id="cardBloodType">@(string.IsNullOrEmpty(Model.BloodType) ? "—" : Model.BloodType)</div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="med-card-label">الطول</div>
                    <div class="fw-bold text-white" id="cardHeight">@(Model.Height.HasValue ? $"{Model.Height.Value} سم" : "—")</div>
                </div>
                <div class="col-6">
                    <div class="med-card-label">الوزن</div>
                    <div class="fw-bold text-white" id="cardWeight">@(Model.Weight.HasValue ? $"{Model.Weight.Value} كجم" : "—")</div>
                </div>
            </div>

            <div class="border-top pt-3 border-secondary">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="med-card-label">مؤشر كتلة الجسم (BMI)</div>
                        <div class="fw-black fs-2 text-white" id="cardBmi">@(bmi > 0 ? bmi.ToString() : "—")</div>
                    </div>
                    
                    <div class="text-start" id="bmiBadgeBox">
                        @if (bmi > 0)
                        {
                            string category = bmi switch {
                                < 18.5m => "وزن ناقص",
                                < 25m => "وزن مثالي",
                                < 30m => "وزن زائد",
                                _ => "سمنة مفرطة"
                            };
                            string color = bmi switch {
                                < 18.5m => "#F39C12",
                                < 25m => "#27AE60",
                                < 30m => "#E67E22",
                                _ => "#E74C3C"
                            };
                            <span class="badge fw-bold px-3 py-1.5" style="background-color: @color; border-radius: 6px;">@category</span>
                            <div class="bmi-indicator-bar">
                                <div class="bmi-indicator-fill" style="width: @(Math.Min(100, bmi * 2.5m))%; background-color: @color"></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching logic
        function switchTab(tabName) {
            // Hide all panes
            $('.profile-section-pane').hide();
            // Remove active classes
            $('.profile-tab-btn').removeClass('active');
            
            // Show active pane
            $('#tab-' + tabName).fadeIn(250);
            // Add active class to clicked button
            event.currentTarget.classList.add('active');
        }

        // Toggle Chronic Notes container based on Switch status
        $('#chronicSwitch').on('change', function () {
            if (this.checked) {
                $('#chronicNotesBox').slideDown(250);
            } else {
                $('#chronicNotesBox').slideUp(200);
            }
        });

        // Live interaction update from form to digital medical card
        $('#formFullName').on('input', function() {
            var val = $(this).val();
            $('#cardName').text(val.trim() === '' ? 'اسم المريض' : val);
        });

        $('#formGender').on('change', function() {
            var val = $(this).val();
            var text = val === 'Male' ? 'ذكر' : val === 'Female' ? 'أنثى' : '—';
            $('#cardGender').text(text);
        });

        $('#formBloodType').on('change', function() {
            var val = $(this).val();
            $('#cardBloodType').text(val === '' ? '—' : val);
        });

        $('#formHeight, #formWeight').on('input', function() {
            var h = parseFloat($('#formHeight').val()) || 0;
            var w = parseFloat($('#formWeight').val()) || 0;
            
            if (h > 0) {
                $('#cardHeight').text(h + ' سم');
            } else {
                $('#cardHeight').text('—');
            }
            
            if (w > 0) {
                $('#cardWeight').text(w + ' كجم');
            } else {
                $('#cardWeight').text('—');
            }

            if (h > 50 && w > 10) {
                var meterH = h / 100;
                var bmi = (w / (meterH * meterH)).toFixed(1);
                $('#cardBmi').text(bmi);

                // Recalculate badge
                var category = '';
                var color = '';
                if (bmi < 18.5) {
                    category = 'وزن ناقص';
                    color = '#F39C12';
                } else if (bmi < 25) {
                    category = 'وزن مثالي';
                    color = '#27AE60';
                } else if (bmi < 30) {
                    category = 'وزن زائد';
                    color = '#E67E22';
                } else {
                    category = 'سمنة مفرطة';
                    color = '#E74C3C';
                }

                var widthPct = Math.min(100, bmi * 2.5);
                var html = `<span class="badge fw-bold px-3 py-1.5" style="background-color: ${color}; border-radius: 6px;">${category}</span>` +
                           `<div class="bmi-indicator-bar"><div class="bmi-indicator-fill" style="width: ${widthPct}%; background-color: ${color}"></div></div>`;
                $('#bmiBadgeBox').html(html);
            } else {
                $('#cardBmi').text('—');
                $('#bmiBadgeBox').html('');
            }
        });
    </script>
}
